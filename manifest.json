        {
          "id": "CPP007",
          "title": "CPP007: Oxygen Therapy",
          "category": "Respiratory",
          "scope": "RNCC",
          "background": "Oxygen therapy corrects hypoxaemia, not breathlessness. Do not routinely give O2 with normal SpO2 except in critical illness. Always target appropriate SpO2 for patient's condition.",
          "recognition": [
            "Hypoxaemia or critical illness requiring O2 supplementation"
          ],
          "memory_items": [
            "Critical illness \u2192 100% O2 via NRB regardless of SpO2",
            "Most patients: target SpO2 94\u201398%",
            "COPD/chronic hypoxaemia: target SpO2 88\u201392%"
          ],
          "checklist_steps": [
            {
              "step": 1,
              "text": "Assess SpO2 and respiratory status (RSA)",
              "note": ""
            },
            {
              "step": 2,
              "text": "Critical illness present? (cardiac arrest, major trauma, shock, anaphylaxis, seizures, DKA/HHS) \u2192 High-flow 100% O2 via NRB regardless of SpO2",
              "note": ""
            },
            {
              "step": 3,
              "text": "Non-critical: Chronically hypoxaemic patient (COPD, cystic fibrosis, neuromuscular, severe obesity)? \u2192 Target SpO2 88\u201392%",
              "note": ""
            },
            {
              "step": 4,
              "text": "Non-critical, non-chronic: target SpO2 94\u201398%",
              "note": ""
            },
            {
              "step": 5,
              "text": "SpO2 unreliable (peripheral vascular disease, CO poisoning, severe shock, cold extremities): Apply 6\u20138L face mask initially",
