    transform: translateY(-1px);
  }
  .splash-link-icon { font-size: 20px; }
  .splash-link-label { font-size: 12px; font-weight: 600; color: #e2e8f0; }
  .splash-link-sub { font-size: 10px; color: #475569; }

  /* AI Search button */
  .splash-search-btn {
    width: 100%; padding: 14px;
