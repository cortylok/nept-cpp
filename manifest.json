        {
          "id": "CPP002",
          "title": "CPP002: Clinical Approach to Assessment \u2013 Unplanned Major Trauma",
          "category": "Assessment",
          "scope": "ATA",
          "background": "Major trauma assessment departs from traditional ABC order. Priorities target immediate life threat. NEPT crew should use time critical guidelines to determine if patient is trauma time critical.",
          "recognition": [
            "Suspected significant traumatic mechanism or injury"
          ],
          "memory_items": [
            "Priority 1: Massive haemorrhage control (before airway)",
            "Priority 2: Airway",
            "Priority 3: Breathing",
            "Trauma time critical = activate CPP006 and transport urgently"
          ],
          "checklist_steps": [
            {
              "step": 1,
              "text": "Scene safety \u2014 mechanism of injury, hazards",
              "note": ""
            },
            {
              "step": 2,
              "text": "Massive haemorrhage control \u2014 apply arterial tourniquet, pressure dressings as indicated",
              "note": ""
            },
            {
              "step": 3,
              "text": "Airway \u2014 assess and manage. Consider C-spine protection",
              "note": ""
            },
            {
              "step": 4,
              "text": "Breathing \u2014 check ventilation, SpO2. Apply O2. Assess for tension pneumothorax",
              "note": ""
            },
            {
              "step": 5,
              "text": "Circulation \u2014 assess perfusion, control haemorrhage, IV access (RN/RNCC only)",
              "note": "Assess and control haemorrhage"
            },
            {
              "step": 6,
              "text": "Disability \u2014 GCS, pupils, motor/sensory if spinal concern",
              "note": ""
            },
            {
              "step": 7,
              "text": "Expose \u2014 identify all injuries. Maintain temperature",
              "note": ""
            },
            {
              "step": 8,
              "text": "Assess against time critical guidelines. Escalate per CPP006 if met",
              "note": ""
            },
            {
              "step": 9,
              "text": "Splint fractures, apply pelvic splint if suspected pelvic fracture",
              "note": ""
            },
            {
              "step": 10,
              "text": "Analgesia as per CPP029",
              "note": "Paracetamol, Methoxyflurane, Entonox"
            }
          ],
          "special_notes": [],
          "decision_tree": [
            {
              "node": "start",
              "text": "Traumatic mechanism / injury suspected",
              "next": [
                "scene_safe"
              ]
            },
            {
              "node": "scene_safe",
              "text": "Scene safe?",
