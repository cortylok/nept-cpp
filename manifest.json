function enterApp(tab, itemId) {
  var splash = document.getElementById('splash-screen');
  if (splash) {
    splash.classList.add('hidden');
    setTimeout(function(){ splash.style.display = 'none'; }, 500);
  }
  if (tab) {
    switchTab(tab);
    if (itemId) {
      setTimeout(function() {
        currentItem = itemId;
        renderItem(itemId);
        renderNav();
      }, 100);
    }
  }
}

