      "id": "ASSESS_MSA",
      "title": "Mental Status Assessment (MSA)",
      "category": "Assessment Tools",
      "scope_applicable": ["PTO","EN","ATA","RN","RNCC"],
      "background": "The MSA provides a structured framework for assessing patients experiencing acute mental health episodes or behavioural disturbance. Use verbal de-escalation, active listening, and calm/open body language throughout. The MSA is structured across three domains: Observe, Listen, and Discuss.",
      "msa_table": {
        "description": "Table 8: Mental Status Assessment (MSA)",
        "observe": [
          {"category": "Safety", "detail": "Safety of crew, patient and bystanders is the first priority. Assess scene for dangers — location, weapons, aggressive persons. Obtain police support early if required. Maintain vigilant reassessment of scene safety throughout transport."},
          {"category": "Appearance", "detail": "Note grooming, hygiene, dress and self-care. Is clothing appropriate for the weather? Is the patient's appearance consistent with their history? Dishevelled or bizarre dress may indicate acute mental health deterioration."},
          {"category": "Behaviour", "detail": "Observe level of cooperation, eye contact, psychomotor activity (agitation, retardation), abnormal movements, repetitive gestures, or hostile/threatening behaviour. Approach should be calm and non-confrontational."},
          {"category": "Affect/Mood", "detail": "Observe emotional expression — is affect appropriate to the situation? Look for flat/blunted affect, emotional lability, tearfulness, euphoria, or inappropriate emotional responses."}
        ],
        "listen": [
          {"category": "Speech", "detail": "Note rate, volume, quantity and tone. Is the patient speaking excessively or reluctant to engage? Are there tangential or pressured patterns? Flat or monotone speech, or rapid disorganised speech, may indicate psychosis or mania."},
          {"category": "Thought Process", "detail": "Is the patient's thinking logical and goal-directed? Listen for disorganised thinking, loosening of associations, flight of ideas, circumstantial or tangential speech, or perseveration on a single topic."}
        ],
        "discuss": [
          {"category": "Thought Content", "detail": "Explore what the patient is thinking about. Content may be dominated by delusions, obsessions, preoccupations, phobias, suicidal or homicidal thoughts, compulsions, or superstitions."},
          {"category": "Self-harm / Safety", "detail": "Assess for suicidal or self-harm ideation, intent, and plan. Ask directly in a calm, non-judgmental manner. Also assess risk of harm to others. Document and escalate any risk identified."},
          {"category": "Perceptions", "detail": "Enquire about hallucinations — auditory (hearing voices), visual, tactile, olfactory. Ask whether the patient is responding to internal stimuli. Hallucinations may not be volunteered spontaneously."},
          {"category": "Cognition", "detail": "Assess orientation (person, place, time), memory (recent and remote), and concentration. Cognitive impairment may indicate delirium, dementia, or metabolic disturbance — consider organic causes."}
        ]
      },
