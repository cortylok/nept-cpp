<script>
// ── DATA LOADING ─────────────────────────────────────────────────────────
// Data is embedded directly for standalone use.
let NEPT_DATA = null;

function loadData() {
  NEPT_DATA = NEPT_EMBEDDED_DATA;
  init();
}

// ── STATE ─────────────────────────────────────────────────────────────────
let currentScope = 'ATA';
let currentTab = 'protocols';
let currentItem = null;
let checkedSteps = {};
let currentViewMode = 'quick'; // 'quick' or 'full'

function scopeData() { return NEPT_DATA.scope_filtered_views[currentScope]; }

// ── INIT ──────────────────────────────────────────────────────────────────
function init() {
  setScope('ATA');
  initMobileSidebar();
}

// ── MOBILE SIDEBAR ────────────────────────────────────────────────────────
function isMobile() { return window.innerWidth <= 768; }

function toggleSidebar() {
  const sb = document.getElementById('sidebar');
  if (sb.classList.contains('open')) closeSidebar();
  else openSidebar();
}

function openSidebar() {
  const sb = document.getElementById('sidebar');
  const ov = document.getElementById('sidebar-overlay');
  const handle = document.getElementById('sidebar-handle');
  sb.classList.add('open');
  ov.classList.add('visible');
  if (handle) handle.classList.add('hidden');
}

function closeSidebar() {
  const sb = document.getElementById('sidebar');
  const ov = document.getElementById('sidebar-overlay');
  const handle = document.getElementById('sidebar-handle');
  sb.classList.remove('open');
  ov.classList.remove('visible');
  if (handle) handle.classList.remove('hidden');
}

function closeSidebarIfMobile() {
  if (isMobile()) closeSidebar();
}

function initMobileSidebar() {
  const sb = document.getElementById('sidebar');
  const ov = document.getElementById('sidebar-overlay');
  if (!sb) return;
  
  let touchStartX = 0;
  let touchStartY = 0;
  let touchCurrentX = 0;
  let isDragging = false;
  let isOpen = false;
  const edgeZone = 30; // px from left edge to start swipe-open
  
  // Get sidebar width
  function getSbWidth() {
    return Math.min(window.innerWidth * 0.85, 340);
  }
  
  // Touch start - on document for edge swipe, on sidebar for close swipe
  document.addEventListener('touchstart', function(e) {
    if (!isMobile()) return;
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
    isOpen = sb.classList.contains('open');
    
    // Allow swipe-open from left edge
    if (!isOpen && touchStartX < edgeZone) {
      isDragging = true;
      sb.classList.add('dragging');
    }
    // Allow swipe-close from open sidebar
    if (isOpen) {
      isDragging = true;
      sb.classList.add('dragging');
    }
  }, { passive: true });
  
  document.addEventListener('touchmove', function(e) {
    if (!isDragging || !isMobile()) return;
    touchCurrentX = e.touches[0].clientX;
    const deltaX = touchCurrentX - touchStartX;
    const deltaY = e.touches[0].clientY - touchStartY;
    
    // If mostly vertical scroll, cancel drag
    if (Math.abs(deltaY) > Math.abs(deltaX) * 1.5 && Math.abs(deltaX) < 20) {
      isDragging = false;
      sb.classList.remove('dragging');
      if (isOpen) {
        sb.style.transform = '';
        ov.style.opacity = '';
      }
      return;
    }
    
    const sbWidth = getSbWidth();
    
    if (!isOpen) {
      // Opening: translate from -100% towards 0
      const progress = Math.max(0, Math.min(1, deltaX / sbWidth));
      sb.style.transform = 'translateX(' + (-100 + progress * 100) + '%)';
      ov.classList.add('visible');
      ov.style.opacity = progress * 1;
    } else {
      // Closing: translate from 0 towards -100%
      const progress = Math.max(0, Math.min(1, -deltaX / sbWidth));
      sb.style.transform = 'translateX(' + (-progress * 100) + '%)';
      ov.style.opacity = 1 - progress;
    }
  }, { passive: true });
  
  document.addEventListener('touchend', function(e) {
    if (!isDragging || !isMobile()) return;
    isDragging = false;
    sb.classList.remove('dragging');
    sb.style.transform = '';
    ov.style.opacity = '';
    
    const deltaX = touchCurrentX - touchStartX;
    const threshold = getSbWidth() * 0.3;
    
    if (!isOpen) {
      // Was opening
      if (deltaX > threshold) {
        openSidebar();
      } else {
        closeSidebar();
      }
    } else {
      // Was closing
      if (deltaX < -threshold) {
        closeSidebar();
      } else {
        openSidebar();
      }
    }
    
    touchCurrentX = 0;
  }, { passive: true });
}

function setScope(s) {
  currentScope = s;
  document.getElementById('scope-select').value = s;
  if (currentTab === 'scope') {
    renderScopeTable();
    return;
  }
  renderNav();
  if (currentItem) {
    // Re-render current item in new scope context
    const sd = scopeData();
    const p = [...sd.protocols, ...sd.medications].find(x => x.id === currentItem);
    if (p) {
      renderItem(currentItem);
    } else {
      clearContent();
    }
  }
}

function setViewMode(mode) {
  currentViewMode = mode;
  document.getElementById('mode-qr').checked = (mode === 'quick');
  document.getElementById('mode-fp').checked = (mode === 'full');
  if (currentItem) {
    const qrView = document.getElementById('qr-view');
    const fpView = document.getElementById('fp-view');
    if (qrView && fpView) {
      if (mode === 'quick') {
        qrView.style.display = 'block';
        fpView.style.display = 'none';
      } else {
        qrView.style.display = 'none';
        fpView.style.display = 'block';
      }
    }
  }
}

function showModeToggle(show) {
  document.getElementById('mode-toggle-wrap').style.display = show ? 'flex' : 'none';
}

function buildFPFlowchartSVG(tree) {
  if (!tree || !tree.length) return '';

  // ── Detect layout type ──
  var hasColType = tree.some(function(n){ return n.type === 'col_header' || n.type === 'col_body' || n.type === 'col_footer'; });
  if (hasColType) return buildColumnFlowchartSVG(tree);
  return buildBFSFlowchartSVG(tree);
}

// ── COLUMN LAYOUT RENDERER (for severity-column style flowcharts like CPP018) ──
function buildColumnFlowchartSVG(tree) {
  var SVG_W = 900;
  var MARGIN = 14;
  var COL_GAP = 8;
  var PAD_X = 9;
  var PAD_Y = 9;
  var FS = 11.5;
  var LH = 15;
  var RX = 5;
  var ARROW_GAP = 18;

  // Blue severity scale: ice → light → medium → dark
  var COL_COLORS = [
    { bg:'#dbeafe', stroke:'#93c5fd', fg:'#1e3a8a', hbg:'#bfdbfe', hstroke:'#60a5fa' },
    { bg:'#bfdbfe', stroke:'#60a5fa', fg:'#1e3a8a', hbg:'#93c5fd', hstroke:'#3b82f6' },
    { bg:'#3b82f6', stroke:'#2563eb', fg:'#ffffff', hbg:'#2563eb', hstroke:'#1d4ed8' },
    { bg:'#1e3a8a', stroke:'#1e40af', fg:'#ffffff', hbg:'#1e40af', hstroke:'#1e3a8a' },
  ];
  var TOP_BOX_COLOR  = { bg:'#eff6ff', stroke:'#93c5fd', fg:'#1e3a8a' };
  var FOOT_BOX_COLOR = { bg:'#1e3a8a', stroke:'#1e40af', fg:'#ffffff' };
  var ARROW_COLOR    = '#3b82f6';
  var ARROW_DARK     = '#1e3a8a';

  function escSVG(s) {
    return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function wrapText(txt, maxW, fs) {
    fs = fs || FS;
    var cpl = Math.floor(maxW / (fs * 0.535));
    var lines = [];
    txt.split('\n').forEach(function(para) {
      if (!para.trim()) { lines.push(''); return; }
      var words = para.split(' '), line = '';
      words.forEach(function(w) {
        var t = line ? line + ' ' + w : w;
        if (t.length > cpl && line) { lines.push(line); line = w; }
        else line = t;
      });
      if (line) lines.push(line);
    });
    return lines;
  }

  function calcBoxH(txt, w, minH) {
    var lines = wrapText(txt, w - PAD_X*2);
    return Math.max(minH || 32, lines.length * LH + PAD_Y*2);
  }

  function drawBox(out, x, y, w, h, color, text, align) {
    out.push('<rect x="'+x+'" y="'+y+'" width="'+w+'" height="'+h+'" rx="'+RX+
             '" fill="'+color.bg+'" stroke="'+color.stroke+'" stroke-width="1.5"/>');
    var lines = wrapText(text, w - PAD_X*2);
    var totalH = lines.length * LH;
    var ty = y + (h - totalH) / 2 + LH * 0.78;
    lines.forEach(function(line, i) {
      var xpos, anchor;
      if (align === 'center') { xpos = x + w/2; anchor = 'middle'; }
      else { xpos = x + PAD_X; anchor = 'start'; }
      var fw = (i===0 && align==='center') ? 'bold' : 'normal';
      out.push('<text x="'+xpos+'" y="'+( ty + i*LH)+'" font-size="'+FS+
               '" font-weight="'+fw+'" text-anchor="'+anchor+'" fill="'+color.fg+
               '" font-family="system-ui,-apple-system,sans-serif">'+escSVG(line)+'</text>');
    });
  }

  function drawLine(out, x1, y1, x2, y2, color, arrow) {
    var me = arrow ? ' marker-end="url(#fparrow)"' : '';
    out.push('<line x1="'+x1+'" y1="'+y1+'" x2="'+x2+'" y2="'+y2+
             '" stroke="'+( color||ARROW_COLOR)+'" stroke-width="1.8"'+me+'/>');
  }

  function drawDivergeArrows(out, midX, fromY, colCenters, toY, color) {
    var branchY = fromY + Math.round(ARROW_GAP * 0.55);
    drawLine(out, midX, fromY, midX, branchY, color, false);
    drawLine(out, colCenters[0], branchY, colCenters[colCenters.length-1], branchY, color, false);
    colCenters.forEach(function(cx) { drawLine(out, cx, branchY, cx, toY, color, true); });
  }

  function drawConvergeArrows(out, midX, fromY, colCenters, toY, color) {
    var mergeY = fromY + Math.round(ARROW_GAP * 0.55);
    colCenters.forEach(function(cx) { drawLine(out, cx, fromY, cx, mergeY, color, false); });
    drawLine(out, colCenters[0], mergeY, colCenters[colCenters.length-1], mergeY, color, false);
    drawLine(out, midX, mergeY, midX, toY, color, true);
  }

  var topHeaders = tree.filter(function(n){ return n.type==='header'; });
  var colHeaders = tree.filter(function(n){ return n.type==='col_header'; }).sort(function(a,b){ return a.col-b.col; });
  var colBodies  = tree.filter(function(n){ return n.type==='col_body';   }).sort(function(a,b){ return a.col-b.col; });
  var colFooters = tree.filter(function(n){ return n.type==='col_footer'; }).sort(function(a,b){ return a.col-b.col; });
  var botFooters = tree.filter(function(n){ return n.type==='footer'; });

  var numCols = Math.max(colHeaders.length, 4);
  var totalW  = SVG_W - MARGIN*2;
  var colW    = (totalW - COL_GAP*(numCols-1)) / numCols;
  var colCenters = [];
  for (var i = 0; i < numCols; i++) {
    colCenters.push(MARGIN + i*(colW + COL_GAP) + colW/2);
  }
  var midX = SVG_W / 2;
  var out = [];
  var y = MARGIN;

  // Top header boxes — narrowed to ~56% width, centred
  var topBoxW = Math.round(totalW * 0.56);
  var topBoxX = MARGIN + (totalW - topBoxW) / 2;
  topHeaders.forEach(function(h, hi) {
    var bh = calcBoxH(h.text, topBoxW, 36);
    drawBox(out, topBoxX, y, topBoxW, bh, TOP_BOX_COLOR, h.text, 'center');
    y += bh;
    if (hi < topHeaders.length - 1) {
      drawLine(out, midX, y, midX, y + ARROW_GAP, ARROW_COLOR, true);
      y += ARROW_GAP;
    }
  });

  // Diverge arrows
  var divergeFromY = y;
  y += ARROW_GAP;

  // Column headers
  var chH = 0;
  colHeaders.forEach(function(h) { chH = Math.max(chH, calcBoxH(h.text, colW, 30)); });
  chH = Math.max(chH, 30);
  drawDivergeArrows(out, midX, divergeFromY, colCenters, y, ARROW_COLOR);
  colHeaders.forEach(function(h, i) {
    var cx = MARGIN + i*(colW + COL_GAP);
    var c = COL_COLORS[i] || COL_COLORS[3];
    drawBox(out, cx, y, colW, chH, { bg:c.hbg, stroke:c.hstroke, fg:c.fg }, h.text, 'center');
  });
  y += chH;

  // Calculate per-col body and footer heights
  var bodyH  = colBodies.map(function(b)  { return calcBoxH(b.text, colW, 50); });
  var footH  = colFooters.map(function(f) { return f.text ? calcBoxH(f.text, colW, 30) : 0; });
  var colContentH = bodyH.map(function(bh, i) { return bh + (footH[i]>0 ? ARROW_GAP + footH[i] : 0); });
  var maxColH = Math.max.apply(null, colContentH);

  // Body boxes
  var bodyStartY = y + ARROW_GAP;
  colBodies.forEach(function(b, i) {
    var c = COL_COLORS[i] || COL_COLORS[3];
    var cx = MARGIN + i*(colW + COL_GAP);
    drawLine(out, colCenters[i], y, colCenters[i], bodyStartY, c.stroke, true);
    drawBox(out, cx, bodyStartY, colW, bodyH[i], c, b.text, 'left');
  });

  // Footer boxes — bottom-aligned
  var colBottomY = bodyStartY + maxColH;
  colFooters.forEach(function(f, i) {
    if (!f.text) return;
    var c = COL_COLORS[i] || COL_COLORS[3];
    var cx = MARGIN + i*(colW + COL_GAP);
    var fh = footH[i];
    var fTopY = colBottomY - fh;
    var bodyBottomY = bodyStartY + bodyH[i];
    drawLine(out, colCenters[i], bodyBottomY, colCenters[i], fTopY, c.stroke, true);
    drawBox(out, cx, fTopY, colW, fh, c, f.text, 'left');
  });
  y = colBottomY;

  // Converge arrows + bottom footer boxes
  var footerTopY = y + ARROW_GAP;
  drawConvergeArrows(out, midX, y, colCenters, footerTopY, ARROW_DARK);
  y = footerTopY;
  botFooters.forEach(function(f) {
    var bh = calcBoxH(f.text, topBoxW, 36);
    drawBox(out, topBoxX, y, topBoxW, bh, FOOT_BOX_COLOR, f.text, 'center');
    y += bh + MARGIN;
  });

  var svgH = y + MARGIN;
  var prefix = [
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 '+SVG_W+' '+svgH+'" style="width:100%;height:auto;background:#fff;display:block;border:1px solid #bfdbfe;border-radius:8px;font-family:system-ui,-apple-system,sans-serif;">',
    '<defs><marker id="fparrow" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto"><polygon points="0 0,8 3,0 6" fill="'+ARROW_DARK+'"/></marker></defs>'
  ];
  return prefix.join('\n') + '\n' + out.join('\n') + '\n</svg>';
}

// ── BFS LAYOUT RENDERER (for linear/decision flowcharts) ──
function buildBFSFlowchartSVG(tree) {
  if (!tree || !tree.length) return '';
  
  var nodeMap = {};
  tree.forEach(function(n) { nodeMap[n.node] = n; });

  // ── BLUE SCALE (light theme, 4 shades) ──
  var BLUES = [
    { bg:'#dbeafe', stroke:'#93c5fd', fg:'#1e3a5f' },  // ice – low severity
    { bg:'#bfdbfe', stroke:'#60a5fa', fg:'#1e3a5f' },  // soft blue
    { bg:'#3b82f6', stroke:'#2563eb', fg:'#ffffff' },  // mid blue
    { bg:'#1d4ed8', stroke:'#1e40af', fg:'#ffffff' },  // dark – critical
  ];
  var S_START = { bg:'#1e40af', stroke:'#1e3a8a', fg:'#ffffff', pill:true };
  var S_END   = { bg:'#166534', stroke:'#14532d', fg:'#ffffff', pill:true };
  var S_ROSC  = { bg:'#166534', stroke:'#14532d', fg:'#ffffff', pill:true };
  var S_DEC   = { bg:'#fef3c7', stroke:'#d97706', fg:'#78350f' };

  function nodeStyle(node, d) {
    if (node.node === 'start') return S_START;
    if (node.node === 'transport') return S_END;
    if (node.node === 'rosc') return S_ROSC;
    if (!node.yes && !node.no && (!node.next || !node.next.length)) return S_END;
    if (node.type === 'decision') return S_DEC;
    var txt = (node.text||'').toLowerCase();
    var critical = txt.includes('adrenaline') || txt.includes('defibrillat') || 
                   txt.includes('shock') || txt.includes('cpr') || txt.includes('rosc');
    var idx = critical ? 3 : Math.min(Math.floor(d/3), 2);
    return BLUES[idx];
  }

  // ── BFS: compute depth & visit order ──
  var depth = {start:0};
  var queue = ['start'];
  var order = [];
  var inQueue = {start:true};
  while (queue.length) {
    var cur = queue.shift();
    if (order.indexOf(cur) > -1) continue;
    order.push(cur);
    var n = nodeMap[cur];
    if (!n) continue;
    var d = depth[cur];
    var nexts = [];
    if (n.yes) nexts.push(n.yes);
    if (n.no)  nexts.push(n.no);
    if (n.next) nexts = nexts.concat(n.next);
    nexts.forEach(function(nid) {
      if (!(nid in depth)) depth[nid] = d + 1;
      if (!inQueue[nid]) { queue.push(nid); inQueue[nid] = true; }
    });
  }

  // ── LAYOUT CONSTANTS ──
  var SVG_W = 780;
  var MARGIN = 16;
  var COL_GAP = 10;   // gap between branch columns
  var NODE_H_MIN = 52;
  var LINE_H = 19;
  var PAD_X = 14;
  var PAD_Y = 11;
  var ROW_GAP = 16;   // vertical gap between rows
  var ARROW_H = 22;   // connector height

  // ── GROUP NODES BY DEPTH LEVEL ──
  var levels = {};
  order.forEach(function(nid) {
    var d = depth[nid] || 0;
    if (!levels[d]) levels[d] = [];
    if (levels[d].indexOf(nid) === -1) levels[d].push(nid);
  });

  // ── TEXT WRAP ──
  function wrapText(txt, maxW, fs) {
    fs = fs || 13;
    // Remove scope annotations
    txt = txt.replace(/\s*\((?:[A-Z]+\/)*[A-Z]+(?:=[A-Z]+)?\)/g, '');
    txt = txt.replace(/\s+/g, ' ').trim();
    var cpl = Math.floor(maxW / (fs * 0.52));
    if (txt.length <= cpl) return [txt];
    var words = txt.split(' '), lines = [], line = '';
    words.forEach(function(w) {
      var t = line ? line + ' ' + w : w;
      if (t.length > cpl && line) { lines.push(line); line = w; }
      else line = t;
    });
    if (line) lines.push(line);
    return lines;
  }

  function nodeH(nid, w) {
    var node = nodeMap[nid];
    if (!node) return NODE_H_MIN;
    var lines = wrapText(node.text, w - PAD_X*2);
    return Math.max(NODE_H_MIN, lines.length * LINE_H + PAD_Y*2);
  }

  // ── ASSIGN POSITIONS ──
  // For each depth level, compute x extents for each column slot
  // Level with 1 node → full width; 2 nodes → half each; 4 nodes → quarter each
  var pos = {}; // nid -> {x, y, w, h}
  var y = MARGIN;

  var maxLevels = Math.max.apply(null, Object.keys(levels).map(Number));

  for (var lv = 0; lv <= maxLevels; lv++) {
    var nodes = levels[lv] || [];
    if (!nodes.length) continue;
    
    var count = nodes.length;
    var totalW = SVG_W - MARGIN*2;
    var colW = (totalW - COL_GAP*(count-1)) / count;
    
    // Compute max height at this level
    var maxH = 0;
    nodes.forEach(function(nid, i) {
      var h = nodeH(nid, colW);
      maxH = Math.max(maxH, h);
    });
    
    nodes.forEach(function(nid, i) {
      var x = MARGIN + i*(colW + COL_GAP);
      pos[nid] = { x:x, y:y, w:colW, h:maxH };
    });
    
    y += maxH + ARROW_H + ROW_GAP;
  }

  var svgH = y + MARGIN;

  // ── RENDER ──
  var out = [];
  out.push('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 '+SVG_W+' '+svgH+'" ' +
    'style="width:100%;height:auto;background:#f8fafc;display:block;border:1px solid #e2e8f0;border-radius:8px;font-family:system-ui,-apple-system,sans-serif;">');
  out.push('<defs><marker id="fparrow" markerWidth="8" markerHeight="6" refX="6" refY="3" orient="auto">' +
    '<polygon points="0 0,8 3,0 6" fill="#94a3b8"/></marker></defs>');

  // Draw arrows
  order.forEach(function(nid) {
    var n = nodeMap[nid];
    if (!n || !pos[nid]) return;
    
    function arrow(fromId, toId, label) {
      var fp = pos[fromId], tp = pos[toId];
      if (!fp || !tp) return;
      var x1 = fp.x + fp.w/2, y1 = fp.y + fp.h;
      var x2 = tp.x + tp.w/2, y2 = tp.y;
      var my = y1 + (y2-y1)*0.5;
      var path = Math.abs(x1-x2) < 4 ?
        'M'+x1+' '+y1+' L'+x2+' '+y2 :
        'M'+x1+' '+y1+' C'+x1+' '+my+' '+x2+' '+my+' '+x2+' '+y2;
      out.push('<path d="'+path+'" fill="none" stroke="#94a3b8" stroke-width="1.5" marker-end="url(#fparrow)"/>');
      if (label) {
        var lx=(x1+x2)/2, ly=(y1+y2)/2;
        var lc = label==='YES' ? {bg:'#dcfce7',stroke:'#86efac',fg:'#166534'} : {bg:'#fee2e2',stroke:'#fca5a5',fg:'#991b1b'};
        out.push('<rect x="'+(lx-14)+'" y="'+(ly-9)+'" width="28" height="16" rx="3" fill="'+lc.bg+'" stroke="'+lc.stroke+'" stroke-width="1"/>');
        out.push('<text x="'+lx+'" y="'+(ly+4)+'" text-anchor="middle" font-size="9" font-weight="bold" fill="'+lc.fg+'">'+label+'</text>');
      }
    }
    
    if (n.type === 'decision') {
      arrow(nid, n.yes, 'YES');
      arrow(nid, n.no, 'NO');
    } else if (n.next) {
      n.next.forEach(function(nid2) { arrow(nid, nid2); });
    }
  });

  // Draw nodes
  order.forEach(function(nid) {
    var n = nodeMap[nid];
    var p = pos[nid];
    if (!n || !p) return;
    
    var s = nodeStyle(n, depth[nid]||0);
    var lines = wrapText(n.text, p.w - PAD_X*2);
    var textH = lines.length * LINE_H;
    var nh = Math.max(NODE_H_MIN, textH + PAD_Y*2);
    var rx = s.pill ? nh/2 : 6;
    
    out.push('<rect x="'+p.x+'" y="'+p.y+'" width="'+p.w+'" height="'+nh+'" rx="'+rx+'" ' +
      'fill="'+s.bg+'" stroke="'+s.stroke+'" stroke-width="1.5"/>');
    
    var ty = p.y + (nh - textH)/2 + LINE_H*0.78;
    lines.forEach(function(line, i) {
      var esc = line.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      out.push('<text x="'+(p.x+p.w/2)+'" y="'+(ty+i*LINE_H)+'" text-anchor="middle" font-size="13" fill="'+s.fg+'">'+esc+'</text>');
    });
  });
  
  out.push('</svg>');
  return out.join('\n');
}

function renderFullProtocol(protocolId, fullProto) {
  var p = fullProto || (NEPT_DATA && NEPT_DATA.protocols.find(function(x){ return x.id === protocolId; }));
  var title = p ? p.title : protocolId;
  var srcHtml = (typeof SOURCE_CPP_HTML !== 'undefined' && SOURCE_CPP_HTML[protocolId]) 
    ? SOURCE_CPP_HTML[protocolId] : null;
  
  if (srcHtml) {
    // 1. Remove pandoc table separator lines (+---+, +===+, -----)
    srcHtml = srcHtml.replace(/<p class="fp-p">\+[-=+| ]+\+[^<]*<\/p>/g, '');
    srcHtml = srcHtml.replace(/<p class="fp-p">[-]{20,}[^<]*<\/p>/g, '');
    srcHtml = srcHtml.replace(/<p class="fp-p">[=]{10,}[^<]*<\/p>/g, '');
    // 2. Merge fragmented <table class="fp-table"> blocks into a single proper table
    //    Pattern: multiple consecutive <table class="fp-table"><tbody>...</tbody></table>
    //    Collect all <tr> rows from them and wrap in one table
    srcHtml = srcHtml.replace(
      /(<table class="fp-table"><tbody>\s*<tr><th>[\s\S]*?<\/tbody><\/table>\s*)(<table class="fp-table"><tbody>[\s\S]*?<\/tbody><\/table>\s*)+/g,
      function(match) {
        // Extract all <tr>...</tr> rows from all fragments
        var allRows = '';
        var rowMatches = match.match(/<tr>[\s\S]*?<\/tr>/g);
        if (rowMatches) allRows = rowMatches.join('\n');
        return '<div class="fp-table-wrap"><table class="fp-table"><tbody>' + allRows + '</tbody></table></div>';
      }
    );
    // Also wrap single standalone tables that weren't merged
    srcHtml = srcHtml.replace(
      /<table class="fp-table"><tbody>([\s\S]*?)<\/tbody><\/table>/g,
      '<div class="fp-table-wrap"><table class="fp-table"><tbody>$1</tbody></table></div>'
    );
    // Avoid double-wrapping
    srcHtml = srcHtml.replace(/<div class="fp-table-wrap"><div class="fp-table-wrap">/g, '<div class="fp-table-wrap">');
    srcHtml = srcHtml.replace(/<\/div><\/div><\/table><\/div>/g, '</table></div>');
  }

  var html = '<div class="fp-container">';
  html += '<div class="fp-header">';
  html += '<div class="fp-id-badge">' + protocolId + '</div>';
  html += '<div class="fp-main-title">' + (title || protocolId) + '</div>';
  html += '</div>';
  html += '<div class="fp-source-body">';
  
  if (srcHtml) {
    html += srcHtml;
  } else if (p) {
    if (p.background) html += '<p class="fp-p">' + p.background + '</p>';
    if (p.recognition && p.recognition.length) {
      html += '<h3 class="fp-h3">Recognition</h3><ul class="fp-ul">';
      p.recognition.forEach(function(r){ 
        var t = typeof r === 'string' ? r : (r.text || JSON.stringify(r));
        html += '<li>' + t + '</li>';
      });
      html += '</ul>';
    }
  }
  
  if (p && p.decision_tree && p.decision_tree.length) {
    var svg = buildFPFlowchartSVG(p.decision_tree);
    var slot_re = /<div class="fp-flowchart-slot"[^>]*><\/div>/g;
    if (html.search(slot_re) > -1) {
      html = html.replace(slot_re, '<div class="fp-flowchart-wrapper">' + svg + '</div>');
    } else {
      html += '<div class="fp-flowchart-wrapper">' + svg + '</div>';
    }
  }
  
  html += '</div></div>';
  return html;
}


function buildFlowchartSVG(tree, title) {
  var nodeMap = {};
  tree.forEach(function(n) { nodeMap[n.node] = n; });
  
  // Layout constants
  var W = 700;           // SVG width
  var nodeW = 640;       // Node width - fill most of canvas
  var nodeH = 54;        // Min node height
  var lineH = 22;        // Text line height
  var padX = 16;         // Horizontal text padding
  var padY = 14;         // Vertical text padding
  var gapY = 20;         // Gap between nodes
  var branchGap = 10;    // Gap between branch columns
  var arrowH = 28;       // Arrow connector height
  
  // Colours
  var C = {
    startBg: '#1e40af', startTx: '#fff',
    actionBg: '#1e293b', actionTx: '#e2e8f0', actionBorder: '#334155',
    decisionBg: '#92400e', decisionTx: '#fef3c7', decisionBorder: '#b45309',
    yesBg: '#065f46', yesTx: '#d1fae5', yesBorder: '#059669',
    noBg: '#7f1d1d', noTx: '#fecaca', noBorder: '#dc2626',
    endBg: '#065f46', endTx: '#d1fae5', endBorder: '#059669',
    arrow: '#64748b', arrowLabel: '#94a3b8',
    bg: '#0f172a'
  };
  
  // Text wrapping helper
  function wrapText(text, maxChars) {
    // Remove scope annotations for cleaner display
    text = text.replace(/\([^)]*(?:PTO|EN|ATA|RN|RNCC)[^)]*\)/g, '').trim();
    text = text.replace(/\s+/g, ' ');
    if (text.length <= maxChars) return [text];
    var words = text.split(' ');
    var lines = [];
    var line = '';
    for (var i = 0; i < words.length; i++) {
      var test = line ? line + ' ' + words[i] : words[i];
      if (test.length > maxChars && line) {
        lines.push(line);
        line = words[i];
      } else {
        line = test;
      }
    }
    if (line) lines.push(line);
    return lines;
  }
  
  function nodeHeight(text, w) {
    var maxChars = Math.floor(((w || nodeW) - padX * 2) / 7.5);
    var lines = wrapText(text, maxChars);
    return Math.max(nodeH, padY * 2 + lines.length * lineH);
  }
  
  // Build layout by traversing tree
  var elements = []; // {type, x, y, w, h, text, nodeType, ...}
  var rendered = {};
  var currentY = 12;
  
  function escXml(s) {
    return s.replace(/&/g,'&amp;').replace(/\x3c/g,'&lt;').replace(/\x3e/g,'&gt;').replace(/"/g,'&quot;');
  }
  
  function addNode(n, x, y, w) {
    if (!n || rendered[n.node]) return y;
    rendered[n.node] = true;
    
    var h = nodeHeight(n.text, w);
    var ntype = 'action';
    if (n.node === 'start') ntype = 'start';
    else if (n.type === 'decision') ntype = 'decision';
    else if (!n.next || !n.next.length) ntype = 'end';
    
    elements.push({ type: 'node', x: x, y: y, w: w, h: h, text: n.text, nodeType: ntype, nodeId: n.node });
    
    var nextY = y + h;
    
    if (n.type === 'decision' && n.yes && n.no) {
      var yesNode = nodeMap[n.yes];
      var noNode = nodeMap[n.no];
      
      if (yesNode && noNode && !rendered[n.yes] && !rendered[n.no]) {
        // Branch: Yes left, No right
        var branchW = (w - branchGap) / 2;
        var leftX = x;
        var rightX = x + branchW + branchGap;
        
        // Arrow from decision to branches
        var arrowStartY = nextY;
        nextY += arrowH;
        
        // Yes label + arrow
        elements.push({ type: 'arrow', x1: x + branchW/2, y1: arrowStartY, x2: x + branchW/2, y2: nextY, label: 'YES', labelSide: 'left' });
        // No label + arrow
        elements.push({ type: 'arrow', x1: rightX + branchW/2, y1: arrowStartY, x2: rightX + branchW/2, y2: nextY, label: 'NO', labelSide: 'right' });
        // Horizontal connectors from decision center to branch centers
        var cx = x + w/2;
        elements.push({ type: 'line', x1: cx, y1: arrowStartY, x2: x + branchW/2, y2: arrowStartY });
        elements.push({ type: 'line', x1: cx, y1: arrowStartY, x2: rightX + branchW/2, y2: arrowStartY });
        
        var yesH = nodeHeight(yesNode.text, branchW);
        var noH = nodeHeight(noNode.text, branchW);
        
        elements.push({ type: 'node', x: leftX, y: nextY, w: branchW, h: yesH, text: yesNode.text, nodeType: 'yes', nodeId: yesNode.node });
        rendered[yesNode.node] = true;
        elements.push({ type: 'node', x: rightX, y: nextY, w: branchW, h: noH, text: noNode.text, nodeType: 'no', nodeId: noNode.node });
        rendered[noNode.node] = true;
        
        var maxBranchH = Math.max(yesH, noH);
        var branchBottomY = nextY + maxBranchH;
        
        // Continue from yes node's children
        var yesEndY = branchBottomY;
        if (yesNode.next && yesNode.next.length) {
          yesNode.next.forEach(function(nid) {
            var nn = nodeMap[nid];
            if (nn && !rendered[nn.node]) {
              // Arrow from branch bottom to merge point
              elements.push({ type: 'arrow', x1: x + w/2, y1: branchBottomY, x2: x + w/2, y2: branchBottomY + arrowH });
              // Merge lines
              elements.push({ type: 'line', x1: leftX + branchW/2, y1: branchBottomY, x2: x + w/2, y2: branchBottomY });
              elements.push({ type: 'line', x1: rightX + branchW/2, y1: branchBottomY, x2: x + w/2, y2: branchBottomY });
              yesEndY = addNode(nn, x, branchBottomY + arrowH, w);
            }
          });
        }
        if (yesEndY === branchBottomY && noNode.next && noNode.next.length) {
          noNode.next.forEach(function(nid) {
            var nn = nodeMap[nid];
            if (nn && !rendered[nn.node]) {
              elements.push({ type: 'arrow', x1: x + w/2, y1: branchBottomY, x2: x + w/2, y2: branchBottomY + arrowH });
              elements.push({ type: 'line', x1: leftX + branchW/2, y1: branchBottomY, x2: x + w/2, y2: branchBottomY });
              elements.push({ type: 'line', x1: rightX + branchW/2, y1: branchBottomY, x2: x + w/2, y2: branchBottomY });
              yesEndY = addNode(nn, x, branchBottomY + arrowH, w);
            }
          });
        }
        return Math.max(yesEndY, branchBottomY);
      } else {
        // One or both branches already rendered — just continue linearly
        if (yesNode && !rendered[n.yes]) {
          elements.push({ type: 'arrow', x1: x + w/2, y1: nextY, x2: x + w/2, y2: nextY + arrowH, label: 'YES' });
          nextY = addNode(yesNode, x, nextY + arrowH, w);
        }
        if (noNode && !rendered[n.no]) {
          elements.push({ type: 'arrow', x1: x + w/2, y1: nextY, x2: x + w/2, y2: nextY + arrowH, label: 'NO' });
          nextY = addNode(noNode, x, nextY + arrowH, w);
        }
        return nextY;
      }
    }
    
    // Linear next
    if (n.next && n.next.length) {
      for (var i = 0; i < n.next.length; i++) {
        var nn = nodeMap[n.next[i]];
        if (nn && !rendered[nn.node]) {
          elements.push({ type: 'arrow', x1: x + w/2, y1: nextY, x2: x + w/2, y2: nextY + arrowH });
          nextY = addNode(nn, x, nextY + arrowH, w);
        }
      }
    }
    return nextY;
  }
  
  var startNode = tree.find(function(n) { return n.node === 'start'; }) || tree[0];
  var marginX = (W - nodeW) / 2;
  var totalH = addNode(startNode, marginX, currentY, nodeW);
  
  // Render orphan nodes
  tree.forEach(function(n) {
    if (!rendered[n.node]) {
      elements.push({ type: 'arrow', x1: W/2, y1: totalH, x2: W/2, y2: totalH + arrowH });
      totalH = addNode(n, marginX, totalH + arrowH, nodeW);
    }
  });
  
  totalH += 16; // Bottom padding
  
  // Generate SVG
  var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ' + W + ' ' + totalH + '" style="width:100%;max-width:' + W + 'px;height:auto;display:block;margin:0 auto;">';
  svg += '<rect width="' + W + '" height="' + totalH + '" fill="' + C.bg + '" rx="8"/>';
  
  elements.forEach(function(el) {
    if (el.type === 'line') {
      svg += '<line x1="' + el.x1 + '" y1="' + el.y1 + '" x2="' + el.x2 + '" y2="' + el.y2 + '" stroke="' + C.arrow + '" stroke-width="1.5"/>';
    }
    if (el.type === 'arrow') {
      svg += '<line x1="' + el.x1 + '" y1="' + el.y1 + '" x2="' + el.x2 + '" y2="' + el.y2 + '" stroke="' + C.arrow + '" stroke-width="1.5"/>';
      // Arrowhead
      svg += '<polygon points="' + (el.x2-4) + ',' + (el.y2-6) + ' ' + (el.x2+4) + ',' + (el.y2-6) + ' ' + el.x2 + ',' + el.y2 + '" fill="' + C.arrow + '"/>';
      if (el.label) {
        var lx = el.x1 + (el.label === 'YES' || el.labelSide === 'left' ? -20 : 8);
        var ly = (el.y1 + el.y2) / 2 + 4;
        var lcolor = el.label === 'YES' ? '#4ade80' : (el.label === 'NO' ? '#f87171' : C.arrowLabel);
        svg += '<text x="' + lx + '" y="' + ly + '" font-family="monospace" font-size="13" font-weight="700" fill="' + lcolor + '" text-anchor="' + (el.label === 'YES' || el.labelSide === 'left' ? 'end' : 'start') + '">' + el.label + '</text>';
      }
    }
    if (el.type === 'node') {
      var bg, tx, border, rx = 6;
      switch (el.nodeType) {
        case 'start':    bg = C.startBg; tx = C.startTx; border = C.startBg; rx = 20; break;
        case 'decision': bg = C.decisionBg; tx = C.decisionTx; border = C.decisionBorder; break;
        case 'yes':      bg = C.yesBg; tx = C.yesTx; border = C.yesBorder; break;
        case 'no':       bg = C.noBg; tx = C.noTx; border = C.noBorder; break;
        case 'end':      bg = C.endBg; tx = C.endTx; border = C.endBorder; break;
        default:         bg = C.actionBg; tx = C.actionTx; border = C.actionBorder; break;
      }
      
      if (el.nodeType === 'decision') {
        // Diamond-ish shape: rounded rect with distinct border
        svg += '<rect x="' + el.x + '" y="' + el.y + '" width="' + el.w + '" height="' + el.h + '" rx="' + rx + '" fill="' + bg + '" stroke="' + border + '" stroke-width="2"/>';
        svg += '<text x="' + (el.x + 6) + '" y="' + el.y + '" font-family="monospace" font-size="9" font-weight="700" fill="' + border + '">?</text>';
      } else {
        svg += '<rect x="' + el.x + '" y="' + el.y + '" width="' + el.w + '" height="' + el.h + '" rx="' + rx + '" fill="' + bg + '" stroke="' + border + '" stroke-width="1.5"/>';
      }
      
      // Render wrapped text
      var lines = wrapText(el.text, Math.floor((el.w - padX * 2) / 7.5));
      var fs = el.nodeType === 'start' ? 17 : (el.w < 280 ? 14 : 16);
      var fw = (el.nodeType === 'start' || el.nodeType === 'decision') ? '700' : '500';
      var lh = el.w < 280 ? 19 : 22;
      var totalTextH = lines.length * lh;
      var textStartY = el.y + (el.h - totalTextH) / 2 + lh * 0.75;
      
      for (var li = 0; li < lines.length; li++) {
        svg += '<text x="' + (el.x + el.w/2) + '" y="' + (textStartY + li * lh) + '" font-family="system-ui,sans-serif" font-size="' + fs + '" font-weight="' + fw + '" fill="' + tx + '" text-anchor="middle">' + escXml(lines[li]) + '</text>';
      }
    }
  });
  
  svg += '</svg>';
  return svg;
}

function hasMedicationsForScope(protocol, scope) {
  if (!protocol.medications_used || !protocol.medications_used.length) return false;
  if (!protocol.checklist_steps || !protocol.checklist_steps.length) return true; // If no steps, show meds
  
  // Build search terms for each medication (including indirect references)
  var searchTerms = {};
  protocol.medications_used.forEach(function(m) {
    var terms = [m.toLowerCase()];
    // Add indirect references
    if (m === 'PARACETAMOL' || m === 'METHOXYFLURANE' || m === 'ENTONOX') {
      terms.push('analgesia', 'pain relief', 'cpp029');
    }
    if (m === 'GLUCOSE_PASTE') {
      terms.push('glucose paste', 'glucose');
    }
    searchTerms[m] = terms;
  });
  
  for (var si = 0; si < protocol.checklist_steps.length; si++) {
    var step = protocol.checklist_steps[si];
    var text = step.text.toLowerCase();
    var hasMedRef = false;
    
    for (var mi = 0; mi < protocol.medications_used.length; mi++) {
      var terms = searchTerms[protocol.medications_used[mi]];
      for (var ti = 0; ti < terms.length; ti++) {
        if (text.indexOf(terms[ti]) !== -1) { hasMedRef = true; break; }
      }
      if (hasMedRef) break;
    }
    
    if (hasMedRef) {
      var scopes = step.scopes;
      if (Array.isArray(scopes) && scopes.indexOf(scope) !== -1) return true;
      if (typeof scopes === 'object' && !Array.isArray(scopes) && scope in scopes) return true;
    }
  }
  return false;
}

function switchTab(tab) {
  currentTab = tab;
  // Hide splash if showing
  var splash = document.getElementById('splash-screen');
  if (splash) { splash.classList.add('hidden'); setTimeout(function(){ splash.style.display='none'; }, 500); }
  document.querySelectorAll('.tab-btn').forEach((b,i) => {
    b.classList.toggle('active', ['protocols','medications','scope'][i] === tab);
  });
  if (tab === 'scope') {
    closeSidebarIfMobile();
    renderScopeTable();
  } else {
    document.getElementById('sidebar').style.display = '';
    renderNav();
    clearContent();
    // On mobile, open sidebar when switching to protocols/medications tab
    if (isMobile()) openSidebar();
  }
}

function clearContent() {
  document.getElementById('empty-state').style.display = 'flex';
  document.getElementById('viewer').style.display = 'none';
  currentItem = null;
  showModeToggle(false);
}

// ── NAV ───────────────────────────────────────────────────────────────────
const CAT_ORDER = ['Assessment Tools', 'Assessment', 'General', 'Cardiac', 'Respiratory', 'Medical', 'Neurological', 'Airway', 'Trauma'];

function renderNav(filter = '') {
  const sd = scopeData();
  const list = document.getElementById('nav-list');
  list.innerHTML = '';
  const q = filter.toLowerCase();

  if (currentTab === 'protocols') {
    // Group by category
    const groups = {};
    sd.protocols.forEach(p => {
      if (q && !p.title.toLowerCase().includes(q) && !p.id.toLowerCase().includes(q)) return;
      const cat = p.category || 'General';
      if (!groups[cat]) groups[cat] = [];
      groups[cat].push(p);
    });

    const cats = CAT_ORDER.filter(c => groups[c]);
    Object.keys(groups).forEach(c => { if (!cats.includes(c)) cats.push(c); });

    cats.forEach(cat => {
      const hdr = document.createElement('div');
      hdr.className = 'nav-group-header cat-' + cat.replace(/\s+/g, '-');
      hdr.textContent = cat;
      list.appendChild(hdr);
      groups[cat].forEach(p => {
        const item = document.createElement('div');
        item.className = 'nav-item' + (currentItem === p.id ? ' active' : '');
        const catClass = 'dot-' + cat.replace(/\s+/g, '-');
        const shortId = p.id.replace('ASSESS_','').replace('CPP','');
        item.innerHTML = `
          <span class="nav-id">${p.id.startsWith('ASSESS') ? 'ASS' : 'CPP'+shortId.padStart(3,'0')}</span>
          <span class="nav-title">${p.title.replace(/^CPP\d+:\s*/,'').replace(/^NEPT\s*/,'')}</span>
          <span class="nav-dot ${catClass}"></span>
        `;
        item.onclick = () => { currentItem = p.id; renderItem(p.id); renderNav(q); closeSidebarIfMobile(); };
        list.appendChild(item);
      });
    });
  } else if (currentTab === 'medications') {
    const hdr = document.createElement('div');
    hdr.className = 'nav-group-header';
    hdr.textContent = `Medications (${sd.medications.length})`;
    list.appendChild(hdr);
    sd.medications.forEach(m => {
      if (q && !m.name.toLowerCase().includes(q) && !m.id.toLowerCase().includes(q)) return;
      const item = document.createElement('div');
      item.className = 'nav-item' + (currentItem === m.id ? ' active' : '');
      item.innerHTML = `
        <span class="nav-id" style="font-size:9px;min-width:auto;max-width:50px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${m.id}</span>
        <span class="nav-title">${m.name}</span>
        <span class="nav-dot" style="background:var(--purple);"></span>
      `;
      item.onclick = () => { currentItem = m.id; renderItem(m.id); renderNav(q); closeSidebarIfMobile(); };
      list.appendChild(item);
    });
  } else if (currentTab === 'scope') {
    // Scope tab uses full-width main content, no sidebar list needed
  } else if (currentTab === 'appendices') {
    if (!NEPT_DATA.appendices) return;
    const hdr = document.createElement('div');
    hdr.className = 'nav-group-header';
    hdr.textContent = 'Appendices';
    list.appendChild(hdr);
    NEPT_DATA.appendices.forEach(function(app) {
      if (q && !app.title.toLowerCase().includes(q)) return;
      const item = document.createElement('div');
      item.className = 'nav-item' + (currentItem === app.id ? ' active' : '');
      item.innerHTML =
        '<span class="nav-id" style="font-size:9px;min-width:36px;">' + app.icon + '</span>' +
        '<span class="nav-title">' + app.title.replace(/^Appendix \d+: /, '') + '</span>';
      item.onclick = function() { currentItem = app.id; renderAppendix(app.id); renderNav(q); closeSidebarIfMobile(); };
      list.appendChild(item);
    });
  }
}

function doSearch(val) { renderNav(val); }

// ── SCOPE TABLE (full main-content render) ───────────────────────────────
function renderScopeTable() {
  const scopes = ['PTO','EN','ATA','RN','RNCC'];
  const sopData = NEPT_DATA.scope_of_practice_table;
  const scopeIdx = scopes.indexOf(currentScope);

  // Hide sidebar, use full width
  document.getElementById('sidebar').style.display = 'none';
  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('viewer').style.display = 'block';

  // Group by category
  const categories = [];
  let currentCat = null;
  sopData.forEach(row => {
    if (row.category !== currentCat) {
      currentCat = row.category;
      categories.push({ name: currentCat, items: [] });
    }
    categories[categories.length - 1].items.push(row);
  });

  let tableRows = '';
  categories.forEach(cat => {
    tableRows += `<tr class="cat-row">
      <td colspan="1">${cat.name}</td>
      ${scopes.map((s,i) => `<td class="${s === currentScope ? 'scope-active' : ''}"></td>`).join('')}
    </tr>`;
    cat.items.forEach(item => {
      tableRows += `<tr>
        <td>${item.skill}</td>
        ${scopes.map(s => {
          const val = item[s] || 'NO';
          const cls = s === currentScope ? 'scope-active' : '';
          let cellContent = '';
          if (val === 'YES') cellContent = '<span class="scope-cell-yes">✓ YES</span>';
          else if (val === 'TE') cellContent = '<span class="scope-cell-te">TE</span>';
          else cellContent = '<span class="scope-cell-no">—</span>';
          return `<td class="${cls}">${cellContent}</td>`;
        }).join('')}
      </tr>`;
    });
  });

  const html = `
    <div class="scope-full-header">
      <div class="scope-full-title">Scope of Practice — All Levels</div>
      <div class="scope-full-sub">Current role: <strong style="color:var(--accent)">${currentScope}</strong> — ${NEPT_DATA.metadata.scope_descriptions[currentScope]}. Column highlighted for quick reference.</div>
    </div>
    <div class="scope-table-wrap">
      <table class="scope-table">
        <colgroup><col><col><col><col><col><col></colgroup>
        <thead><tr>
          <th>Protocol / Skill</th>
          ${scopes.map(s => `<th class="${s === currentScope ? 'scope-active' : ''}">${s}</th>`).join('')}
        </tr></thead>
        <tbody>${tableRows}</tbody>
      </table>
    </div>
  `;

  document.getElementById('viewer').innerHTML = html;
}

// ── RENDER ITEM ───────────────────────────────────────────────────────────
function renderItem(id) {
  const sd = scopeData();
  const proto = sd.protocols.find(p => p.id === id);
  const med = sd.medications.find(m => m.id === id);

  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('viewer').style.display = 'block';

  if (proto) {
    // Show mode toggle for protocols (not assessment tools without CPP ids)
    const hasCppId = proto.id && proto.id.startsWith('CPP');
    showModeToggle(hasCppId);
    if (proto.id === 'ASSESS_PAED_CALC') {
      renderPaedCalc();
    } else {
      renderProtocol(proto);
    }
  } else if (med) {
    showModeToggle(false);
    renderMedication(med);
  }
}

// ── PROTOCOL RENDERER ─────────────────────────────────────────────────────
function renderProtocol(p) {
  var catClass = 'cat-' + (p.category || 'General').replace(/\s+/g, '-');
  var scope = currentScope;
  var master = NEPT_DATA.protocols.find(function(x) { return x.id === p.id; });
  var cards = master && master.action_cards;

  var html = '<div class="proto-header">' +
    '<div class="proto-category-tag ' + catClass + '">' + (p.category || 'General') + '</div>' +
    '<div class="proto-title">' + p.title + '</div>' +
    '<div class="proto-scope-line">Scope: <span>' + scope + '</span> — ' + NEPT_DATA.metadata.scope_descriptions[scope] + '</div>' +
  '</div>';

  // Background
  if (p.background) {
    html += '<div class="section"><div class="section-title">Background</div>' +
      '<div class="background-text">' + p.background + '</div></div>';
  }
  // Assessment table (use master data - identical across all scopes)
  var assessTable = p.assessment_table;
  if (!assessTable) {
    var _mp = NEPT_DATA.protocols.find(function(x){ return x.id === p.id; });
    if (_mp && _mp.assessment_table) assessTable = _mp.assessment_table;
  }
  if (assessTable) {
    html += '<div class="section"><div class="section-title">Assessment Table</div>' +
      renderAssessTable(assessTable) + '</div>';
  }
  // Not Suitable Criteria
  if (p.not_suitable_criteria) {
    var nsc = p.not_suitable_criteria;
    html += '<div class="section"><div class="section-title" style="color:#f87171;">⛔ Vital Sign Thresholds</div>';
    html += '<div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.3);border-radius:8px;padding:10px;margin-bottom:8px;">';
    (nsc.vital_signs || []).forEach(function(v) {
      html += '<div style="padding:4px 0;font-size:12px;border-bottom:1px solid rgba(239,68,68,0.15);">• ' + v + '</div>';
    });
    html += '</div>';
    if (nsc.exceptions && nsc.exceptions.length) {
      html += '<div style="font-weight:600;font-size:12px;color:#4ade80;margin:8px 0 4px;">✓ Exceptions</div>';
      html += '<div style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.25);border-radius:8px;padding:10px;">';
      nsc.exceptions.forEach(function(e) {
        html += '<div style="padding:4px 0;font-size:11px;border-bottom:1px solid rgba(34,197,94,0.15);">• ' + e + '</div>';
      });
      html += '</div>';
    }
    html += '</div>';
  }
  // Recognition
  if (p.recognition && p.recognition.length) {
    html += '<div class="section"><div class="section-title">Recognition / Criteria</div><div class="recog-list">';
    p.recognition.forEach(function(r) {
      html += '<div class="recog-item">' + (typeof r === 'string' ? r : r.text || r) + '</div>';
    });
    html += '</div></div>';
  }

  // ── ACTION CARDS (Demo C) ─────────────────────────────
  if (cards && cards.length) {
    var scopeCards = cards.filter(function(c) { return !c.scopes || c.scopes.indexOf(scope) !== -1; });
    var userNotes = getUserNotes(p.id);
    var n = 0;

    html += '<div class="section"><div class="section-title">Action Cards</div><div class="action-stack">';

    scopeCards.forEach(function(card, idx) {
      n++;
      // User notes before this card position
      userNotes.forEach(function(note, ni) {
        if (note.position === idx) html += renderSingleUserNote(p.id, note, ni);
      });

      var pc = card.priority === 1 ? 'p1' : card.priority === 2 ? 'p2' : 'p3';
      var scopeNote = card.scope_notes ? card.scope_notes[scope] : null;
      // Skip meaningless scope notes
      if (scopeNote && ['YES','NO','TRUE','FALSE',''].indexOf(scopeNote.trim().toUpperCase()) !== -1) scopeNote = null;
      var badgeHtml = '';
      if (card.badge === 'memory') badgeHtml = '<span class="ac-badge memory">MEMORY</span>';
      else if (card.badge === 'scope') badgeHtml = '<span class="ac-badge scope">SCOPE-DEPENDENT</span>';
      if (scopeNote) {
        var cls = scopeNote.indexOf('TE') !== -1 ? 'te' : 'scope';
        badgeHtml += '<span class="ac-badge ' + cls + '">' + escapeHtml(scopeNote) + '</span>';
      }

      html += '<div class="action-card">';
      html += '<div class="action-card-header">' +
        '<div class="ac-priority ' + pc + '">' + n + '</div>' +
        '<div class="ac-title">' + card.title + '</div>' +
        badgeHtml +
      '</div>';

      // Body
      var hasBody = card.body || card.params || card.scope_params || card.subs || card.branch;
      if (hasBody) {
        html += '<div class="action-card-body">';
        if (card.body) html += linkCPPs(card.body);

        // Params — use scope_params if available, else params
        var params = card.scope_params ? card.scope_params[scope] : card.params;
        if (params && params.length) {
          html += '<div class="ac-params">';
          params.forEach(function(p) { html += '<span class="ac-param">' + linkCPPs(p) + '</span>'; });
          html += '</div>';
        }

        // Sub-sections (e.g. ventilation ratio)
        if (card.subs) {
          card.subs.forEach(function(sub) {
            html += '<div style="margin-top:10px;padding-top:8px;border-top:1px solid var(--border);">';
            html += '<strong style="font-size:12px;color:var(--text);">' + sub.label + '</strong>';
            if (sub.params) {
              html += '<div class="ac-params" style="margin-top:4px;">';
              sub.params.forEach(function(p) { html += '<span class="ac-param">' + p + '</span>'; });
              html += '</div>';
            }
            html += '</div>';
          });
        }

        // Branch (yes/no split)
        if (card.branch) {
          html += '<div class="ac-branch">' +
            '<div class="ac-branch-box yes"><div class="bl">' + card.branch.yes_label + '</div>' + card.branch.yes_text + '</div>' +
            '<div class="ac-branch-box no"><div class="bl">' + card.branch.no_label + '</div>' + card.branch.no_text + '</div>' +
          '</div>';
        }
        html += '</div>'; // close body
      }

      // Footer
      if (card.footer) {
        html += '<div class="ac-footer">' + linkCPPs(card.footer) + '</div>';
      }
      html += '</div>'; // close card

      // Edit mode: add-box button
      html += '<button class="edit-add-box-btn" onclick="openNoteEditor(\'' + p.id + '\', ' + (idx + 1) + ')">+ Add box here</button>';
    });

    // User notes at end
    userNotes.forEach(function(note, ni) {
      if (!note.position || note.position >= scopeCards.length) html += renderSingleUserNote(p.id, note, ni);
    });
    html += '<button class="edit-add-box-btn" onclick="openNoteEditor(\'' + p.id + '\', ' + scopeCards.length + ')">+ Add box</button>';

    html += '</div></div>'; // close action-stack, section

  } else {
    // ── FALLBACK: original memory / checklist / flowchart ─────
    var stepKey = p.id + '_' + scope;
    if (!checkedSteps[stepKey]) checkedSteps[stepKey] = new Set();
    var totalSteps = p.checklist_steps ? p.checklist_steps.length : 0;
    var doneSteps = checkedSteps[stepKey].size;

    if (p.memory_items && p.memory_items.length) {
      html += '<div class="section"><div class="section-title"><span style="color:var(--yellow);">★</span> Memory Items</div><div class="memory-list">';
      p.memory_items.forEach(function(m) { html += '<div class="memory-item">' + linkCPPs(m) + '</div>'; });
      html += '</div></div>';
    }

    // ── AVPU RENDERING ──────────────────────────────────────
    var masterP = NEPT_DATA.protocols.find(function(x){ return x.id === p.id; }) || p;
    if (masterP.avpu) {
      html += '<div class="section"><div class="section-title">AVPU Scale</div>';
      html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">';
      (masterP.avpu.levels || []).forEach(function(item) {
        var colors = {A:'#22c55e',V:'#f59e0b',P:'#f97316',U:'#ef4444'};
        var c = colors[item.level] || 'var(--accent)';
        html += '<div style="padding:10px;border-radius:8px;border:1px solid var(--border);background:var(--card-bg);">';
        html += '<div style="font-size:22px;font-weight:900;color:' + c + ';">' + item.level + '</div>';
        html += '<div style="font-size:11px;color:var(--text);margin-top:4px;">' + item.description + '</div>';
        html += '</div>';
      });
      html += '</div></div>';
    }

    // ── PAT RENDERING ──────────────────────────────────────
    if (masterP.pat_components) {
      var pat = masterP.pat_components;
      var patColors = {appearance:'#818cf8',work_of_breathing:'#38bdf8',circulation_to_skin:'#f472b6'};
      html += '<div class="section"><div class="section-title">Paediatric Assessment Triangle</div>';
      // Triangle SVG
      html += '<svg viewBox="0 0 320 200" style="width:100%;max-width:320px;display:block;margin:0 auto 12px;" xmlns="http://www.w3.org/2000/svg">';
      html += '<polygon points="160,12 8,192 312,192" fill="none" stroke="#334155" stroke-width="2"/>';
      html += '<text x="160" y="36" text-anchor="middle" font-size="13" font-weight="700" fill="#818cf8">Appearance</text>';
      html += '<text x="160" y="50" text-anchor="middle" font-size="9" fill="#94a3b8">TICLS</text>';
      html += '<text x="52" y="185" text-anchor="middle" font-size="10" font-weight="700" fill="#38bdf8">Work of</text>';
      html += '<text x="52" y="196" text-anchor="middle" font-size="10" font-weight="700" fill="#38bdf8">Breathing</text>';
      html += '<text x="268" y="185" text-anchor="middle" font-size="10" font-weight="700" fill="#f472b6">Circulation</text>';
      html += '<text x="268" y="196" text-anchor="middle" font-size="10" font-weight="700" fill="#f472b6">to Skin</text>';
      html += '</svg>';
      // Three component cards
      ['appearance','work_of_breathing','circulation_to_skin'].forEach(function(key) {
        var comp = pat[key];
        if (!comp) return;
        var c = patColors[key] || 'var(--accent)';
        html += '<div style="margin-bottom:10px;padding:10px;border-radius:8px;border-left:3px solid ' + c + ';background:var(--card-bg);">';
        html += '<div style="font-weight:700;font-size:13px;color:' + c + ';margin-bottom:4px;">' + comp.label + '</div>';
        if (comp.mnemonic) html += '<div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;">Mnemonic: <strong>' + comp.mnemonic + '</strong></div>';
        if (comp.detail) html += '<div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;">' + comp.detail + '</div>';
        if (comp.items) {
          if (Array.isArray(comp.items) && comp.items.length && typeof comp.items[0] === 'object' && comp.items[0].key) {
            // TICLS items
            comp.items.forEach(function(item) {
              html += '<div style="padding:5px 0;border-bottom:1px solid var(--border);font-size:11px;display:flex;gap:8px;">';
              html += '<span style="font-weight:700;color:' + c + ';min-width:14px;">' + item.key + '</span>';
              html += '<span><strong>' + item.label + ':</strong> ' + item.detail + '</span>';
              html += '</div>';
            });
          } else {
            comp.items.forEach(function(item) {
              html += '<div style="padding:4px 0;border-bottom:1px solid var(--border);font-size:11px;">• ' + item + '</div>';
            });
          }
        }
        html += '</div>';
      });
      // Interpretation
      if (masterP.pat_interpretation) {
        html += '<details><summary style="cursor:pointer;font-size:12px;color:var(--text-muted);font-weight:600;">PAT Interpretation Guide</summary>';
        html += '<div style="margin-top:8px;">';
        masterP.pat_interpretation.forEach(function(interp) {
          html += '<div style="padding:6px 8px;margin:3px 0;border-radius:6px;background:var(--card-bg);border:1px solid var(--border);font-size:11px;">';
          html += '<strong style="color:var(--text);">' + interp.pattern + '</strong><br>';
          html += '<span style="color:var(--text-muted);">' + interp.implication + '</span>';
          html += '</div>';
        });
        html += '</div></details>';
      }
      html += '</div>';
    }

    // ── SAT / MSA RENDERING ────────────────────────────────
    if (masterP.sat_table) {
      var sat = masterP.sat_table;
      html += '<div class="section"><div class="section-title">Sedation Assessment Tool (SAT)</div>';
      html += '<div style="font-size:11px;color:var(--text-muted);margin-bottom:8px;">' + sat.description + '</div>';
      html += '<div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:11px;">';
      html += '<thead><tr style="background:var(--panel-bg);"><th style="padding:6px 8px;text-align:left;border:1px solid var(--border);">Score</th><th style="padding:6px 8px;text-align:left;border:1px solid var(--border);">Responsiveness</th><th style="padding:6px 8px;text-align:left;border:1px solid var(--border);">Speech</th></tr></thead><tbody>';
      (sat.rows || []).forEach(function(row) {
        var sc = parseInt(row.score);
        var bgColor = sc >= 2 ? 'rgba(239,68,68,0.15)' : sc === 1 ? 'rgba(249,115,22,0.1)' : sc === 0 ? 'rgba(34,197,94,0.1)' : sc === -1 ? 'rgba(249,115,22,0.1)' : 'rgba(239,68,68,0.15)';
        var noteHtml = row.note ? ' <span style="font-size:9px;color:var(--accent);font-style:italic;">(' + row.note + ')</span>' : '';
        html += '<tr style="background:' + bgColor + ';">';
        html += '<td style="padding:5px 8px;border:1px solid var(--border);font-weight:700;color:' + (sc > 0 ? '#f87171' : sc === 0 ? '#4ade80' : '#94a3b8') + ';">' + row.score + noteHtml + '</td>';
        html += '<td style="padding:5px 8px;border:1px solid var(--border);">' + row.responsiveness + '</td>';
        html += '<td style="padding:5px 8px;border:1px solid var(--border);">' + row.speech + '</td>';
        html += '</tr>';
      });
      html += '</tbody></table></div></div>';
    }
    if (masterP.msa_table) {
      var msa = masterP.msa_table;
      var msaColors = {observe:'#818cf8',listen:'#38bdf8',discuss:'#4ade80'};
      var msaIcons = {observe:'👁',listen:'👂',discuss:'💬'};
      html += '<div class="section"><div class="section-title">Mental Status Assessment (MSA)</div>';
      html += '<div style="font-size:11px;color:var(--text-muted);margin-bottom:10px;">Look for, listen to and ask about all categories below. Use verbal de-escalation, active listening, and calm/open body language.</div>';
      ['observe','listen','discuss'].forEach(function(domain) {
        var items = msa[domain];
        if (!items || !items.length) return;
        var c = msaColors[domain] || 'var(--accent)';
        var icon = msaIcons[domain] || '';
        html += '<div style="margin-bottom:12px;">';
        html += '<div style="font-weight:700;font-size:13px;color:' + c + ';margin-bottom:6px;text-transform:uppercase;letter-spacing:1px;">' + icon + ' ' + domain + '</div>';
        items.forEach(function(item) {
          html += '<div style="padding:8px 10px;margin:4px 0;border-radius:7px;border-left:3px solid ' + c + ';background:var(--card-bg);">';
          html += '<div style="font-weight:600;font-size:12px;color:var(--text);margin-bottom:3px;">' + item.category + '</div>';
          html += '<div style="font-size:11px;color:var(--text-muted);">' + item.detail + '</div>';
          html += '</div>';
        });
        html += '</div>';
      });
      html += '</div>';
    }
    // ── END NEW RENDERERS ──────────────────────────────────

    if (p.checklist_steps && p.checklist_steps.length) {
      html += '<div class="section"><div class="section-title" style="display:flex;align-items:center;gap:8px;"><span>Checklist</span><div style="flex:1;height:1px;background:var(--border);"></div><button class="reset-btn" onclick="resetChecklist(\'' + p.id + '\')">Reset</button></div>';
      html += '<div class="checklist-progress"><div class="progress-bar-track"><div class="progress-bar-fill" id="prog-fill-' + p.id + '" style="width:' + (totalSteps ? doneSteps/totalSteps*100 : 0) + '%"></div></div><div class="progress-text" id="prog-text-' + p.id + '">' + doneSteps + '/' + totalSteps + '</div></div>';
      html += '<div class="checklist" id="checklist-' + p.id + '">';
      p.checklist_steps.forEach(function(step) {
        var checked = checkedSteps[stepKey].has(step.step);
        var isTE = step.note && step.note.indexOf('TE') !== -1;
        html += '<div class="check-item' + (checked ? ' checked' : '') + '" onclick="toggleStep(\'' + p.id + '\', ' + step.step + ')">' +
          '<span class="check-num">' + step.step + '</span>' +
          '<div class="check-box">' + (checked ? '✓' : '') + '</div>' +
          '<span class="check-text">' + linkCPPs(step.text) + '</span>' +
          (step.note ? '<span class="check-note' + (isTE ? ' te-badge' : '') + '">' + step.note + '</span>' : '') +
        '</div>';
      });
      html += '</div></div>';
    }
    if (p.decision_tree && p.decision_tree.length) {
      html += '<div class="section"><div class="section-title">Clinical Flowchart</div>' +
        '<div class="flowchart-svg-wrap">' + buildFlowchartSVG(p.decision_tree, p.title || '') + '</div></div>';
    }
  }

  // Medications
  if (p.medications_used && p.medications_used.length) {
    if (hasMedicationsForScope(p, scope)) {
      html += '<div class="section"><div class="section-title">Medications &amp; Dosing</div><div class="med-dose-cards">';
      p.medications_used.forEach(function(mid) {
        var card = renderMedDoseCard(mid, scope);
        if (card) html += card;
      });
      html += '</div></div>';
    }
  }
  // Special notes
  if (p.special_notes && p.special_notes.length) {
    var snotes = p.special_notes.filter(function(n) { return typeof n === 'string'; });
    if (snotes.length) {
      html += '<div class="section"><div class="section-title">Special Notes</div>';
      snotes.forEach(function(n) { html += '<div class="special-note">' + linkCPPs(n) + '</div>'; });
      html += '</div>';
    }
  }

  // Full protocol view
  var fullProto = NEPT_DATA.protocols.find(function(x) { return x.id === p.id; });
  var fpHtml = renderFullProtocol(p.id, fullProto);
  var qrD = currentViewMode === 'quick' ? 'block' : 'none';
  var fpD = currentViewMode === 'full' ? 'block' : 'none';
  document.getElementById('viewer').innerHTML =
    '<div id="qr-view" style="display:' + qrD + ';">' + html + '</div>' +
    '<div id="fp-view" style="display:' + fpD + ';">' + fpHtml + '</div>';
}

function renderAssessTable(table) {
  if (!table) return '';
  
  // GCS interactive table
  if (table.eye_response && table.verbal_response && table.motor_response) {
    return renderGCSTable(table);
  }
  
  // PSA table: grades as columns, parameters as rows
  if (table.type === 'psa' && table.grades && table.parameters) {
    const keyMap = {
      'Skin': 'skin', 'Pulse (BPM)': 'pulse', 'BP (Systolic)': 'bp',
      'Conscious State': 'conscious_state', 'Capillary Refill': 'cap_refill',
      'Blood Pressure': 'bp', 'Pulse': 'pulse', 'Capillary refill': 'cap_refill'
    };
    const colors = ['var(--green)','#a3e635','var(--orange)','#f87171','#ef4444'];
    let html = '<div style="overflow-x:auto;-webkit-overflow-scrolling:touch;">';
    html += '<table class="assess-table psa-table"><thead><tr><th style="min-width:90px">Parameter</th>';
    table.grades.forEach((g, i) => {
      html += '<th style="min-width:90px;color:'+colors[i]+'">' + g.grade + '</th>';
    });
    html += '</tr></thead><tbody>';
    table.parameters.forEach(param => {
      const key = keyMap[param] || param.toLowerCase().replace(/[\s()\/]/g,'_');
      html += '<tr><td style="font-weight:600;font-size:11px;">' + param + '</td>';
      table.grades.forEach((g, i) => {
        const val = (g[key] || '—').replace(/\\n/g,'<br>');
        html += '<td style="font-size:11px;">' + val + '</td>';
      });
      html += '</tr>';
    });
    html += '</tbody></table></div>';
    return html;
  }

  // RSA table: grades as columns, parameters as rows
  if (table.type === 'rsa' && table.grades && table.parameters) {
    const keyMap = {
      'General Appearance': 'appearance', 'Speech': 'speech',
      'Breath Sounds & Auscultation': 'sounds', 'Breath Sounds': 'sounds',
      'Respiratory Rate': 'rr', 'Respiratory Rhythm': 'rhythm',
      'Work of Breathing': 'work', 'Heart Rate': 'hr',
      'Skin': 'skin', 'Conscious State': 'conscious_state'
    };
    const gradeColors = ['var(--green)','#a3e635','var(--orange)','#f87171','#ef4444'];
    let html = '<div style="overflow-x:auto;-webkit-overflow-scrolling:touch;">';
    html += '<table class="assess-table rsa-table"><thead><tr><th style="min-width:100px">Parameter</th>';
    table.grades.forEach((g, i) => {
      html += '<th style="min-width:100px;color:'+gradeColors[i]+'">' + g.grade + '</th>';
    });
    html += '</tr></thead><tbody>';
    table.parameters.forEach(param => {
      const key = keyMap[param] || param.toLowerCase().replace(/[\s&\/]/g,'_');
      html += '<tr><td style="font-weight:600;font-size:11px;">' + param + '</td>';
      table.grades.forEach(g => {
        const val = (g[key] || '—').replace(/\\n/g,'<br>');
        html += '<td style="font-size:11px;line-height:1.4;">' + val + '</td>';
      });
      html += '</tr>';
    });
    html += '</tbody></table></div>';
    return html;
  }

  // Legacy PSA grades table (parameters as rows)
  if (table.grades && table.parameters) {
    let html = '<div style="overflow-x:auto;-webkit-overflow-scrolling:touch;">';
    html += '<table class="assess-table"><thead><tr><th>Parameter</th>';
    table.grades.forEach(g => { html += '<th>' + g.grade + '</th>'; });
    html += '</tr></thead><tbody>';
    table.parameters.forEach(param => {
      html += '<tr><td>' + param + '</td>';
      table.grades.forEach(g => {
        const key = param.toLowerCase().replace(/\s+/g, '_');
        html += '<td>' + (g[key] || '—') + '</td>';
      });
      html += '</tr>';
    });
    html += '</tbody></table></div>';
    return html;
  }
  
  // Simple grades table (grades as rows, key/value columns)
  if (table.grades && !table.parameters) {
    let html = '<table class="assess-table"><thead><tr><th>Grade</th><th>Description</th></tr></thead><tbody>';
    table.grades.forEach(g => {
      html += '<tr><td style="font-weight:600;">' + (g.grade || g.level || '') + '</td><td>' + (g.description || g.criteria || '') + '</td></tr>';
    });
    html += '</tbody></table>';
    return html;
  }
  
  // AVPU levels
  if (table.levels) {
    let html = '<table class="assess-table"><thead><tr><th>Level</th><th>Description</th></tr></thead><tbody>';
    table.levels.forEach(l => {
      html += '<tr><td style="font-weight:600;font-family:var(--mono);font-size:13px;">' + (l.letter || l.level || '') + '</td><td>' + (l.description || l.meaning || '') + '</td></tr>';
    });
    html += '</tbody></table>';
    return html;
  }
  
  // Generic rows/headers table
  if (table.rows) {
    return '<table class="assess-table">' +
      (table.headers ? '<thead><tr>' + table.headers.map(function(h){ return '<th>'+h+'</th>'; }).join('') + '</tr></thead>' : '') +
      '<tbody>' + table.rows.map(function(row){ return '<tr>' + row.map(function(c){ return '<td>'+c+'</td>'; }).join('') + '</tr>'; }).join('') + '</tbody>' +
      '</table>';
  }
  
  return '';
}

// ── PAEDIATRIC WEIGHT & DRUG CALCULATOR ──────────────────────────────────
function renderPaedCalc() {
  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('viewer').style.display = 'block';
  document.getElementById('viewer').innerHTML = `
  <div class="paed-calc">
    <div class="paed-calc-header">
      <div class="paed-calc-icon">👶</div>
      <div>
        <div class="paed-calc-title">Paediatric Weight & Drug Calculator</div>
        <div class="paed-calc-sub">NEPT CPP 2024 · Tables 5, 6, CPP005, CPP029</div>
      </div>
    </div>

    <div class="paed-calc-inputs">
      <div class="paed-input-group">
        <label class="paed-label">Age</label>
        <div id="paed_age_wheel_container"></div>
      </div>
      <div class="paed-input-sep">— or —</div>
      <div class="paed-input-group">
        <label class="paed-label">Known weight</label>
        <div class="paed-age-row">
          <input type="number" id="paed-weight-val" min="1" max="70" step="0.5" placeholder="—"
            oninput="paedCalcUpdate()" class="paed-input" style="width:90px">
          <span class="paed-unit-label">kg</span>
        </div>
      </div>
    </div>

    <div id="paed-calc-result" class="paed-result-area" style="display:none"></div>
  </div>`;
  setTimeout(function() {
    var cont = document.getElementById('paed_age_wheel_container');
    if (cont) {
      cont.innerHTML = buildAgeWheel('paed_main_age', 'years', 16, function() { paedCalcUpdate(); });
    }
  }, 0);
}

function paedCalcUpdate() {
  var knownKg = parseFloat(document.getElementById('paed-weight-val').value);
  var _aw = ageWheelGet('paed_main_age');
  var ageVal  = (_aw && _aw.value !== null) ? _aw.value : NaN;
  var ageUnit = (_aw && _aw.unit) ? _aw.unit : 'years';

  var weightKg = null;
  var ageMonths = null;
  var ageLabel = '';
  var ageGroup = '';

  if (!isNaN(knownKg) && knownKg > 0) {
    weightKg = knownKg;
    ageLabel = 'Known weight: ' + knownKg.toFixed(1) + ' kg';
    // Estimate age group from weight
    if (knownKg <= 4) ageGroup = 'newborn';
    else if (knownKg <= 6) ageGroup = 'small_infant';
    else if (knownKg <= 10) ageGroup = 'large_infant';
    else if (knownKg <= 20) ageGroup = 'small_child';
    else ageGroup = 'medium_child';
  } else if (!isNaN(ageVal) && ageVal >= 0) {
    ageMonths = ageUnit === 'years' ? ageVal * 12 : ageVal;
    ageLabel = ageVal + ' ' + ageUnit;
    if (ageMonths < 0.1) { ageGroup = 'newborn'; weightKg = 3.5; }
    else if (ageMonths < 3) { ageGroup = 'small_infant'; weightKg = 6; }
    else if (ageMonths < 12) { ageGroup = 'large_infant'; weightKg = 8; }
    else if (ageMonths < 48) {
      ageGroup = 'small_child';
      var yrs = ageMonths / 12;
      weightKg = Math.round((yrs * 2 + 8) * 10) / 10;
    } else if (ageMonths < 132) {
      ageGroup = 'medium_child';
      var yrs = ageMonths / 12;
      weightKg = Math.round(yrs * 3.3 * 10) / 10;
    } else {
      ageGroup = 'adolescent'; weightKg = Math.min(70, Math.round(ageMonths/12 * 3.3));
    }
  }

  if (weightKg === null) {
    document.getElementById('paed-calc-result').style.display = 'none';
    return;
  }

  // VSS lookup table [age_label, weight, sbp_range, hr_range, rr_range]
  var vssTable = [
    ['Term newborn',  3.5,  '60–95',  '120–185', '25–60'],
    ['3 months',      6,    '60–105', '115–180',  '25–60'],
    ['6 months',      8,    '75–105', '110–180',  '20–55'],
    ['1 year',        10,   '70–105', '105–180',  '20–45'],
    ['2 years',       12,   '70–105', '95–175',   '20–40'],
    ['4 years',       15,   '75–110', '80–150',   '17–30'],
    ['6 years',       20,   '80–115', '75–140',   '16–30'],
    ['8 years',       25,   '80–115', '70–130',   '16–30'],
    ['10 years',      30,   '85–120', '60–130',   '15–25'],
    ['12 years',      40,   '90–120', '65–120',   '15–25'],
    ['14 years',      50,   '90–125', '60–115',   '14–25'],
    ['16 years',      60,   '90–130', '60–115',   '14–25'],
  ];
  // Find closest VSS row
  var vss = vssTable[0];
  var minDiff = 999;
  vssTable.forEach(function(row) {
    var diff = Math.abs(row[1] - weightKg);
    if (diff < minDiff) { minDiff = diff; vss = row; }
  });

  // Calculations
  var defibJ = Math.round(weightKg * 4);
  var defibDisplay = defibJ + ' J (4 J/kg — round UP to nearest setting)';

  // Drug doses
  var paracetamol_mg = Math.round(weightKg * 15);
  var paracetamol_max = Math.min(paracetamol_mg, 1000);
  var adr_im_mcg = Math.round(weightKg * 10); // 0.01mg/kg = 10mcg/kg IM
  var adr_im_mg  = Math.min(0.5, Math.round(weightKg * 0.01 * 100) / 100); // capped 0.5mg
  var adr_im_ml  = adr_im_mg.toFixed(2); // 1:1000 = 1mg/mL
  var adr_iv_mg = (weightKg * 0.01).toFixed(2);
  var salb_puff = weightKg < 20 ? 4 : 8;
  var gluc_paste_g = weightKg < 25 ? 15 : 20;
  var methox_ml = weightKg >= 20 ? '3 mL' : (weightKg >= 10 ? '1.5–3 mL' : 'Not recommended <10kg');

  // CPR technique
  var cprTech = '';
  if (ageGroup === 'newborn') cprTech = 'Newborn: 3:1 · 90/min · 2-finger or 2-thumb · 1/3 chest depth';
  else if (ageGroup === 'small_infant' || ageGroup === 'large_infant') cprTech = 'Infant: 30:2 (1 rescuer) or 15:2 (2 rescuers) · 100–120/min · 2-thumb encircling or 2-finger · 1/3 chest';
  else cprTech = 'Child: 30:2 (1 rescuer) or 15:2 (2 rescuers) · 100–120/min · 1 or 2 hands · 1/3 chest';

  var groupLabels = {
    newborn: 'Newborn (0–24h)',
    small_infant: 'Small Infant (<3 months)',
    large_infant: 'Large Infant (3–12 months)',
    small_child: 'Small Child (1–4 years)',
    medium_child: 'Medium Child (5–11 years)',
    adolescent: 'Adolescent (≥12 years — use adult CPP)'
  };

  var html = '<div class="paed-result">';
  
  // Weight summary
  html += '<div class="paed-result-header">';
  html += '<div class="paed-result-age">' + ageLabel + '</div>';
  html += '<div class="paed-result-weight">Est. weight: <span>' + weightKg.toFixed(1) + ' kg</span></div>';
  html += '<div class="paed-result-group">' + (groupLabels[ageGroup] || ageGroup) + '</div>';
  html += '</div>';

  // Vital signs
  html += '<div class="paed-section-title">📊 Acceptable Vital Signs (Table 5)</div>';
  html += '<div class="paed-vss-grid">';
  html += '<div class="paed-vss-card"><div class="paed-vss-label">Systolic BP</div><div class="paed-vss-val">' + vss[2] + '</div><div class="paed-vss-unit">mmHg</div></div>';
  html += '<div class="paed-vss-card"><div class="paed-vss-label">Heart Rate</div><div class="paed-vss-val">' + vss[3] + '</div><div class="paed-vss-unit">bpm</div></div>';
  html += '<div class="paed-vss-card"><div class="paed-vss-label">Resp Rate</div><div class="paed-vss-val">' + vss[4] + '</div><div class="paed-vss-unit">breaths/min</div></div>';
  html += '</div>';
  html += '<div class="paed-vss-note">Reference row: ' + vss[0] + ' (' + vss[1] + ' kg)</div>';

  // Defibrillation
  html += '<div class="paed-section-title">⚡ Defibrillation (CPP005)</div>';
  html += '<div class="paed-drug-row"><div class="paed-drug-name">Initial shock energy</div><div class="paed-drug-dose accent">' + defibDisplay + '</div></div>';
  if (ageGroup === 'newborn' || ageGroup === 'small_infant') {
    html += '<div class="paed-drug-row paed-note-row"><div class="paed-drug-name">⚠️ Note</div><div class="paed-drug-dose">Use paediatric pads/settings if available. AED acceptable if no manual.</div></div>';
  }

  // CPR
  html += '<div class="paed-section-title">🫀 CPR Technique (CPP005)</div>';
  html += '<div class="paed-cpr-box">' + cprTech + '</div>';

  // Medications
  // Scope-based medication filtering
  var scopeMeds = {
    PTO:  [],
    EN:   ['paracetamol','methox'],
    ATA:  ['paracetamol','methox','salbutamol','adr_im','glucose'],
    RN:   ['paracetamol','methox','salbutamol','adr_im','glucose','adr_iv'],
    RNCC: ['paracetamol','methox','salbutamol','adr_im','glucose','adr_iv']
  };
  var allowedMeds = scopeMeds[currentScope] || [];
  
  if (allowedMeds.length === 0) {
    html += '<div class="paed-section-title">💊 Medication Doses</div>';
    html += '<div class="paed-cpr-box" style="color:var(--text3);">No medications authorised for PTO scope.</div>';
  } else {
  html += '<div class="paed-section-title">💊 Medication Doses (' + currentScope + ')</div>';
  html += '<div class="paed-drug-table">';
  html += '<div class="paed-drug-header"><span>Drug</span><span>Dose</span><span>Max</span></div>';
  if (allowedMeds.indexOf('paracetamol') !== -1) {
  html += '<div class="paed-drug-row"><div class="paed-drug-name">Paracetamol oral (>1 month)</div><div class="paed-drug-dose">' + paracetamol_mg + ' mg (15 mg/kg)</div><div class="paed-drug-max">1 g / dose · 4 g/day</div></div>';
  }
  if (allowedMeds.indexOf('adr_im') !== -1) {
  html += '<div class="paed-drug-row"><div class="paed-drug-name">Adrenaline IM (anaphylaxis)</div><div class="paed-drug-dose">' + adr_im_mcg + ' mcg (0.01 mg/kg) &nbsp;|&nbsp; ' + adr_im_ml + ' mL of 1:1000</div><div class="paed-drug-max">500 mcg</div></div>';
  }
  if (allowedMeds.indexOf('adr_iv') !== -1) {
  html += '<div class="paed-drug-row"><div class="paed-drug-name">Adrenaline IV (arrest)</div><div class="paed-drug-dose">' + adr_iv_mg + ' mg (0.01 mg/kg)</div><div class="paed-drug-max">Per cycle</div></div>';
  }
  if (allowedMeds.indexOf('salbutamol') !== -1) {
  html += '<div class="paed-drug-row"><div class="paed-drug-name">Salbutamol pMDI</div><div class="paed-drug-dose">' + salb_puff + ' puffs via spacer</div><div class="paed-drug-max">Repeat per RSA</div></div>';
  }
  if (allowedMeds.indexOf('methox') !== -1) {
  html += '<div class="paed-drug-row"><div class="paed-drug-name">Methoxyflurane</div><div class="paed-drug-dose">' + methox_ml + '</div><div class="paed-drug-max">6 mL / 24h</div></div>';
  }
  if (allowedMeds.indexOf('glucose') !== -1) {
  html += '<div class="paed-drug-row"><div class="paed-drug-name">Glucose paste (hypoglycaemia)</div><div class="paed-drug-dose">' + gluc_paste_g + ' g glucose paste</div><div class="paed-drug-max">Conscious + able to swallow</div></div>';
  }
  html += '</div>';
  } // end scope meds

  html += '<div class="paed-disclaimer">⚠️ For clinical reference only. Always apply clinical judgement. Paediatric patients ≥12 years use adult CPP.</div>';
  html += '</div>';

  document.getElementById('paed-calc-result').innerHTML = html;
  document.getElementById('paed-calc-result').style.display = 'block';
}

// ── GCS INTERACTIVE TABLE ─────────────────────────────────────────────────



function renderGCSTable(table) {
  const id = 'gcs_' + Date.now();
  // Get paediatric verbal from master
  var masterGCS = NEPT_DATA.protocols.find(function(x){ return x.id === 'ASSESS_GCS_AVPU'; });
  var paedVerbal = masterGCS && masterGCS.gcs_paediatric ? masterGCS.gcs_paediatric.verbal_response : null;
  var paedNote = masterGCS && masterGCS.gcs_paediatric ? (masterGCS.gcs_paediatric.note || 'Modified verbal scale for patients ≤4 years') : '';
  
  var html = '<div class="gcs-widget" id="' + id + '">' +
    '<div class="gcs-header">' +
      '<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">' +
        '<div class="gcs-title">GCS Calculator</div>' +
        (paedVerbal ? '<div class="gcs-age-toggle" data-widget="' + id + '">' +
          '<button onclick="switchGCSCalcMode(this,\'adult\')" class="gcs-age-btn active">Adult</button>' +
          '<button onclick="switchGCSCalcMode(this,\'paeds\')" class="gcs-age-btn">Paeds (\u22644 yrs)</button>' +
        '</div>' : '') +
      '</div>' +
      '<div class="gcs-score-display">' +
        '<span class="gcs-score-label">Total:</span>' +
        '<span class="gcs-score-value" id="' + id + '_total">\u2014</span>' +
        '<span class="gcs-score-of">/15</span>' +
        '<button class="gcs-reset-btn" onclick="resetGCS(\'' + id + '\')">Reset</button>' +
      '</div>' +
    '</div>';

  // Adult columns
  html += '<div id="' + id + '_adult" class="gcs-columns">' +
    renderGCSColumn(id, 'eye', 'Eye Response (E)', table.eye_response) +
    renderGCSColumn(id, 'verbal', 'Verbal Response (V)', table.verbal_response) +
    renderGCSColumn(id, 'motor', 'Motor Response (M)', table.motor_response) +
  '</div>';

  // Paediatric columns
  if (paedVerbal) {
    html += '<div id="' + id + '_paeds" class="gcs-columns" style="display:none;">' +
      '<div style="grid-column:1/-1;font-size:11px;color:var(--text-muted,#94a3b8);padding:6px 10px;background:rgba(59,130,246,0.08);border-radius:6px;border:1px solid rgba(59,130,246,0.2);margin-bottom:4px;">\u2139\ufe0f ' + paedNote + '</div>' +
      renderGCSColumn(id + '_p', 'eye', 'Eye Response (E)', table.eye_response) +
      renderGCSColumn(id + '_p', 'verbal', 'Verbal Response (V)', paedVerbal) +
      renderGCSColumn(id + '_p', 'motor', 'Motor Response (M)', table.motor_response) +
    '</div>';
  }

  html += '<div class="gcs-breakdown" id="' + id + '_breakdown">' +
    '<span>E: \u2014</span><span>V: \u2014</span><span>M: \u2014</span>' +
  '</div></div>';
  return html;
}

function renderGCSColumn(widgetId, type, title, items) {
  let html = '<div class="gcs-col">' +
    '<div class="gcs-col-title">' + title + '</div>';
  items.forEach(function(item) {
    html += '<div class="gcs-option" data-widget="' + widgetId + '" data-type="' + type + '" data-score="' + item.score + '" onclick="selectGCS(this)">' +
      '<span class="gcs-opt-score">' + item.score + '</span>' +
      '<span class="gcs-opt-desc">' + item.description + '</span>' +
    '</div>';
  });
  html += '</div>';
  return html;
}

var gcsSelections = {};

function selectGCS(el) {
  var widgetId = el.getAttribute('data-widget');
  var type = el.getAttribute('data-type');
  var score = parseInt(el.getAttribute('data-score'));
  
  if (!gcsSelections[widgetId]) gcsSelections[widgetId] = {};
  
  if (gcsSelections[widgetId][type] === score) {
    delete gcsSelections[widgetId][type];
    el.classList.remove('selected');
  } else {
    gcsSelections[widgetId][type] = score;
    var siblings = document.querySelectorAll('.gcs-option[data-widget="' + widgetId + '"][data-type="' + type + '"]');
    siblings.forEach(function(s) { s.classList.remove('selected'); });
    el.classList.add('selected');
  }
  
  // Paeds widget (_p suffix) updates the main widget display
  var mainId = widgetId.replace(/_p$/, '');
  updateGCSTotal(mainId, widgetId);
}

function updateGCSTotal(widgetId, activeId) {
  var selId = activeId || widgetId;
  var sel = gcsSelections[selId] || {};
  var e = sel.eye, v = sel.verbal, m = sel.motor;
  var totalEl = document.getElementById(widgetId + '_total');
  var breakdownEl = document.getElementById(widgetId + '_breakdown');
  if (!totalEl || !breakdownEl) return;
  
  if (e !== undefined && v !== undefined && m !== undefined) {
    var total = e + v + m;
    totalEl.textContent = total;
    totalEl.className = 'gcs-score-value' + (total <= 8 ? ' critical' : total <= 12 ? ' moderate' : '');
  } else {
    totalEl.textContent = '\u2014';
    totalEl.className = 'gcs-score-value';
  }
  
  breakdownEl.innerHTML = '<span>E: ' + (e !== undefined ? e : '\u2014') + '</span>' +
    '<span>V: ' + (v !== undefined ? v : '\u2014') + '</span>' +
    '<span>M: ' + (m !== undefined ? m : '\u2014') + '</span>';
}

function resetGCS(widgetId) {
  gcsSelections[widgetId] = {};
  var options = document.querySelectorAll('.gcs-option[data-widget="' + widgetId + '"]');
  options.forEach(function(o) { o.classList.remove('selected'); });
  updateGCSTotal(widgetId);
}

function switchGCSCalcMode(btn, mode) {
  var toggle = btn.parentElement;
  var widgetId = toggle.getAttribute('data-widget');
  toggle.querySelectorAll('.gcs-age-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  
  var adultPanel = document.getElementById(widgetId + '_adult');
  var paedsPanel = document.getElementById(widgetId + '_paeds');
  if (mode === 'paeds' && paedsPanel) {
    adultPanel.style.display = 'none';
    paedsPanel.style.display = '';
  } else {
    adultPanel.style.display = '';
    if (paedsPanel) paedsPanel.style.display = 'none';
  }
  // Reset both panels
  resetGCS(widgetId);
  resetGCS(widgetId + '_p');
  updateGCSTotal(widgetId);
}

// ── CPP LINKING HELPER ────────────────────────────────────────────────────
function linkCPPs(text) {
  if (text === null || text === undefined) return '';
  if (typeof text !== 'string') text = String(text);
  // Build title map from all protocols
  const titleMap = {};
  if (NEPT_DATA) {
    NEPT_DATA.protocols.forEach(p => {
      const num = p.id.replace('CPP', '');
      titleMap[p.id] = p.title.replace(/^CPP\d+:\s*/, '');
    });
  }
  // Replace CPP### references with clickable links showing the title
  text = text.replace(/CPP(\d{3})/g, (match, num) => {
    const id = 'CPP' + num;
    const title = titleMap[id] || '';
    const display = title ? `${match}: ${title}` : match;
    return `<a class="cpp-link" onclick="jumpToCPP('${id}')" title="${title}">${display}</a>`;
  });
  return linkMeds(text);
}

function jumpToProtocol(id, mode) {
  // mode: 'full' or 'quick' - if not given, preserve currentViewMode
  currentTab = 'protocols';
  document.querySelectorAll('.tab-btn').forEach((b,i) => {
    b.classList.toggle('active', ['protocols','medications','scope'][i] === 'protocols');
  });
  document.getElementById('sidebar').style.display = '';
  currentItem = id;
  if (mode) {
    currentViewMode = mode;
  }
  renderNav();
  renderItem(id);
  // Scroll to top of content
  var content = document.getElementById('main-content') || document.querySelector('.content-area');
  if (content) content.scrollTop = 0;
}
function jumpToCPP(id) {
  // When called from QR view cpp-links → stay in QR; from FP → stay in FP
  jumpToProtocol(id);
}
function jumpToCPPFP(id) {
  // Explicitly jump to Full Protocol view of a CPP
  jumpToProtocol(id, 'full');
}
function jumpToCPPQR(id) {
  // Explicitly jump to Quick Reference view of a CPP
  jumpToProtocol(id, 'quick');
}

// ── SCOPE FILTERING FOR FLOWCHART ────────────────────────────────────────
function nodeAvailableForScope(text, scope) {
  // Check if a node's text contains scope annotations that exclude the current scope.
  // Patterns to detect:
  //   "(RNCC only)" "(RNCC)" "(RN/RNCC)" - only those scopes
  //   "(RN=TE, RNCC)" - has scope assignments
  //   "(ATA/RN/RNCC; EN=TE)" - slash-separated lists
  
  const scopeHierarchy = ['PTO', 'EN', 'ATA', 'RN', 'RNCC'];
  const scopeLevel = scopeHierarchy.indexOf(scope);
  
  // Find all parenthesised scope annotations
  const annotations = text.match(/\(([^)]*(?:PTO|EN|ATA|RN|RNCC)[^)]*)\)/g);
  if (!annotations) return 'show'; // No scope annotations = show for all
  
  // Check each annotation
  for (const ann of annotations) {
    const inner = ann.slice(1, -1); // Remove parens
    // Check if the current scope appears in this annotation (as YES or TE or listed)
    if (inner.includes(scope)) return 'show';
    // Check combined scopes like "RN/RNCC"
    if (inner.includes(scope + '/') || inner.includes('/' + scope)) return 'show';
  }
  
  // Current scope not mentioned in any annotation — it's excluded
  return 'hide';
}

function filterNodeTextForScope(text, scope) {
  // Clean up text by removing scope annotations and treatments not available for this scope
  // Remove parts like ". Extreme: adrenaline IV 0.02mg (RNCC only)" when scope isn't RNCC
  
  // Remove "treatment (SCOPE only)" segments where current scope isn't mentioned
  let cleaned = text.replace(/\.\s*(?:Extreme:\s*)?[^.]*\((?:(?!PTO|EN|ATA|RN|RNCC).)*?(RNCC only|RN only)[^)]*\)[^.]*(?:\.|$)/gi, (match) => {
    if (match.includes(scope)) return match;
    return '.';
  });
  
  // Clean scope annotations to just show TE badge if current scope is TE
  cleaned = cleaned.replace(/\(([^)]*(?:PTO|EN|ATA|RN|RNCC)[^)]*)\)/g, (match, inner) => {
    // Check if current scope is TE in this annotation
    const teMatch = inner.match(new RegExp(scope + '\\s*=\\s*TE'));
    if (teMatch) return '<span class="fc-scope-tag te">TE</span>';
    // Check if scope is listed (YES)
    if (inner.includes(scope)) return '';
    return '';
  });
  
  // Clean up double dots/spaces
  cleaned = cleaned.replace(/\.\s*\./g, '.').replace(/\s{2,}/g, ' ').trim();
  
  return cleaned;
}

// ── FLOWCHART RENDERER ───────────────────────────────────────────────────
function renderFlowchart(tree) {
  const nodeMap = {};
  tree.forEach(n => { nodeMap[n.node] = n; });

  const rendered = new Set();
  const scope = currentScope;

  function arrow(label) {
    if (label) {
      const cls = label.toLowerCase() === 'yes' ? 'yes' : (label.toLowerCase() === 'no' ? 'no' : '');
      return `<div class="fc-arrow"><span class="fc-arrow-label ${cls}">${label}</span>↓</div>`;
    }
    return '<div class="fc-arrow">↓</div>';
  }

  function nodeClass(n) {
    if (n.node === 'start') return 'start';
    if (n.node === 'transport' || n.node === 'end' || n.node === 'escalation') return 'transport';
    if (n.type === 'decision') return 'decision';
    return 'action';
  }

  function processText(text) {
    let t = filterNodeTextForScope(text, scope);
    t = linkCPPs(t);
    return t;
  }

  function renderNode(n) {
    if (!n || rendered.has(n.node)) return '';
    rendered.add(n.node);

    // Check if this node is available for the current scope
    const availability = nodeAvailableForScope(n.text, scope);
    
    // For decision nodes: check if branches are available
    if (n.type === 'decision' && (n.yes || n.no)) {
      const yesNode = nodeMap[n.yes];
      const noNode = nodeMap[n.no];
      const yesAvail = yesNode ? nodeAvailableForScope(yesNode.text, scope) !== 'hide' : false;
      const noAvail = noNode ? nodeAvailableForScope(noNode.text, scope) !== 'hide' : false;

      // If neither branch is available for this scope, skip the whole decision
      if (!yesAvail && !noAvail && availability === 'hide') return '';

      // If the decision question itself mentions scope-exclusive treatments, check
      // whether at least one path is relevant
      const cls = nodeClass(n);
      let out = `<div class="fc-node ${cls}">${processText(n.text)}</div>`;

      if (yesAvail && noAvail) {
        // Both branches available — show full decision
        out += `<div class="fc-branch-container">`;
        out += `<div class="fc-branch">${arrow('Yes')}${renderNode(yesNode)}</div>`;
        out += `<div class="fc-branch">${arrow('No')}${renderNode(noNode)}</div>`;
        out += `</div>`;
      } else if (yesAvail) {
        // Only yes branch available — show as linear flow
        out += arrow('Yes');
        out += renderNode(yesNode);
        if (noNode) rendered.add(noNode.node); // Mark no branch as rendered (skip)
      } else if (noAvail) {
        out += arrow('No');
        out += renderNode(noNode);
        if (yesNode) rendered.add(yesNode.node);
      }
      return out;
    }

    // For action nodes: check scope availability
    if (availability === 'hide') {
      // Skip this node but continue to children
      if (n.next && n.next.length) {
        return n.next.map(nid => {
          const nn = nodeMap[nid];
          return nn ? renderNode(nn) : '';
        }).join('');
      }
      return '';
    }

    const cls = nodeClass(n);
    let out = `<div class="fc-node ${cls}">${processText(n.text)}</div>`;

    // Multi-next (parallel considerations)
    if (n.next && n.next.length > 1) {
      const availChildren = n.next.map(nid => nodeMap[nid]).filter(nn => nn && nodeAvailableForScope(nn.text, scope) !== 'hide');
      if (availChildren.length > 1) {
        out += arrow('');
        out += `<div class="fc-parallel">`;
        availChildren.forEach(nn => { out += renderNode(nn); });
        out += `</div>`;
        // Mark skipped children
        n.next.forEach(nid => { if (nodeMap[nid]) rendered.add(nid); });
      } else if (availChildren.length === 1) {
        out += arrow('');
        out += renderNode(availChildren[0]);
        n.next.forEach(nid => rendered.add(nid));
      } else {
        n.next.forEach(nid => rendered.add(nid));
      }
      return out;
    }

    // Single next
    if (n.next && n.next.length === 1) {
      const nextNode = nodeMap[n.next[0]];
      if (nextNode) {
        out += arrow('');
        out += renderNode(nextNode);
      }
    }

    return out;
  }

  const startNode = tree.find(n => n.node === 'start') || tree[0];
  let html = renderNode(startNode);

  // Render remaining unrendered nodes (orphans)
  tree.forEach(n => {
    if (!rendered.has(n.node)) {
      const avail = nodeAvailableForScope(n.text, scope);
      if (avail !== 'hide') {
        html += arrow('');
        html += renderNode(n);
      }
    }
  });

  return html;
}

// ── MEDICATION RENDERER ───────────────────────────────────────────────────
function renderMedDoseCard(medId, scope) {
  var med = NEPT_DATA.medications.find(function(m) { return m.id === medId; });
  if (!med) return '';
  
  var auth = med.scope_authorisation;
  if (auth && auth[scope]) {
    var val = auth[scope].toUpperCase();
    if (val === 'NO' || val === 'N/A') return '';
  }
  var isTE = auth && auth[scope] && auth[scope].toUpperCase().indexOf('TE') !== -1;
  
  // Dosing lines
  var doseLines = [];
  if (med.dosing && med.dosing.adult) {
    med.dosing.adult.forEach(function(d) {
      var inScope = (d.scopes && d.scopes.indexOf(scope) !== -1);
      var inTE = (d.te_scopes && d.te_scopes.indexOf(scope) !== -1);
      if (inScope || inTE) {
        var line = '<strong>' + d.dose + '</strong> ' + d.route;
        if (d.indication) line += ' — ' + d.indication;
        if (inTE && !inScope) line += ' <span class="te-tag">TE</span>';
        doseLines.push(line);
      }
    });
  }
  
  // Repeat info
  var repeatLines = [];
  if (med.repeat_dosing) {
    Object.keys(med.repeat_dosing).forEach(function(key) {
      var r = med.repeat_dosing[key];
      if (r.rule) repeatLines.push(r.rule);
      if (r.maximum) repeatLines.push('Max: ' + r.maximum);
    });
  }

  // Contraindications
  var ciItems = [];
  if (med.contraindications) {
    var ci = med.contraindications;
    if (typeof ci === 'string') {
      ci.split(/[.;]/).forEach(function(s) { s = s.trim(); if (s.length > 2) ciItems.push(s.replace(/\.$/, '')); });
    } else if (Array.isArray(ci)) {
      ciItems = ci;
    }
  }
  
  // Build card — name as title, doses below, contraindications as dots
  var html = '<div class="med-dose-card" onclick="jumpToMed(\'' + medId + '\')">';
  html += '<div class="mdc-name">' + med.name + (isTE ? ' <span class="te-tag">TE</span>' : '') + '</div>';
  
  if (doseLines.length) {
    html += '<div class="mdc-doses">';
    doseLines.forEach(function(l) { html += '<div class="mdc-dose-line">' + l + '</div>'; });
    html += '</div>';
  }
  if (repeatLines.length) {
    html += '<div class="mdc-repeat">';
    repeatLines.forEach(function(l) { html += '<div>' + l + '</div>'; });
    html += '</div>';
  }
  if (ciItems.length) {
    html += '<div class="mdc-ci"><div class="mdc-ci-label">Contraindications</div><ul>';
    ciItems.forEach(function(item) { html += '<li>' + item + '</li>'; });
    html += '</ul></div>';
  }
  
  html += '<div class="mdc-hint">Tap for full details →</div></div>';
  return html;
}

function renderContraindications(ci) {
  if (!ci) return 'None listed';
  if (typeof ci === 'string') {
    // Split on periods or semicolons to create bullet points
    var items = ci.split(/\.\s+/).filter(function(s) { return s.trim().length > 2; });
    if (items.length <= 1) return ci;
    return '<ul class="ci-list">' + items.map(function(s) { return '<li>' + s.trim().replace(/\.$/, '') + '</li>'; }).join('') + '</ul>';
  }
  if (Array.isArray(ci)) {
    if (ci.length === 0) return 'None listed';
    return '<ul class="ci-list">' + ci.map(function(s) { return '<li>' + s + '</li>'; }).join('') + '</ul>';
  }
  return String(ci);
}

function renderMedication(m) {
  let html = `
    <div class="med-header">
      <div class="med-title">${m.name}</div>
      <div class="med-class">${m.class}</div>
      <div class="med-scope-badge cat-${m.scope || 'General'}" style="margin-right:6px;">
        ${m.scope} — ${NEPT_DATA.metadata.scope_descriptions[m.scope] || m.scope}
      </div>
    </div>
  `;

  // Panel tabs
  html += `<div class="panel-tabs" id="med-tabs">
    <button class="panel-tab active" onclick="showMedPanel('overview', this)">Overview</button>
    <button class="panel-tab" onclick="showMedPanel('dosing', this)">Dosing</button>
    <button class="panel-tab" onclick="showMedPanel('pharmacology', this)">Pharmacology</button>
  </div>
  <div id="med-panel-overview">
    ${renderMedOverview(m)}
  </div>
  <div id="med-panel-dosing" style="display:none;">
    ${renderMedDosing(m)}
    ${renderMedRepeat(m)}
  </div>
  <div id="med-panel-pharmacology" style="display:none;">
    ${renderMedPharmacology(m)}
  </div>`;

  document.getElementById('viewer').innerHTML = html;
}

function showMedPanel(panel, btn) {
  ['overview','dosing','pharmacology'].forEach(p => {
    document.getElementById('med-panel-' + p).style.display = p === panel ? 'block' : 'none';
  });
  document.querySelectorAll('#med-tabs .panel-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

function renderMedOverview(m) {
  return `
    <div class="section">
      <div class="section-title">Indications</div>
      <div class="tag-list">
        ${(m.indications || []).map(i => `<span class="tag indication">${i}</span>`).join('')}
      </div>
    </div>
    <div class="section">
      <div class="section-title">Presentations</div>
      <div class="pres-list">
        ${(m.presentations || []).map(p => `<div class="pres-item">${p}</div>`).join('')}
      </div>
    </div>
    <div class="section">
      <div class="section-title">Contraindications</div>
      <div class="background-text" style="border-left-color:var(--red);">${renderContraindications(m.contraindications)}</div>
    </div>
    <div class="section">
      <div class="section-title">Precautions</div>
      <div class="tag-list">
        ${(m.precautions || []).map(p => `<span class="tag precaution">${p}</span>`).join('')}
      </div>
    </div>
    <div class="section">
      <div class="section-title">Side Effects</div>
      <div class="tag-list">
        ${(m.side_effects || []).map(s => `<span class="tag side">${s}</span>`).join('')}
      </div>
    </div>
    ${m.special_notes && m.special_notes.length ? `
      <div class="section">
        <div class="section-title">Special Notes</div>
        ${m.special_notes.map(n => `<div class="special-note">${n}</div>`).join('')}
      </div>` : ''}
  `;
}

function renderMedDosing(m) {
  let html = '';

  if (m.dosing_adult && m.dosing_adult.length) {
    html += `<div class="section">
      <div class="section-title">Adult Dosing</div>
      <table class="dose-table">
        <thead><tr>
          <th>Indication</th>
          <th>Dose</th>
          <th>Route</th>
          <th>Authorisation</th>
        </tr></thead>
        <tbody>
          ${m.dosing_adult.map(d => `
            <tr>
              <td>${d.indication}</td>
              <td><span class="dose-value">${d.dose}</span></td>
              <td>${d.route || ''}</td>
              <td><span class="auth-badge ${d.authorisation.includes('TE') ? 'auth-te' : 'auth-independent'}">${d.authorisation}</span></td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>`;
  }

  if (m.dosing_paediatric && m.dosing_paediatric.length) {
    html += `<div class="section">
      <div class="section-title">Paediatric Dosing</div>
      <table class="dose-table">
        <thead><tr>
          <th>Indication</th>
          <th>Dose</th>
          <th>Route</th>
          <th>Authorisation</th>
        </tr></thead>
        <tbody>
          ${m.dosing_paediatric.map(d => `
            <tr>
              <td>${d.indication}</td>
              <td><span class="dose-value">${d.dose}</span></td>
              <td>${d.route || ''}</td>
              <td><span class="auth-badge ${d.authorisation.includes('TE') ? 'auth-te' : 'auth-independent'}">${d.authorisation}</span></td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>`;
  }

  if (!html) html = '<div style="color:var(--text3);font-size:13px;">No dosing authorised for this scope.</div>';
  return html;
}

function renderMedRepeat(m) {
  const rd = m.repeat_dosing;
  if (!rd || Object.keys(rd).length === 0) {
    return '<div style="color:var(--text3);font-size:13px;">No repeat dosing data available.</div>';
  }

  // Build a lowercase string of all dosing indications available for this scope
  const allIndications = [
    ...(m.dosing_adult || []),
    ...(m.dosing_paediatric || [])
  ].map(d => d.indication.toLowerCase()).join('|');

  const html = Object.entries(rd).map(([key, val]) => {
    // Convert repeat_dosing key to searchable keywords
    // e.g. "cardiac_arrest_iv" → ["cardiac", "arrest", "iv"]
    const keywords = key.toLowerCase().split('_');

    // Check if any keyword from the key appears in any dosing indication
    // This handles cases like "adult_pain" matching indication "Pain"
    // and "cardiac_arrest_iv" matching "Cardiac arrest IV"
    const hasMatch = keywords.some(kw => allIndications.includes(kw));

    if (!hasMatch) return ''; // Skip — not authorised for this scope

    const title = key.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
    return `
      <div class="repeat-card">
        <div class="repeat-card-title">${title}</div>
        <div class="repeat-row">
          <div class="repeat-key">Rule</div>
          <div class="repeat-val">${val.rule || '—'}</div>
        </div>
        <div class="repeat-row">
          <div class="repeat-key">Maximum</div>
          <div class="repeat-val repeat-max">${val.maximum || '—'}</div>
        </div>
        ${val.note ? `<div class="repeat-row">
          <div class="repeat-key">Note</div>
          <div class="repeat-val repeat-note">${val.note}</div>
        </div>` : ''}
        ${val.monitoring ? `<div class="repeat-row">
          <div class="repeat-key">Monitor</div>
          <div class="repeat-val" style="color:var(--text2);font-size:12px;">${val.monitoring}</div>
        </div>` : ''}
      </div>
    `;
  }).join('');

  if (!html.trim()) {
    return '<div style="color:var(--text3);font-size:13px;">No repeat dosing rules for this scope.</div>';
  }

  return `<div class="section">
    <div class="section-title">Repeat Dosing Rules</div>
    <div class="repeat-dosing-grid">${html}</div>
  </div>`;
}

function renderMedPharmacology(m) {
  let html = `
    <div class="section">
      <div class="section-title">Mechanism of Action</div>
      <div class="pharmacology-box">${m.pharmacology || 'Not available'}</div>
    </div>
  `;

  if (m.key_timings && Object.keys(m.key_timings).length) {
    html += `<div class="section">
      <div class="section-title">Key Timings</div>
      <div class="timings-grid">
        ${Object.entries(m.key_timings).map(([route, timing]) => `
          <div class="timing-card">
            <div class="timing-route">${route}</div>
            ${timing.onset ? `<div class="timing-row"><span class="timing-label">Onset</span><span class="timing-value">${timing.onset}</span></div>` : ''}
            ${timing.peak ? `<div class="timing-row"><span class="timing-label">Peak</span><span class="timing-value">${timing.peak}</span></div>` : ''}
            ${timing.duration ? `<div class="timing-row"><span class="timing-label">Duration</span><span class="timing-value">${timing.duration}</span></div>` : ''}
          </div>
        `).join('')}
      </div>
    </div>`;
  }
  return html;
}

// ── INTERACTIONS ──────────────────────────────────────────────────────────
function toggleStep(protoId, stepNum) {
  const key = protoId + '_' + currentScope;
  if (!checkedSteps[key]) checkedSteps[key] = new Set();
  if (checkedSteps[key].has(stepNum)) {
    checkedSteps[key].delete(stepNum);
  } else {
    checkedSteps[key].add(stepNum);
  }

  // Update DOM without full re-render
  const sd = scopeData();
  const proto = sd.protocols.find(p => p.id === protoId);
  const total = proto.checklist_steps.length;
  const done = checkedSteps[key].size;

  const items = document.querySelectorAll(`#checklist-${protoId} .check-item`);
  items.forEach(item => {
    const num = parseInt(item.querySelector('.check-num').textContent);
    const isChecked = checkedSteps[key].has(num);
    item.classList.toggle('checked', isChecked);
    item.querySelector('.check-box').textContent = isChecked ? '✓' : '';
  });

  const fill = document.getElementById('prog-fill-' + protoId);
  const text = document.getElementById('prog-text-' + protoId);
  if (fill) fill.style.width = (total ? done/total*100 : 0) + '%';
  if (text) {
    text.textContent = `${done}/${total} ${done === total && total > 0 ? '✓' : ''}`;
    text.className = 'progress-text' + (done === total && total > 0 ? ' complete' : '');
  }
}

function resetChecklist(protoId) {
  const key = protoId + '_' + currentScope;
  checkedSteps[key] = new Set();
  const sd = scopeData();
  const proto = sd.protocols.find(p => p.id === protoId);
  renderProtocol(proto);
}

// ── USER NOTES ───────────────────────────────────────────────────────────
function getUserNotes(id) {
  try { return (JSON.parse(localStorage.getItem('nept_user_notes') || '{}'))[id] || []; } catch { return []; }
}
function saveUserNotes(id, notes) {
  try { var a = JSON.parse(localStorage.getItem('nept_user_notes') || '{}'); a[id] = notes; localStorage.setItem('nept_user_notes', JSON.stringify(a)); } catch(e) {}
}
function renderSingleUserNote(pid, note, ni) {
  var cls = note.type === 'claude' ? ' claude-note' : '';
  var h = '<div class="user-note-box' + cls + '">' +
    '<div class="un-move-btns">' +
      '<button class="un-move-btn" onclick="moveUserNote(\'' + pid + '\',' + ni + ',-1)" title="Move up">▲</button>' +
      '<button class="un-move-btn" onclick="moveUserNote(\'' + pid + '\',' + ni + ',1)" title="Move down">▼</button>' +
    '</div>' +
    '<button class="user-note-delete" onclick="deleteUserNote(\'' + pid + '\',' + ni + ')">×</button>';
  if (note.title) h += '<div class="un-title">' + escapeHtml(note.title) + '</div>';
  if (note.type === 'bullets' && note.items) {
    h += '<ul class="un-bullets">';
    note.items.forEach(function(i) { h += '<li>' + escapeHtml(i) + '</li>'; });
    h += '</ul>';
  } else if (note.type === 'claude') {
    h += '<div class="un-content">' + escapeHtml(note.content || '') + '</div>';
  } else {
    h += '<div class="un-content">' + escapeHtml(note.content || '') + '</div>';
  }
  return h + '</div>';
}
function openNoteEditor(pid, pos) {
  var ov = document.createElement('div'); ov.className = 'note-editor-overlay';
  ov.onclick = function(e) { if (e.target === ov) ov.remove(); };
  ov.innerHTML = '<div class="note-editor"><h3>Add Box</h3>' +
    '<label>Type</label><select id="ne-type" onchange="neTypeChange()">' +
    '<option value="text">Text / Paragraph</option>' +
    '<option value="bullets">Dot Points</option>' +
    '<option value="claude">💬 Note to Claude</option></select>' +
    '<label>Title (optional)</label><input id="ne-title" placeholder="e.g. Key Reminders...">' +
    '<div id="ne-ta"><label>Content</label><textarea id="ne-content" placeholder="Write here..."></textarea></div>' +
    '<div id="ne-ba" style="display:none;"><label>One per line</label><textarea id="ne-bullets" placeholder="First point&#10;Second"></textarea></div>' +
    '<div id="ne-ca" style="display:none;"><label>Instructions for Claude</label><textarea id="ne-claude" placeholder="e.g. Please add more detail about X, or move the Adrenaline info to card 3..."></textarea></div>' +
    '<label>Position</label><select id="ne-pos"></select>' +
    '<div class="ne-actions">' +
    '<button class="ne-btn ne-cancel" onclick="this.closest(\'.note-editor-overlay\').remove()">Cancel</button>' +
    '<button class="ne-btn ne-save" onclick="saveNote(\'' + pid + '\')">Save</button></div></div>';
  document.body.appendChild(ov);
  // Populate position selector
  var master = NEPT_DATA.protocols.find(function(x){return x.id===pid;});
  var cards = master && master.action_cards;
  var sel = document.getElementById('ne-pos');
  var maxPos = cards ? cards.length : 10;
  for (var i = 0; i <= maxPos; i++) {
    var opt = document.createElement('option');
    opt.value = i;
    opt.textContent = i === 0 ? 'Before card 1' : i >= maxPos ? 'After last card' : 'After card ' + i;
    if (i === pos) opt.selected = true;
    sel.appendChild(opt);
  }
}
function neTypeChange() {
  var t = document.getElementById('ne-type').value;
  document.getElementById('ne-ta').style.display = t === 'text' ? 'block' : 'none';
  document.getElementById('ne-ba').style.display = t === 'bullets' ? 'block' : 'none';
  document.getElementById('ne-ca').style.display = t === 'claude' ? 'block' : 'none';
}
function saveNote(pid) {
  var type = document.getElementById('ne-type').value;
  var title = document.getElementById('ne-title').value.trim();
  var pos = parseInt(document.getElementById('ne-pos').value);
  var note;
  if (type === 'bullets') {
    var lines = document.getElementById('ne-bullets').value.split('\n').map(function(l){return l.trim();}).filter(function(l){return l;});
    if (!lines.length) return;
    note = { type:'bullets', title:title, items:lines, position:pos };
  } else if (type === 'claude') {
    var cc = document.getElementById('ne-claude').value.trim();
    if (!cc) return;
    note = { type:'claude', title: title || 'Note to Claude', content:cc, position:pos };
  } else {
    var content = document.getElementById('ne-content').value.trim();
    if (!content) return;
    note = { type:'text', title:title, content:content, position:pos };
  }
  var notes = getUserNotes(pid); notes.push(note); saveUserNotes(pid, notes);
  editChanges.push({ timestamp: new Date().toISOString(), context: pid, element: type === 'claude' ? 'claude-note' : 'note-added', from:'', to: title || note.content?.substring(0,50) || note.items?.join('; ') || '' });
  updateChangeLog();
  document.querySelector('.note-editor-overlay')?.remove();
  var sd = scopeData(), proto = sd.protocols.find(function(p){return p.id===pid;});
  if (proto) renderProtocol(proto);
}
function deleteUserNote(pid, idx) {
  var notes = getUserNotes(pid), removed = notes.splice(idx, 1)[0]; saveUserNotes(pid, notes);
  editChanges.push({ timestamp: new Date().toISOString(), context: pid, element:'note-deleted', from: removed.title || '', to:'' });
  updateChangeLog();
  var sd = scopeData(), proto = sd.protocols.find(function(p){return p.id===pid;});
  if (proto) renderProtocol(proto);
}
function moveUserNote(pid, idx, dir) {
  var notes = getUserNotes(pid);
  var newIdx = idx + dir;
  if (newIdx < 0 || newIdx >= notes.length) return;
  var tmp = notes[idx]; notes[idx] = notes[newIdx]; notes[newIdx] = tmp;
  saveUserNotes(pid, notes);
  var sd = scopeData(), proto = sd.protocols.find(function(p){return p.id===pid;});
  if (proto) renderProtocol(proto);
}

function jumpToMed(medId) {
  const sd = scopeData();
  const med = sd.medications.find(m => m.id === medId);
  if (!med) {
    // Switch to medications tab and select
    switchTab('medications');
    setTimeout(() => { currentItem = medId; renderItem(medId); renderNav(); }, 50);
    return;
  }
  currentTab = 'medications';
  document.querySelectorAll('.tab-btn').forEach((b,i) => {
    b.classList.toggle('active', i === 1);
  });
  currentItem = medId;
  renderNav();
  renderItem(medId);
}

function toggleCollapse(header) {
  header.classList.toggle('open');
  const body = header.nextElementSibling;
  body.classList.toggle('open');
}


const SOURCE_CPP_HTML = {"CPP001": "<h2 class=\"fp-h2\">Clinical approach to assessment -- unplanned medical presentation</h2>\n<p class=\"fp-p\">Generally, unplanned events will present following calls to the emergency phone line (Triple Zero '000'), State health emergency management plan (SHEMP -- replaced SHERP) activations, or incidentally when conducting other NEPT duties.</p>\n<p class=\"fp-p\">This approach should also be applied by NEPT crew members when conducting an IFT and the patient presents with an unexpected deterioration or with a different complaint or condition than the IFT was originally requested for.</p>\n<p class=\"fp-p\">Where NEPT crew members suspect a significant underlying condition or are concerned with patient presentation regardless of patient VSS, refer to <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP006\\')\">CPP006</span> Clinical escalation. NEPT crew members should be suspicious of signs and symptoms that cannot be explained.</p>\n<p class=\"fp-caption\">Figure 2. Clinical approach to assessment unplanned medical presentation</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP001\" data-idx=\"1\"></div>", "CPP002": "<h2 class=\"fp-h2\">Clinical approach to assessment -- unplanned major trauma presentation</h2>\n<p class=\"fp-p\">Trauma presentations should be assessed in the first instance with these considerations before moving on to injury specific assessment and management. The priorities listed below are the priorities in managing immediate life threat in major trauma and are a departure from traditional order of 'ABC'.</p>\n<p class=\"fp-caption\">Figure 3. Clinical approach to assessment unplanned major trauma</p>\n<p class=\"fp-p\">presentation</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP002\" data-idx=\"1\"></div>", "CPP003": "<h2 class=\"fp-h2\">Clinical approach to inter-facility transport</h2>\n<p class=\"fp-p\">Inter-facility transport (IFT) is defined as the transport of patients between healthcare facilities. IFT is a crucial part of today\\'s healthcare system that allows facilities to transfer patients needing specialised assessment or care that cannot be adequately provided at their current health facility.</p>\n<p class=\"fp-p\">Prior to conducting an IFT, NEPT crew members should ascertain the exact clinical condition of the patient and determine the potential for deterioration prior to commencing transport. Refer to Table 4 'not suitable for NEPT' to determine patient eligibility for transport.</p>\n<p class=\"fp-p\">During the IFT, NEPT crew members are required to reassess the patient appropriately, and clearly document any changes in the patient's condition or any interventions that have been undertaken.</p>\n<p class=\"fp-p\">At a minimum, a set of VSS must be obtained within 30 minutes prior to transfer from a sending facility. Additional sets of VSS should be recorded as required and with respect to patient acuity. Patients receiving active management should receive 15-minutely VSS or more frequently as dictated by patient condition.</p>\n<p class=\"fp-p\">Minimum observations include:</p>\n<ul class=\"fp-ul\">\n<li>GCS or AVPU</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>RSA</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>PSA</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>SPO<sub>2</sub></li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Pain assessment (where appropriate)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>BGL (where appropriate)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Temperature (where appropriate).</li>\n</ul>\n<p class=\"fp-p\">The following checklist table may be completed as a memory aid by NEPT crew members prior to transport commencing.</p>\n<p class=\"fp-p\">Table 9. Checklist for completion prior to transport</p>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Item</th><th>Yes</th><th>No</th><th>N/A</th></tr>\n</tbody></table>\n<p class=\"fp-p\">+===============================================+======+======+======+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Handover provided and transfer paperwork</th><th></th><th></th><th></th></tr>\n<tr><td>provided</td><td></td><td></td><td></td></tr>\n<tr><td>-   Confirm receiving facility</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Is the patient time critical or likely to</th><th></th><th></th><th></th></tr>\n<tr><td>become time critical during transfer?</td><td></td><td></td><td></td></tr>\n<tr><td>If yes, transfer is not suitable for NEPT</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Has the patient experienced cardiac related</th><th></th><th></th><th></th></tr>\n<tr><td>chest pain in the\\</td><td></td><td></td><td></td></tr>\n<tr><td>2 hours prior to transfer?</td><td></td><td></td><td></td></tr>\n<tr><td>If yes, transfer is not suitable for NEPT</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Has the patient been assessed by a registered</th><th></th><th></th><th></th></tr>\n<tr><td>paramedic, registered nurse or registered</td><td></td><td></td><td></td></tr>\n<tr><td>medical practitioner as being</td><td></td><td></td><td></td></tr>\n<tr><td>haemodynamically stable for the duration of</td><td></td><td></td><td></td></tr>\n<tr><td>the transfer?</td><td></td><td></td><td></td></tr>\n<tr><td>-   If no, transfer is not suitable for NEPT</td><td></td><td></td><td></td></tr>\n<tr><td>Gain details of authorising health</td><td></td><td></td><td></td></tr>\n<tr><td>practitioner</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Advanced care directive provided (where an</th><th></th><th></th><th></th></tr>\n<tr><td>ACD exists)</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Plan for clinical management/deterioration</th><th></th><th></th><th></th></tr>\n<tr><td>agreed upon and ongoing management identified</td><td></td><td></td><td></td></tr>\n<tr><td>-   Frequency of VSS stipulated</td><td></td><td></td><td></td></tr>\n<tr><td>-   Clinical trajectory</td><td></td><td></td><td></td></tr>\n<tr><td>-   Infusion doses established</td><td></td><td></td><td></td></tr>\n<tr><td>-   Medication and other care required PRN</td><td></td><td></td><td></td></tr>\n<tr><td>during transfer established</td><td></td><td></td><td></td></tr>\n<tr><td>-   Pressure injury assessment or prevention</td><td></td><td></td><td></td></tr>\n<tr><td>plan</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Does patient acuity at time of dispatch match</th><th></th><th></th><th></th></tr>\n<tr><td>patient acuity at time of transfer?</td><td></td><td></td><td></td></tr>\n<tr><td>If no, and patient acuity not within scope of</td><td></td><td></td><td></td></tr>\n<tr><td>NEPT crew, transfer is not suitable for NEPT</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Is patient ready for transfer?</th><th></th><th></th><th></th></tr>\n<tr><td>-   Toileted</td><td></td><td></td><td></td></tr>\n<tr><td>-   Hydrated</td><td></td><td></td><td></td></tr>\n<tr><td>-   Fed</td><td></td><td></td><td></td></tr>\n<tr><td>-   Analgesia provided (if applicable)</td><td></td><td></td><td></td></tr>\n<tr><td>-   Sedation provided (if applicable)</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Confirm three (3) points of patient</th><th></th><th></th><th></th></tr>\n<tr><td>identification, for example:</td><td></td><td></td><td></td></tr>\n<tr><td>-   Medical ID bracelet</td><td></td><td></td><td></td></tr>\n<tr><td>-   Health care record</td><td></td><td></td><td></td></tr>\n<tr><td>-   Patient stating name and identifying</td><td></td><td></td><td></td></tr>\n<tr><td>features</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Is all required equipment for transport</th><th></th><th></th><th></th></tr>\n<tr><td>present, for example (as applicable):</td><td></td><td></td><td></td></tr>\n<tr><td>-   Cardiac monitoring</td><td></td><td></td><td></td></tr>\n<tr><td>-   NIBP</td><td></td><td></td><td></td></tr>\n<tr><td>-   SPO<sub>2</sub></td><td></td><td></td><td></td></tr>\n<tr><td>-   BGL</td><td></td><td></td><td></td></tr>\n<tr><td>-   ETCO<sub>2</sub></td><td></td><td></td><td></td></tr>\n<tr><td>-   Infusion pump(s)</td><td></td><td></td><td></td></tr>\n<tr><td>-   Arterial line established</td><td></td><td></td><td></td></tr>\n<tr><td>-   IDC in situ</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Have all medications required for transport</th><th></th><th></th><th></th></tr>\n<tr><td>been prepared and supplied?</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Have all medications or prescriptions</th><th></th><th></th><th></th></tr>\n<tr><td>required for ongoing care been provided and</td><td></td><td></td><td></td></tr>\n<tr><td>included as part of handover documentation?</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Have all patient belongings been accounted</th><th></th><th></th><th></th></tr>\n<tr><td>for and are they able to be transported?</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Is patient aware of the reasons for transfer</th><th></th><th></th><th></th></tr>\n<tr><td>and do they consent to the transfer (where</td><td></td><td></td><td></td></tr>\n<tr><td>appropriate)?</td><td></td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------------------+------+------+------+</p>\n<p class=\"fp-p\">Table 9. Post transport checklist</p>\n<p class=\"fp-p\">------------------------------------------------------------------------ Item                                             Yes     No      N/A</p>\n<p class=\"fp-p\">------------------------------------------------ ------- ------- ------- Has verbal handover been provided to receiving facility?</p>\n<p class=\"fp-p\">Has a patient care record been completed?</p>\n<p class=\"fp-p\">Has a patient care record been provided to receiving facility (medium-high acuity only)?</p>\n<p class=\"fp-p\">Have patient belongings, medication and clinical notes been transferred to the receiving facility?</p>", "CPP004": "<h2 class=\"fp-h2\">Cardiac arrest -- adult</h2>\n<h3 class=\"fp-h3\">Signs of life</h3>\n<p class=\"fp-p\">Any patient who is unconscious and not breathing normally (for example, gasping, agonal breathing) should be presumed to be in cardiac arrest. Palpation of a pulse is unreliable, if any doubt exists as to the presence of a pulse, chest compressions must be commenced.</p>\n<h3 class=\"fp-h3\">High-quality CPR principles</h3>\n<ul class=\"fp-ul\">\n<li>Rate: 100-120 compressions per minute</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Depth: ≥ 5 cm, allow for full recoil</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Ventilation duration: 1 second per ventilation (aiming to see rise and fall of the chest)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Two-minute rotations of compressor</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Minimise interruptions to chest compressions (including while pad placement occurs)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Optimal defibrillation pad positioning</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Resume compressions immediately after defibrillation or disarm/no shock delivered.</li>\n</ul>\n<h3 class=\"fp-h3\">Compression ratio:</h3>\n<h4 class=\"fp-h4\">No SGA (OP/NPA/BVM)</h4>\n<ul class=\"fp-ul\">\n<li>30 compressions : 2 ventilations</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Pause for ventilations.</li>\n</ul>\n<h4 class=\"fp-h4\">SGA or ETT in situ</h4>\n<ul class=\"fp-ul\">\n<li>15 compressions : 1 ventilation</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>6-8 ventilations per minute</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>No pause for ventilations.</li>\n</ul>\n<h3 class=\"fp-h3\">Defibrillation pad placement</h3>\n<p class=\"fp-p\">Optimal defibrillation pad positioning ensures transmyocardial current density is maximised when defibrillation occurs.</p>\n<ul class=\"fp-ul\">\n<li>Apex pad is positioned on the left, at the mid axillary line, 6th intercostal space</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Sternal pad rolled on laterally from right sternal margin on the patient's right chest, under the right clavicle and above the right nipple.</li>\n</ul>\n<h3 class=\"fp-h3\">General notes</h3>\n<ul class=\"fp-ul\">\n<li>For the purposes of the protocols, an automatic external defibrillator (AED) is regarded as being the same as a semi‑automatic external defibrillator (SAED)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>High-quality ECC and defibrillation are the cornerstone of resuscitation -- this must be prioritised over all other interventions</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>If CPR is commenced, escalation of care <strong><span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP006\\')\">CPP006</span></strong> is required as early as practicable.</li>\n</ul>\n<h4 class=\"fp-h4\">Hypothermic cardiac arrest &lt; 30°C</h4>\n<ul class=\"fp-ul\">\n<li>The primary goal is to prevent further heat loss prior to ROSC or transport - significant improvement in temperature from prehospital intervention is unlikely</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Double the interval for Adrenaline and Amiodarone dose.</li>\n</ul>\n<h4 class=\"fp-h4\">Traumatic cardiac arrest</h4>\n<p class=\"fp-p\">Where trauma is the suspected cause of cardiac arrest prioritise control of major haemorrhage over all other interventions. Follow management within <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP002\\')\">CPP002</span> Clinical approach to assessment - unplanned major trauma presentation.</p>\n<h4 class=\"fp-h4\">Withholding or ceasing resuscitation</h4>\n<p class=\"fp-p\">Refer to Appendix 2: Withholding or ceasing resuscitation.</p>\n<p class=\"fp-caption\">Figure 4. Cardiac arrest algorithm</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP004\" data-idx=\"1\"></div>\n<p class=\"fp-p\">[</p>", "CPP005": "<h2 class=\"fp-h2\">Cardiac arrest -- paediatric</h2>\n<p class=\"fp-p\">This guideline applies to patients &lt;12 years of age. See also: <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP004\\')\">CPP004</span> Cardiac arrest: adult for patients ≥ 12 years.</p>\n<p class=\"fp-p\">Effective airway control and adequate ventilation with oxygen supplementation is the cornerstone of paediatric resuscitation.</p>\n<h3 class=\"fp-h3\">Signs of life</h3>\n<p class=\"fp-p\">Patients &lt; 12 years of age who are unresponsive, not breathing normally and pulseless;\\ or HR &lt; 60 bpm (infants); or HR &lt; 40 bpm (children) are presumed to be in cardiac arrest.</p>\n<h3 class=\"fp-h3\">High-quality CPR principles</h3>\n<ul class=\"fp-ul\">\n<li>1/3 chest depth, allow for full recoil</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Ventilation duration: 1 second per ventilation (aiming to see rise and fall of the chest)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Two-minute rotations of compressor</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Minimise interruptions to chest compressions (including while pad placement occurs)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Optimal defibrillation pad positioning</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Resume compressions immediately after defibrillation or disarm/no shock delivered.</li>\n</ul>\n<h3 class=\"fp-h3\">Compression ratio, rate and technique</h3>\n<p class=\"fp-p\"><strong>Table 10. Paediatric CPR compression ratio and rates</strong></p>\n<p class=\"fp-p\">+--------+------------------------+-----------------+-----------------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Age</th><th>CPR ratio</th><th>Compression</th><th>Technique</th></tr>\n<tr><td></td><td></td><td>rate</td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+========+========================+=================+=================+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>N</th><th>3 compressions : 1</th><th>90 compressions</th><th>2 finger or 2</th></tr>\n<tr><td>ewborn</td><td>ventilation</td><td>per minute with</td><td>thumbs</td></tr>\n<tr><td>(birth</td><td></td><td>0.5 second</td><td></td></tr>\n<tr><td>up to</td><td></td><td>pause for</td><td>One third of</td></tr>\n<tr><td>24</td><td></td><td>ventilation</td><td>the depth of</td></tr>\n<tr><td>hours)</td><td></td><td></td><td>chest</td></tr>\n</tbody></table>\n<p class=\"fp-p\">+--------+------------------------+-----------------+-----------------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>In</th><th>30 compressions : 2</th><th>100-120</th><th>2 finger or 2</th></tr>\n<tr><td>fants\\</td><td>ventilations (one</td><td>compressions</td><td>thumbs</td></tr>\n<tr><td>(1 day</td><td>rescuer)</td><td>per minute</td><td></td></tr>\n<tr><td>up to</td><td></td><td></td><td>One third of</td></tr>\n<tr><td>1</td><td>15 compressions : 2</td><td></td><td>the depth of</td></tr>\n<tr><td>year)</td><td>ventilations (two</td><td></td><td>chest</td></tr>\n<tr><td></td><td>rescuers)</td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+--------+------------------------+-----------------+-----------------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Small</th><th>30 compressions : 2</th><th>100-120</th><th>One hand or 2</th></tr>\n<tr><td>and</td><td>ventilations (one</td><td>compressions</td><td>hands</td></tr>\n<tr><td>medium</td><td>rescuer)</td><td>per minute</td><td></td></tr>\n<tr><td>child</td><td></td><td></td><td>One third of</td></tr>\n<tr><td>(1 to</td><td>15 compressions : 2</td><td></td><td>the depth of</td></tr>\n<tr><td>11</td><td>ventilations (two</td><td></td><td>chest</td></tr>\n<tr><td>years)</td><td>rescuers)</td><td></td><td></td></tr>\n</tbody></table>\n<p class=\"fp-p\">+--------+------------------------+-----------------+-----------------+</p>\n<h3 class=\"fp-h3\">Defibrillation pad placement</h3>\n<p class=\"fp-p\">Optimal defibrillation pad positioning ensures transmyocardial current density is maximised when defibrillation occurs.</p>\n<ul class=\"fp-ul\">\n<li>Defibrillation pad placement should be as close as possible to adult placement</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>The 'anterior' pad is placed on the left side, mid-axillary line (same as adult placement)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>The 'posterior' pad is placed on the right upper chest/clavicle (same as adult placement)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Wrapping over the shoulder is permissible to ensure sufficient gap between the pads. Avoid the neck.</li>\n</ul>\n<h3 class=\"fp-h3\">General notes</h3>\n<ul class=\"fp-ul\">\n<li>Cardiac arrest in children and infants is commonly caused by hypoxia. This guideline prioritises airway and ventilatory support</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Respiratory arrest followed by bradycardic cardiac arrest may be corrected with ventilation prior to commencing chest compressions</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Small children, infants and newborns may need a small amount of padding beneath the shoulders to keep the occiput from causing too much flexion of the head and compressing the neck. Be cautious with head and neck extension in children &lt; 8 years</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>For the purposes of the CPPs, an automatic external defibrillator (AED) is regarded as being the same as a semi‑automatic external defibrillator (SAED)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>An AED can be used in children if the appropriate settings and attachments are available. If not accredited in manual defibrillation and an AED without paediatric settings/attachments is the only option, it should be applied and utilized until further assistance arrives. If defibrillation is required, delivering a higher shock energy than the standard is less harmful than failing to defibrillate</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>If accredited in manual defibrillation, 4 joules per kg should be delivered rounded up to the nearest setting.</li>\n</ul>\n<h3 class=\"fp-h3\">Hypothermic cardiac arrest &lt; 30°C</h3>\n<p class=\"fp-p\">The primary goal is to prevent further heat loss prior to ROSC or transport -- significant improvement in temperature from prehospital intervention is unlikely.</p>\n<p class=\"fp-caption\">Figure 5. cardiac arrest algorithm - paediatric</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP005\" data-idx=\"1\"></div>", "CPP006": "<h2 class=\"fp-h2\">Clinical escalation</h2>\n<p class=\"fp-p\">Whilst the regulations stipulate that NEPT providers are to not routinely transport haemodynamically unstable patients and the CPPs present VSS which would indicate the transport is not suitable for NEPT, situations may arise where this occurs.</p>\n<p class=\"fp-p\">Presented below are some options which NEPT crew members may consider to escalate care if the patient presentation no longer falls within their scope to manage.</p>\n<ul class=\"fp-ul\">\n<li>Escalate to AV care via provider communications or through Triple Zero '000'</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>If conducting IFT from a medical facility or hospital and NEPT crew members still at facility, consider what management options available at sending facility and escalate care using normal means within facility, for example, 'MET call'</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>If unable to contact AV or other relevant communications centre in the case of significant event, emergency or disaster that is likely to overwhelm communications systems (for example, thunderstorm asthma or bushfire emergencies), NEPT providers and crew members may commence transport to the closest emergency department or other source of higher-level clinical care or support.</li>\n</ul>\n<p class=\"fp-p\">Once this is completed, consider the following actions:</p>\n<ul class=\"fp-ul\">\n<li>Change type of VSS gained, for example, consider manual BP vs automatic BP</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Change crew members if clinical grade is different or tasks overwhelm initial crew member</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Refer to CPPs to pre-empt management options</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Apply extra equipment where required or in anticipation of deterioration -- for example, defibrillator pads or preparing resuscitation equipment</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Contact for consultation with provider clinician OR AV clinician</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Contact for consultation sending or receiving facility for management advice OR if still at sending facility assist with continued management of patient to optimise prior to transport</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Consult with poisons information line in case of suspected toxicology presentation by calling\\ 13 11 26</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Pre-empting and communicating specialist resources that may be required following contact to AV -- for example, MICA, AAV, Manual Handling assistance, Mobile Stroke Unit (MSU)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Fax or picture messaging of ECG to appropriate consult for diagnostic cross-checking</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Consult with specialist service (ARV or PIPER) for IFT. If contacting ARV or PIPER, state clearly that calling from a NEPT service</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>ARV: 1300 368 661</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>PIPER: 1300 137 650</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Consider upgrade to urgent ('code 1') driving to reach transport destination or other appropriate health service.</li>\n</ul>\n<p class=\"fp-p\">NEPT providers are required to establish a clinical oversight committee to review instances where clinical escalation is required. NEPT crew members should submit instances of clinical escalation to the NEPT provider for consideration as part of the committee to determine root cause and whether variation to practice needs to be considered. Clinical escalation implies no fault on the part of a NEPT crew member and is a cornerstone of patient safety.</p>", "CPP007": "<h2 class=\"fp-h2\">Oxygen therapy</h2>\n<p class=\"fp-p\">Oxygen therapy should be directed toward correcting hypoxaemia and not resolving a feeling of breathlessness. Patients should not be routinely administered oxygen in the presence of normal oxygen saturations (SPO<sub>2</sub>), except in the case of critical illnesses including:</p>\n<ul class=\"fp-ul\">\n<li>cardiac arrest</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>major trauma/head injury</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>undifferentiated (or septic) shock</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>anaphylaxis</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>seizures</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Diabetic ketoacidosis (DKA) and hyperosmolar hyperglycaemic state (HHS).</li>\n</ul>\n<p class=\"fp-p\">For critical illnesses, High flow 100% oxygen should be administered regardless of SPO<sub>2</sub> via NRB.</p>\n<p class=\"fp-p\">Oxygen targets are as follows:</p>\n<ul class=\"fp-ul\">\n<li>Most patients should receive a target SPO<sub>2</sub> of 94-98%</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Chronically hypoxaemic patients (including COPD, cystic fibrosis, neuromuscular disorders, bronchiectasis, severe obesity) should receive oxygen titrated to achieve an SPO<sub>2</sub> of 88-92%. Care must be taken to avoid the over-administration of oxygen in this patient cohort</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Chronically hypoxaemic patients who also present with a critical illness should have oxygen applied until haemodynamically stable.</li>\n</ul>\n<p class=\"fp-p\">Where SPO<sub>2</sub> is unavailable or unreliable and a patient appears short of breath, initial oxygen delivered by nasal cannula or face mask at 6-8L is appropriate until a reliable SPO<sub>2</sub> level can be acquired. Situations where SPO<sub>2</sub> may be unreliable include:</p>\n<ul class=\"fp-ul\">\n<li>peripheral vascular disease</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>suspected carbon monoxide (CO) poisoning -- the SPO<sub>2</sub> measurement will not differentiate between carboxyhaemoglobin and oxyhaemoglobin and will present an artificially high reading. Where CO poisoning is suspected high flow oxygen should be applied</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>severely shocked patients with poor peripheral perfusion</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>cold extremities.</li>\n</ul>\n<p class=\"fp-p\">As a general rule, when managing a hypoxic patient, a low SPO<sub>2</sub> reading dictates selecting an oxygen delivery system with a higher fraction of inspired Oxygen (FiO<sub>2</sub>). The suggest flow rate and FiO<sub>2</sub> of oxygen delivery systems are as follows:</p>\n<p class=\"fp-p\">Table 11. FiO<sub>2</sub> and oxygen delivery system guide</p>\n<p class=\"fp-p\">------------------------------------------------------------------------ Mask                        FiO<sub>2</sub>               Flow rate</p>\n<p class=\"fp-p\">--------------------------- -------------------- ----------------------- Nasal cannulae              &gt; 21-35 %           1-6 L/min</p>\n<p class=\"fp-p\">Simple face mask (Hudson    40-60%               6-8 L/min mask)</p>\n<p class=\"fp-p\">Non-rebreather mask (NRB)   &gt; 60%               10-15 L/min</p>\n<p class=\"fp-p\">Bag valve mask (BVM)        100% (with good      15 L/min or enough to seal)                inflate reservoir bag</p>\n<p class=\"fp-p\">Nebuliser mask (NEB)        40-50%               8 L/min</p>\n<p class=\"fp-caption\">Figure 6. Oxygen administration guidance</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP007\" data-idx=\"1\"></div>", "CPP008": "<h2 class=\"fp-h2\">Narrow complex tachycardia (NCT)</h2>\n<p class=\"fp-p\">Typically, tachyarrhythmias will present to high acuity services undertaking cardiac-related IFT, however may present as an incidental finding. Where there is an agreed management plan or medical order, in the case of a tachyarrhythmia this takes precedence over the management options presented below.</p>\n<p class=\"fp-p\">Narrow complex tachycardias (NCT) present when a pacemaker site above the ventricles is firing abnormally. NCT ECG strips will have differences depending on the rhythm but share the characteristic of having a QRS complex &lt; 0.12s and a rate &gt; 100. NCT are generally divided into the following types which may be identifiable by NEPT crew members.</p>\n<ul class=\"fp-ul\">\n<li>Sinus tachycardia (STach)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>(Rapid) atrial fibrillation (R-AF)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Paroxysmal supraventricular tachycardia (PSVT/SVT)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Atrial flutter (AFlutter)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Atrial tachycardia</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Junctional tachycardia.</li>\n</ul>\n<p class=\"fp-p\">NEPT crew members should be suspicious of unexplained sinus tachycardias as this may be a sign of physiological distress.</p>\n<p class=\"fp-p\">Some common medicines that may be provided by sending health services to high acuity NEPT services include:</p>\n<ul class=\"fp-ul\">\n<li>Adenosine</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Calcium channel blockers (for example, diltiazem or verapamil)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Beta blockers (for example, metoprolol or sotolol)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Anti-arrhythmic medicines (for example, amiodarone or flecainide).</li>\n</ul>\n<p class=\"fp-p\">Synchronised cardioversion is not to be authorised for routine use by NEPT crew members.</p>\n<p class=\"fp-caption\">Figure 7. Management of NCT</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP008\" data-idx=\"1\"></div>", "CPP009": "<h2 class=\"fp-h2\">Wide complex tachycardia (WCT)</h2>\n<p class=\"fp-p\">NEPT providers are not authorised to routinely commence transfer of a patient with a current WCT at time of transfer from a facility, however situations may arise where a WCT presents during the course of transport.</p>\n<p class=\"fp-p\">WCT is defined as:</p>\n<ul class=\"fp-ul\">\n<li>Lasting &gt; 30 seconds</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Rate &gt; 100</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>QRS &gt; 0.12 seconds</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Regular</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>AV dissociation or absence of P waves.</li>\n</ul>\n<p class=\"fp-p\">WCT may present for a number of reasons, including:</p>\n<ul class=\"fp-ul\">\n<li>cardiomyopathy</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>acidosis</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>coronary artery disease</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>drug toxicity</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Hyperkalaemia.</li>\n</ul>\n<p class=\"fp-p\">In the out-of-hospital environment without access to further diagnostic facilities a WCT should always be presumed to be a ventricular tachycardia (VT) and managed with anti-arrhythmics unless specifically planned for (for example, transfer of a patient with known hyperkalaemia).</p>\n<p class=\"fp-p\">All WCT should be managed with a high degree of caution and with the assumption of deterioration regardless of perfusion status at time of presentation.</p>\n<p class=\"fp-p\">The majority of NEPT services will not require the management options contained within this protocol. Management of WCT will be an infrequent occurrence and therefore clinical consult as part of escalation is strongly recommended.</p>\n<p class=\"fp-caption\">Figure 8. Management of WCT</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP009\" data-idx=\"1\"></div>", "CPP010": "<h2 class=\"fp-h2\">Bradycardia</h2>\n<p class=\"fp-p\">Bradycardia may be defined as a heart rate &lt; 60 bpm however many people may have a heart rate between 50-60 bpm in their day-to-day lives.</p>\n<p class=\"fp-p\">Escalation of care and decision to transport should be guided by the 'not suitable for NEPT' criteria. The management indicated within this protocol relates to an unplanned presentation of symptomatic bradycardia during transport. Unstable symptomatic bradycardia requiring intervention is defined as the following:</p>\n<ul class=\"fp-ul\">\n<li>Less than adequate perfusion (for example hypotension or altered mentation)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>HR &lt; 20 regardless of overall perfusion status</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Persistent ventricular escape rhythms or runs of VT in between bradycardia.</li>\n</ul>\n<p class=\"fp-p\">Note that atropine may not be effective in the case of a complete or 2<sup>nd</sup> degree type II heart block, however, should still be administered.</p>\n<p class=\"fp-p\">Occasionally high acuity NEPT may be required to transport patients who are undergoing investigation for bradycardia who have active management. Common medication infusions which may be encountered include:</p>\n<ul class=\"fp-ul\">\n<li>Isoprenaline</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Dopamine</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Adrenaline (epinephrine).</li>\n</ul>\n<p class=\"fp-p\">External transcutaneous pacing is not routinely authorised for use by NEPT crew members.</p>\n<p class=\"fp-p\">The majority of NEPT services will not require the management options contained within this protocol. Management of symptomatic bradycardia will be an infrequent occurrence and therefore clinical consult as part of escalation is strongly recommended.</p>\n<p class=\"fp-caption\">Figure 9. Management of bradycardia</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP010\" data-idx=\"1\"></div>", "CPP011": "<h2 class=\"fp-h2\">Sepsis recognition and escalation</h2>\n<p class=\"fp-p\">Sepsis is a condition which spans a clinical continuum with a complex series of interactions of inflammatory responses and microvascular injury which ultimately may lead to a state of septic shock and is one of the leading causes of preventable death worldwide.</p>\n<p class=\"fp-p\">NEPT services are often the transport means for vulnerable members of the community with the potential for any infective process to progress into sepsis. The following are some risk factors for infection progressing to sepsis:</p>\n<ul class=\"fp-ul\">\n<li>Elderly patients</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Compromised immune system including patients undergoing chemotherapy treatment</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Chronic kidney or liver disease</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Admission to hospital for a significant length</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Recent antibiotic administrations</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Invasive devices, for example an in-dwelling catheter (IDC).</li>\n</ul>\n<p class=\"fp-p\">For this reason, an NEPT specific sepsis recognition and escalation pathway has been developed to assist NEPT crew members to identify and escalate care. While management options may be limited in NEPT services, early identification and escalation of care is aimed at preventing severe complications of sepsis.</p>\n<p class=\"fp-p\">Criteria have been developed based on a modified systemic inflammatory response syndrome SIRS criteria and a modified sepsis related organ failure (qSOFA) criteria with the recognition that blood analysis, in particular blood lactate and white cell count (WCC), is not feasible in the NEPT environment.</p>\n<p class=\"fp-caption\">Figure 10. Sepsis recognition and management</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP011\" data-idx=\"1\"></div>", "CPP012": "<h2 class=\"fp-h2\">Undifferentiated shock</h2>\n<p class=\"fp-p\">NEPT crew members may encounter patients who are in a state of shock as an incidental finding during the course of unplanned NEPT activities, such as when responding to cases generated by Triple Zero '000' or SHEMP activations or as an acute deterioration during IFT.</p>\n<p class=\"fp-p\">Shock can be defined as a state of cellular and tissue hypoxia due to either reduced oxygen delivery, increased oxygen consumption, inadequate oxygen utilization or a combination of these processes.</p>\n<p class=\"fp-p\">It is important to consider a patient's overall perfusion status when determining shock. The most visible marker of shock is profound hypotension and for this reason may be the decision point to initiate intervention. Overall perfusion status should be established using the perfusion status assessment table 2.</p>\n<p class=\"fp-p\">Shock is divided into different types based on the cause. Table 12 lists the types of shock and common examples:</p>\n<p class=\"fp-p\">Table 12. Shock types</p>\n<p class=\"fp-p\">+-----------------------------------+----------------------------------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Shock type</th><th>Example cause(s)</th></tr>\n</tbody></table>\n<p class=\"fp-p\">+===================================+==================================+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Obstructive shock\\</th><th>-   Tension pneumothorax</th></tr>\n<tr><td>(unlikely during NEPT service</td><td></td></tr>\n<tr><td>delivery)</td><td>-   Haemothorax</td></tr>\n<tr><td></td><td>-   Cardiac tamponade</td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------+----------------------------------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Cardiogenic shock</th><th>-   Acute myocardial Infarction</th></tr>\n<tr><td></td><td>-   Tachyarrhythmias</td></tr>\n<tr><td></td><td>-   Bradyarrhythmias</td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------+----------------------------------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Distributive shock</th><th>-   Sepsis</th></tr>\n<tr><td></td><td>-   Anaphylaxis</td></tr>\n<tr><td></td><td>-   Neurogenic shock</td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------+----------------------------------+</p>\n<table class=\"fp-table\"><tbody>\n<tr><th>Hypovolaemic shock\\</th><th>-   Lack of blood volume</th></tr>\n<tr><td>(unlikely during NEPT service</td><td>(haemorrhage)</td></tr>\n<tr><td>delivery)</td><td></td></tr>\n<tr><td></td><td>-   Lack of systemic volume\\</td></tr>\n<tr><td></td><td>(vomiting, diarrhoea, burns)</td></tr>\n</tbody></table>\n<p class=\"fp-p\">+-----------------------------------+----------------------------------+</p>\n<p class=\"fp-p\">NEPT crew members should consider management of specific conditions relevant, which may\\ lead to a shocked state, and manage these as per the applicable CPP, For example:</p>\n<ul class=\"fp-ul\">\n<li>Anaphylaxis should prioritise management with adrenaline (epinephrine) according to\\ <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP020\\')\">CPP020</span> Anaphylaxis</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Bradycardia should prioritise management to increase heart rate according to <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP010\\')\">CPP010</span> Bradycardia</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Tachyarrthymias should prioritise a decrease in heart rate according to <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP008\\')\">CPP008</span> Narrow complex tachycardia or <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP009\\')\">CPP009</span> Wide complex tachycardia</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Cardiogenic shock associated with ACS should be managed according to <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP013\\')\">CPP013</span> Cardiogenic shock.</li>\n</ul>\n<p class=\"fp-p\">NEPT high acuity services may transport patients who have a condition that would lead to a shocked state provided that these patients are not expected to deteriorate enroute and are stable at time of transfer. Prior to departure from the sending facility a plan for deterioration needs to be agreed upon with a medication order and infusion schedule prepared.</p>\n<p class=\"fp-p\">Some common vasopressors:</p>\n<ul class=\"fp-ul\">\n<li>Noradrenaline (norepinephrine)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Adrenaline (epinephrine)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Metaraminol</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Vasopressin</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Dopamine</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Phenylephrine</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Dobutamine.</li>\n</ul>\n<p class=\"fp-p\">Management options presented below represent management of an undifferentiated acute shock state and/or following initial unsuccessful management of a presumed cause for which no other management option is presented.</p>\n<p class=\"fp-p\">The majority of NEPT services will not require the management options contained within this protocol. Management of undifferentiated shock will be an infrequent occurrence and therefore clinical consult as part of escalation is strongly recommended.</p>\n<p class=\"fp-caption\">Figure 11. Management of undifferentiated shock</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP012\" data-idx=\"1\"></div>", "CPP013": "<h3 class=\"fp-h3\">Cardiogenic shock</h3>\n<p class=\"fp-p\">Cardiogenic shock can be defined as a shock state (SBP &lt;90 mmHg) from a primary cardiac disorder. For purposes of intervention, this CPP refers to a patient with ≤ inadequate perfusion as defined on listed in table</p>\n<p class=\"fp-p\">2. The most common causes of cardiogenic shock likely to be recognised</p>\n<p class=\"fp-p\">by NEPT crew members and encountered during NEPT service delivery, and that this CPP applies to, include:</p>\n<ul class=\"fp-ul\">\n<li>acute myocardial ischaemia (AMI)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>pulmonary embolus</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>right ventricular failure</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>overdose of cardiotoxic trugs, medication overdoses (beta/calcium channel blockers).</li>\n</ul>\n<p class=\"fp-p\">NEPT crew members must not transport a patient who has experienced cardiac chest pain within 2 hours of presentation.</p>\n<p class=\"fp-p\">Other causes of shock should be managed per <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP009\\')\">CPP009</span> Undifferentiated shock. For tachy/brady-arrhythmias this should be managed per the relevant CPP.</p>\n<p class=\"fp-p\">Care should be applied by high acuity services when managing with adrenaline (epinephrine) as the effects will increase myocardial workload and consequently metabolic demand. The majority of NEPT services will not require the management options contained within this protocol. Management of cardiogenic shock will be an infrequent occurrence and is therefore clinical consult as part of escalation is strongly recommended.</p>\n<p class=\"fp-caption\">Figure 12. Management of cardiogenic shock</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP013\" data-idx=\"1\"></div>", "CPP014": "<h2 class=\"fp-h2\">Acute cardiogenic pulmonary oedema (ACPO)</h2>\n<p class=\"fp-p\">Acute pulmonary oedema can be defined as an accumulation of excessive fluid in the alveolar walls and alveolar spaces of the lung. This manifests in the following ways.</p>\n<ul class=\"fp-ul\">\n<li>Compromised respiratory status</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Hypoxia</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Orthopnoea (increasing shortness of breath or feeling of drowning whilst supine).</li>\n</ul>\n<p class=\"fp-p\">Pulmonary oedema can be classified as cardiogenic (resulting from an issue with the heart) or non-cardiogenic. Non-cardiogenic pulmonary oedema usually results from direct injury to the lung parenchyma (tissue) or vasculature or as a result of volume (fluid) overload and is not covered by this CPP. If non-cardiogenic pulmonary oedema is encountered and recognised, management should be targeted to correct hypoxia as described in <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP007\\')\">CPP007</span> Oxygen therapy and supportive care.</p>\n<p class=\"fp-p\">ACPO is likely to be seen during NEPT service delivery as an incidental finding whilst conducting unplanned (non IFT) service delivery or during the transport of patients with chronic issues such as:</p>\n<ul class=\"fp-ul\">\n<li>coronary artery disease with left ventricular failure</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>congestive heart failure</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>cardiomyopathy</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>valvular heart diseases</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>cardiac dysrhythmias</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>right to left shunts.</li>\n</ul>\n<p class=\"fp-p\">Clinical indicators that may assist a provisional diagnosis of ACPO include:</p>\n<ul class=\"fp-ul\">\n<li>excessive shortness of breath on exertion</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>excessive sweating or diaphoresis</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>blood-tinged or pink sputum in severe presentations</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>chest pain -- if associated with an acute cardiac event</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>significant hypertension -- and if present, is an indication of severe left ventricular systolic dysfunction and patient may require management per <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP013\\')\">CPP013</span> Cardiogenic shock</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>dependent oedema</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>'crackles' heard on chest auscultation.</li>\n</ul>\n<p class=\"fp-p\">NEPT crew members may transport patients with chronic pulmonary oedema provided there is no acute deterioration present or forecast, no recent change in patient condition and the patient's physiological status would not otherwise make the patient ineligible for NEPT transport.</p>\n<p class=\"fp-p\">The use of non-invasive ventilation (CPAP/Bi-Level) is not authorised for routine use by NEPT services but may be considered by high acuity services if an escort is provided or the attending NEPT crew member is endorsed and a clinical plan is developed with sending facility prior to transport. In this unusual circumstance the patient should be stable on the NIV prior to transfer. The use of NIV must not occur during air transport.</p>\n<p class=\"fp-p\">The management of ACPO in NEPT service delivery is targeted at reducing blood pressure and improving hypoxia.</p>\n<p class=\"fp-caption\">Figure 13. Management of acute cardiogenic pulmonary oedemea</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP014\" data-idx=\"1\"></div>", "CPP015": "<h2 class=\"fp-h2\">Stroke</h2>\n<p class=\"fp-p\">Acute stroke is the second leading cause of death worldwide and the leading cause of disability. There are two main types of stroke -- ischaemic and haemorrhagic. Both types of stroke are time-critical and very difficult to differentiate in the out-of-hospital environment without access to medical imaging services. The key objective is identification of stroke symptoms and rapid transfer.</p>\n<p class=\"fp-p\">For the purposes of this CPP, stroke is defined as a set of neurological signs and symptoms that together would indicate a stroke even if symptoms are improving or have improved.</p>\n<h5 class=\"fp-h5\">Melbourne ambulance stroke screen (MASS)</h5>\n<p class=\"fp-p\">In the setting of a normal blood glucose level (BGL), an abnormal finding in one or more of the following is MASS positive for suspicion of stroke.</p>\n<p class=\"fp-p\">Table 13. Stroke symptoms</p>\n<p class=\"fp-p\">------------------------------------------------------------------------ Instruction        Normal finding    Abnormal finding</p>\n<p class=\"fp-p\">------------ ------------------ ----------------- ---------------------- Facial droop Patient to show    Both sides of the One side of the face teeth or smile     face move         does not move as well as the other</p>\n<p class=\"fp-p\">Speech       Patient to repeat  Patient says the  Patient slurs words, 'you can't teach   correct words     says incorrect words an old dog new     with no slurring  or is unable to speak tricks'                              or understand</p>\n<p class=\"fp-p\">Hand grip    Patient to squeeze Equal grip        Unilateral weakness your fingers       strength</p>\n<p class=\"fp-p\">Alternatively, any concerning acute-onset unexpected symptom(s) which cannot be explained should be escalated. Such symptoms include:</p>\n<ul class=\"fp-ul\">\n<li>prolonged gaze toward one side of the body</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>favouring one side of the body and/or uneven gait</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>disinhibition of speech (that is, inappropriate words)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>impaired judgement</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>spontaneous urinary incontinence</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>vertigo not normal presentation</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>ataxia (clumsy involuntary movements)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>visual field disturbances</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>altered conscious state or acute onset confusion.</li>\n</ul>\n<p class=\"fp-p\">Presumed time of stroke should be from when patient was last seen well. Stroke treatment timeframes are longer than previously thought.</p>\n<ul class=\"fp-ul\">\n<li>Thrombolysis up to 12-hours post-stroke</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Endovascular Clot Retrieval (ECR) up to 24 hours post-stroke.</li>\n</ul>\n<p class=\"fp-p\">All patients who present to NEPT services that are MASS positive or display concerning neurological signs and symptoms must have care escalated.</p>\n<p class=\"fp-p\">NEPT services may be directed to transport stroke patients if it is outside the window for management or the patient is unlikely to receive further management, for example, if the patient relies on others for all activities of daily living.</p>\n<p class=\"fp-p\">The use of NEPT to transport confirmed stroke patients for ECR from a facility that has initiated thrombolysis is not routinely endorsed. If this occurs on direction of the AV communications centre, NEPT crew members are to ensure that management priorities and escalation points are discussed prior to departure from the sending facility.</p>", "CPP016": "<h2 class=\"fp-h2\">Headache</h2>\n<p class=\"fp-p\">Headaches may present during NEPT service delivery and be characterised in a number of ways. It is not possible or realistic to classify different headache types during NEPT service delivery and as such the goal should be identification of symptoms of concern which may indicate a serious cause for the headache, escalation of care where these symptoms are identified and analgesia to provide relief from symptoms.</p>\n<p class=\"fp-p\">NEPT services are not authorised to routinely transport patients experiencing an undiagnosed headache which is not typical for the patient.</p>\n<p class=\"fp-p\">In addition to standard assessment, symptoms of concern include:</p>\n<ul class=\"fp-ul\">\n<li>Sudden onset</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Significant pain at time of initial presentation</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Visual disturbances</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Significant hypertension</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Other abnormal neurological signs or symptoms</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Unilateral headache</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Nausea and vomiting</li>\n</ul>\n<p class=\"fp-p\">If these symptoms present NEPT services should escalate care as per <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP005\\')\">CPP005</span> clinical escalation.</p>\n<p class=\"fp-p\">Management of pain should be as per <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP029\\')\">CPP029</span> pain relief with a preference to commence management with oral paracetamol.</p>", "CPP017": "<h2 class=\"fp-h2\">Seizures</h2>\n<p class=\"fp-p\">Seizures are a sign of abnormal brain activity and involve a complex relationship of neurotransmitters. It is important to be aware that not every seizure presents the same. Seizures can be classified in the following ways, which NEPT crew members may recognise:</p>\n<ul class=\"fp-ul\">\n<li>Generalised</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Tonic-clonic (generalised convulsive seizure) - involves rhythmic muscle jerking with a loss of consciousness</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Absent seizures -- patient presents with a vacant look and is unresponsive, generally self-limiting</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Myoclonic -- results in a sudden jerking of a part of the body</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Atonic -- involves a sudden loss of muscular control,</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Partial</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Simple focal -- a seizure that involves one part of the brain, leaving the person with awareness but unable to respond</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Complex focal -- seizure activity in one part of the brain, where the person is not aware, may lose focus, appear dazed or confused</li>\n</ul>\n<p class=\"fp-p\">Seizures may present due to a number of causes, such as:</p>\n<ul class=\"fp-ul\">\n<li>stroke</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>infective process including encephalitis or meningitis</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>brain tumour</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>drugs and medications</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>epilepsy</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>head injury</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>febrile seizures (paediatric)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>pregnancy (eclampsia).</li>\n</ul>\n<p class=\"fp-p\">For NEPT services the recognition of any type of seizure activity or concerning neurological sign(s) or symptom(s) should lead to prompt clinical escalation and supportive care. NEPT crew members should note the time of seizure activity commencing and its duration. It is important to recognise that ongoing seizure activity may have pronounced effects on BP, airway tone and oxygenation.</p>\n<p class=\"fp-p\">NEPT crew members should not attempt to control or physically restrain somebody experiencing a seizure or attempt to place anything in the patient's mouth. Suction is rarely required and should only be used if the airway is occluded, when applied it is to be short duration (&lt;5 seconds in any one attempt) and confined to the oropharynx.</p>\n<p class=\"fp-caption\">Figure 14. Management of seizures</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP017\" data-idx=\"1\"></div>", "CPP018": "<h2 class=\"fp-h2\">Asthma -- adult</h2>\n<p class=\"fp-p\">Bronchospasm is defined as a spasm of bronchial smooth muscle leading to narrowing of the bronchi and consequently a reduction in air moving in (reduced oxygen intake) and out of the lungs (reduced removal of carbon dioxide).</p>\n<p class=\"fp-p\">Bronchospasm is managed in different ways depending on the underlying condition. Management is targeted towards the resolution of spasm and a reduction in inflammatory mediators which lead to bronchospasm.</p>\n<p class=\"fp-p\">Asthma causes the muscles in the airways to tighten and the lining of the airway to become swollen and inflamed, producing sticky mucous. These changes cause the airways to become narrow, making it difficult to breathe. Asthma may have a number of triggers including:</p>\n<ul class=\"fp-ul\">\n<li>allergy triggers such as house dust mites, pollens, pets and moulds</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>cigarette smoke</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>viral infections -- for example, colds and flu</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>cold air or changes in the weather</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>work-related triggers -- for example, wood dust, chemicals, metal salts</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>some medication.</li>\n</ul>\n<p class=\"fp-p\">In Australia, asthma is usually a well-controlled condition, and most patients will be aware of an asthma exacerbation. Clinically, asthma may present with the following signs and symptoms signifying an exacerbation.</p>\n<ul class=\"fp-ul\">\n<li>Increased shortness of breath</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Wheezing on auscultation or audible without auscultation</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Tachycardia</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Sweating.</li>\n</ul>\n<p class=\"fp-p\">Where patients experience an acute exacerbation of their asthma, management is dictated by the patient's respiratory status. Patients that respond to management of mild to moderate asthma with a complete resolution of symptoms may continue transport with a NEPT service provided no physiological parameter would otherwise make the patient ineligible for NEPT transport.</p>\n<p class=\"fp-p\">Where patients present with bronchospasm of a cause other than asthma (for example, smoke inhalation) or for which no other protocol exists (for example, COPD) they should be managed using interventions detailed in this protocol, except for the use of IM adrenaline.</p>\n<p class=\"fp-caption\">Figure 15. Management of asthma</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP018\" data-idx=\"1\"></div>\n<h3 class=\"fp-h3\">Thunderstorm asthma</h3>\n<p class=\"fp-p\">Thunderstorm asthma poses a significant risk in Victoria during defined time periods, usually commencing in October and ending in December or early January annually.</p>\n<p class=\"fp-p\">The department releases high risk mapping and guidance for thunderstorm asthma &lt;https://www.health.vic.gov.au/environmental-health/epidemic-thunderstorm-asthma-risk-forecast&gt;.</p>\n<p class=\"fp-p\">NEPT providers may be activated as part of a SHEMP response to manage significant escalations relating to thunderstorm asthma and NEPT service providers should subscribe to alerts.</p>\n<p class=\"fp-p\">Where NEPT crew members suspect a thunderstorm asthma event or are entering a declared thunderstorm asthma event, consideration should be given to early IMI adrenaline delivery (either from a 1:1000 ampoule or from an auto-injector device). If there is a delay to normal means of clinical escalation including emergency ambulance services, NEPT crew members are authorised and encouraged to commence transport (instead of remaining on scene) to an appropriate ED if escalation through normal means is not possible.</p>", "CPP019": "<h2 class=\"fp-h2\">Asthma -- paediatric</h2>\n<p class=\"fp-p\">The general background and identification of asthma is similar to that of adult patients and management goals the same with the following considerations:</p>\n<ul class=\"fp-ul\">\n<li>Asthma exacerbations may be more dynamic with a lower threshold for clinical escalation required</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Nebulised therapy should be reserved for paediatric patients who present as severely unwell</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Early consideration should be given to IMI Adrenaline for severely unwell children</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Any exacerbation of paediatric asthma should involve an escalation of care.</li>\n</ul>\n<p class=\"fp-p\">Paediatric patients should be assessed using Table 14 (based on the paediatric assessment triangle) to determine severity prior to initiation of therapy.</p>\n<p class=\"fp-p\">Table 14. Paediatric asthma severity clinical features</p>\n<p class=\"fp-p\">------------------------------------------------------------------------- Mild/moderate     Severe              Critical</p>\n<p class=\"fp-p\">----------------- ----------------- ------------------- ----------------- Conscious state   Normal            Distressed          Altered</p>\n<p class=\"fp-p\">Work of breathing Increased         Markedly increased  Maximal</p>\n<p class=\"fp-p\">Tachycardia       Tachycardia       Tachycardia         Marked tachycardia</p>\n<p class=\"fp-p\">Speech            Phrase/sentence   Words               Unable to speak</p>\n<p class=\"fp-p\">Table 15. Paediatric IMI adrenaline doses</p>\n<p class=\"fp-p\"><table> <colgroup> <col style=\"width: 12%\" /> <col style=\"width: 8%\" /> <col style=\"width: 8%\" /> <col style=\"width: 8%\" /> <col style=\"width: 8%\" /> <col style=\"width: 8%\" /> <col style=\"width: 8%\" /> <col style=\"width: 8%\" /> <col style=\"width: 8%\" /> <col style=\"width: 8%\" /> <col style=\"width: 8%\" /> </colgroup> <thead> <tr class=\"header\"> <th>Age (years)</th> <th>≥ 2</th> <th>3</th> <th>4</th> <th>5</th> <th>6</th> <th>7</th> <th>8</th> <th>9</th> <th>10</th> <th>11</th> </tr> </thead> <tbody> <tr class=\"odd\"> <td>Dose of 1:1000 Adrenaline (IMI</td> <td><p>0.12 mg</p> <p>(0.12 ml)</p></td> <td><p>0.14 mg</p> <p>(0.14 ml)</p></td> <td><p>0.16 mg</p> <p>(0.16 ml)</p></td> <td><p>0.18 mg</p> <p>(0.18 ml)</p></td> <td><p>0.2 mg</p> <p>(0.2 ml)</p></td> <td><p>0.22 mg</p> <p>(0.22 ml)</p></td> <td><p>0.24 mg</p> <p>(0.24 ml)</p></td> <td><p>0.26 mg</p> <p>(0.26 ml)</p></td> <td><p>0.33 mg</p> <p>(0.33 ml)</p></td> <td><p>0.36 mg</p> <p>(0.36 ml)</p></td> </tr> </tbody> </table></p>\n<p class=\"fp-caption\">Figure 16. Management of asthma - paediatric</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP019\" data-idx=\"1\"></div>", "CPP020": "<h2 class=\"fp-h2\">Chronic obstructive pulmonary disease (COPD) exacerbation</h2>\n<p class=\"fp-p\">COPD can be defined as an irreversible chronic inflammatory lung disease causing an obstructed airflow to and from the lungs which may present to NEPT services as a periodic exacerbation. Chronic bronchitis and emphysema are the two most common conditions contributing to COPD, and management of an exacerbation is targeted to relieve symptoms associated with this including bronchoconstriction and hypoxia.</p>\n<p class=\"fp-p\">It is important to avoid the over-administration of oxygen to patients suffering from an exacerbation of COPD and generally an SPO<sub>2</sub> target of 88 per cent should be accepted.</p>\n<p class=\"fp-p\">COPD should be suspected in the patients over 40 years of age with:</p>\n<ul class=\"fp-ul\">\n<li>smoking history</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>progressively worsening dyspnoea (difficulty breathing) that has become worse</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>poor exercise tolerance</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>chronic cough or sputum production.</li>\n</ul>\n<p class=\"fp-p\">An exacerbation of COPD should be considered and managed in patients who present with:</p>\n<ul class=\"fp-ul\">\n<li>increased dyspnoea (worse than base level)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>increasing cough and sputum production</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>increased wheeze.</li>\n</ul>\n<p class=\"fp-p\">NEPT crew members must take care to not cause an exacerbation of COPD. Patients with COPD who are to be transported can have the risk of exacerbation reduced by:</p>\n<ul class=\"fp-ul\">\n<li>minimising exercise or effort during transfer</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>slow, deliberate and careful planning of transfers</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>use of wheelchair or stretcher to reduce effort.</li>\n</ul>\n<p class=\"fp-caption\">Figure 17. Management of acute exacerbation of chronic obstructive</p>\n<p class=\"fp-p\">pulmonary disease</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP020\" data-idx=\"1\"></div>", "CPP021": "<h2 class=\"fp-h2\">Anaphylaxis: adult</h2>\n<p class=\"fp-p\">Anaphylaxis may be defined as a severe, potentially life-threatening, systemic hypersensitivity reaction characterised by rapid onset of a life-threatening airway, breathing or circulatory problem(s) with usual (but not always) skin and mucosal changes. Anaphylaxis is becoming more prevalent within the Australian population and NEPT providers and crew members must be vigilant to ensure anaphylaxis is recognised and managed where it presents.</p>\n<p class=\"fp-p\">Some common triggers of anaphylaxis:</p>\n<ul class=\"fp-ul\">\n<li>Insect stings</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Food -- commonly nuts, eggs, shellfish, fish, soy and wheat</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Medications -- including parental, enteral and topical</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Physical exercise or cold</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Biological triggers -- idiopathic (no known cause), latex and antivenoms</li>\n</ul>\n<h3 class=\"fp-h3\">Recognition of anaphylaxis (RASH criteria)</h3>\n<p class=\"fp-p\">Anaphylaxis can be suspected using the following criteria ('RASH +'):</p>\n<ul class=\"fp-ul\">\n<li>Sudden onset of symptoms (usually &lt; 30 min or up to 4 hours),</li>\n</ul>\n<p class=\"fp-p\">AND</p>\n<ul class=\"fp-ul\">\n<li>Two or more of RASH</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>R: Respiratory distress</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>A: Abdominal symptoms (vomiting, nausea, diarrhoea)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>S: Skin or mucosal symptoms (rash, discolouration or mucous secretion)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>H: Hypotension (SBP &lt; 90)</li>\n</ul>\n<p class=\"fp-p\">> OR</p>\n<ul class=\"fp-ul\">\n<li>Isolated hypotension (SBP &lt; 90mmHg) following exposure to a <em>known</em> antigen,</li>\n</ul>\n<p class=\"fp-p\">> OR</p>\n<ul class=\"fp-ul\">\n<li>Isolated respiratory distress following exposure to a <em>known</em> antigen.</li>\n</ul>\n<p class=\"fp-p\">Where doubt exists about the diagnosis of anaphylaxis in the absence of any definitive other differential diagnosis, manage as per anaphylaxis and escalate care early.</p>\n<p class=\"fp-p\">Anaphylaxis management is centred around early intervention with IMI adrenaline. Other considerations should follow and not interrupt regular IMI adrenaline doses.</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP021\" data-idx=\"1\"></div>", "CPP022": "<h2 class=\"fp-h2\">Anaphylaxis -- paediatric</h2>\n<p class=\"fp-p\">The background information, recognition (RASH+ criteria) and management goals of anaphylaxis are broadly similar to the adult population. Below is a modified protocol for paediatric anaphylaxis:</p>\n<h5 class=\"fp-h5\">Recognition of anaphylaxis (RASH criteria)</h5>\n<p class=\"fp-p\">Anaphylaxis can be reasonably suspected using the following criteria ('RASH +'):</p>\n<ul class=\"fp-ul\">\n<li>Sudden onset of symptoms (usually &lt; 30 min or up to 4 hours)</li>\n</ul>\n<p class=\"fp-p\">AND</p>\n<ul class=\"fp-ul\">\n<li>Two or more of RASH. If two or more symptoms, consider differential diagnosis. If nothing obvious or easy to confirm, manage as anaphylaxis.</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>R: Respiratory distress</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>A: Abdominal symptoms (vomiting, nausea, diarrhoea)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>S: Skin or mucosal symptoms (rash, discolouration or mucous secretion)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>H: Hypotension (SBP &lt; 90)</li>\n</ul>\n<p class=\"fp-p\">OR</p>\n<ul class=\"fp-ul\">\n<li>Isolated hypotension (SBP &lt; 90mmHg) following exposure to a known antigen</li>\n</ul>\n<p class=\"fp-p\">OR</p>\n<ul class=\"fp-ul\">\n<li>Isolated respiratory distress following exposure to a known antigen.</li>\n</ul>\n<p class=\"fp-p\">Where doubt exists about the diagnosis of anaphylaxis in the absence of any definitive other differential diagnosis, manage as per anaphylaxis and escalate care early.</p>\n<p class=\"fp-p\">Anaphylaxis management is centred around early intervention with IMI adrenaline. Other considerations should follow and not interrupt regular IMI adrenaline doses.</p>\n<p class=\"fp-p\">Contact PIPER on 1300 137 650 for guidance for ongoing management. Clearly state position and that the call is coming from a NEPT service.</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP022\" data-idx=\"1\"></div>", "CPP023": "<h2 class=\"fp-h2\">Acute coronary syndrome -- cardiac chest pain</h2>\n<p class=\"fp-p\">Acute coronary syndrome (ACS) can be defined as a group of diseases in which blood flow to the heart is decreased. Specifically, ACS that this protocol applies to include:</p>\n<ul class=\"fp-ul\">\n<li>ST-elevation myocardial Infarction (STEMI)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>non-ST elevation acute coronary syndrome (NSTEAC), including non-ST elevation myocardial infarction (NSTEMI) and unstable angina</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>persistently increasing angina without definitive evidence of myonecrosis (heart muscle damage).</li>\n</ul>\n<p class=\"fp-p\">For the purposes of NEPT service delivery, the presence of suspicious acute central chest pain or epigastric pain which cannot be explained by other definitive diagnosis, should lead NEPT crew members to suspect ACS and manage accordingly.</p>\n<p class=\"fp-p\">Some other symptoms of concern include:</p>\n<ul class=\"fp-ul\">\n<li>nausea or vomiting</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>diaphoresis</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>ECG abnormalities</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>pain radiating to jaw or back</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>pain in chest or epigastric region that is described as aching, pressure, tightness or burning</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>dyspnoea.</li>\n</ul>\n<p class=\"fp-p\">The goal of NEPT management of ACS is to reduce platelet aggregation through the administration of aspirin, rapid clinical escalation, a reduction in myocardial workload by reducing hypertension with GTN, and pain relief.</p>\n<p class=\"fp-p\">In the case of ACS, the complete removal of pain is unlikely. The goal of analgesia should be to provide a level of pain relief which the patient considers mild.</p>\n<p class=\"fp-p\">12-lead ECGs may be acquired by NEPT services where there is capacity and appropriate equipment. Where a suspicious ECG is identified, this should be communicated as part of clinical escalation.</p>\n<p class=\"fp-p\">Management of associated symptoms (for example, nausea and vomiting, pain relief, acute cardiogenic pulmonary oedema) should be conducted as per the appropriate CPP.</p>\n<p class=\"fp-caption\">Figure 20. Management of acute coronary syndrome</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP023\" data-idx=\"1\"></div>", "CPP024": "<h2 class=\"fp-h2\">Hypoglycaemia</h2>\n<p class=\"fp-p\">Hypoglycaemia is defined as blood glucose level (BGL) concentration less than 4 mmol/L. Signs and symptoms of hypoglycaemia may not occur until levels lower than this and may include:</p>\n<ul class=\"fp-ul\">\n<li>altered level of consciousness (or unconscious)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>agitation</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>dizziness</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>increased appetite</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>sweating.</li>\n</ul>\n<p class=\"fp-p\">Hypoglycaemia is usually found in patients who have diabetes and are undergoing management with insulin, meglitinides and sulfonylureas. Accidental overdoses of medication (usually relative to the amount of energy intake the person is consuming) are the most common cause of hypoglycaemic episodes. Hypoglycaemia may also be found in certain patient cohorts who are not diabetics including:</p>\n<ul class=\"fp-ul\">\n<li>alcoholic patients</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>patient with critical illness or trauma</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>patients suffering from counter-regulatory hormone deficiencies</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>patients with some cancers.</li>\n</ul>\n<p class=\"fp-p\">Hypoglycaemia management is aimed toward correcting the low BGL and supportive care including airway security (if required).</p>\n<p class=\"fp-p\">It is important to note that glucagon may not be effective in patients who have low stores of glycogen, including:</p>\n<ul class=\"fp-ul\">\n<li>frail or elderly</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>people on low carbohydrate diets</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>alcoholic patients.</li>\n</ul>\n<p class=\"fp-p\">For patients who present with any of the symptoms of hypoglycaemia listed above but who have a BGL great than 4 mmol/L, it is important to consider other potential causes including:</p>\n<ul class=\"fp-ul\">\n<li>stroke</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>seizure (absent seizure)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>shock-state</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>tumour.</li>\n</ul>\n<p class=\"fp-p\">If a patient presents able to swallow and obeying commands, medium-high acuity services may attempt management with oral glucose prior to escalating care. If correction of symptoms and BGL occurs after one dose and physiological parameters do not preclude transport by NEPT, continue transport.</p>\n<p class=\"fp-caption\">Figure 21. Management of hypoglycaemia</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP024\" data-idx=\"1\"></div>", "CPP025": "<h2 class=\"fp-h2\">Hyperglycaemia</h2>\n<p class=\"fp-p\">Hyperglycaemia is defined as blood glucose level (BGL) concentration greater than 11 mmol/L.</p>\n<p class=\"fp-p\">Diabetic ketoacidosis (DKA) and hyperosmolar hyperglycaemic state (HHS) represent the extreme in the spectrum of hyperglycaemia. DKA and HHS are classified as medical emergencies and are a leading cause of mortality among diabetic patients.</p>\n<p class=\"fp-p\">DKA and HHS may occur in both type 1 and type 2 diabetes mellitus. DKA typically evolves within a few hours, whereas HHS has a slower onset of days to weeks.</p>\n<p class=\"fp-p\">Signs and symptoms of hyperglycaemic presentations include:</p>\n<ul class=\"fp-ul\">\n<li>altered level of consciousness (or unconscious)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>agitation</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>dizziness</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>seizure</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>sweating</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>polydipsia</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>polyuria</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>presence of ketones.</li>\n</ul>\n<p class=\"fp-p\">There is limited value in differentiating between hyperglycaemic crises during NEPT service delivery. Care for the hyperglycaemic patient, in the NEPT context, centres around general supportive care, clinical escalation and fluid replacement where indicated and within scope.</p>\n<p class=\"fp-caption\">Figure 22. Management of hyperglycaemia</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP025\" data-idx=\"1\"></div>", "CPP026": "<h2 class=\"fp-h2\">Nausea and vomiting</h2>\n<p class=\"fp-p\">Nausea and vomiting are caused by a complex series of interactions between different nervous system pathways with different causes including:</p>\n<ul class=\"fp-ul\">\n<li>vestibular nausea</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>medications in particular chemotherapy</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>allergies</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>migraines and headaches</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>ocular injury</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>acute coronary syndrome.</li>\n</ul>\n<p class=\"fp-p\">It is important to note that severe, uncontrollable and undifferentiated nausea and vomiting may be a sign of critical illness and care should be escalated.</p>\n<p class=\"fp-p\">The aim of this CPP is to provide management with an anti-emetic (ondansetron) that has an effect on both the vomiting centres within the nervous system and in the gastro-intestinal system to reduce negative side effects of uncontrollable nausea and vomiting. Often simple nausea and single-episode vomiting that is able to be tolerated does not require the administration of an anti-emetic.</p>\n<p class=\"fp-caption\">Figure 23. Management of nausea and vomiting</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP026\" data-idx=\"1\"></div>", "CPP027": "<h2 class=\"fp-h2\">Foreign body airway obstruction (FBAO)</h2>\n<p class=\"fp-p\">FBAO is a life-threatening emergency that is more common in the paediatric population, but with a higher mortality rate for adults in the out-of-hospital environment. FBAOs may be partial or complete obstructions. FBAO may result in inadequate or complete air flow to or from the lungs leading to insufficient oxygen exchange at a cellular level.</p>\n<p class=\"fp-p\">Key indicators of a partial airway obstruction include:</p>\n<ul class=\"fp-ul\">\n<li>clutching at throat</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>cough</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>crying or verbal response</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>stridor or wheeze</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>adequate or altered perfusion status</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>normal or altered CGS</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>respiratory difficulty.</li>\n</ul>\n<p class=\"fp-p\">Key indicators of a complete airway obstruction include:</p>\n<ul class=\"fp-ul\">\n<li>clutching at throat</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>ineffective or absent cough</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>absence of crying or verbal response</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>absence of stridor or wheeze</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>inadequate perfusion status</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>lack of consciousness</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>absence of ventilation</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>cyanosis.</li>\n</ul>\n<p class=\"fp-caption\">Figure 24. Management of suspected FBAO</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP027\" data-idx=\"1\"></div>", "CPP028": "<h2 class=\"fp-h2\">Laryngectomy and tracheostomy care</h2>\n<p class=\"fp-p\">This CPP is not for the purpose of creating a surgical airway. Its purpose is to give guidance in the event of airway emergencies associated with patients who have an existing tracheostomy or laryngectomy that NEPT services are likely to encounter. NEPT services are not authorised to transport patients where difficulty with an airway is forecast.</p>\n<p class=\"fp-p\">A tracheostomy is a surgical opening in the anterior neck and trachea to allow direct access into the trachea to facilitate ventilation for a variety of reasons. Tracheostomy patients can breathe through their stoma and through their mouth or nose to some extent. A tracheotomy tube with or without an inner tube may be present.</p>\n<p class=\"fp-p\">A laryngectomy is the surgical removal of the larynx and separation of the airway from the mouth, nose and oesophagus. Ventilation will be facilitated though a tracheotomy stoma. Importantly, patients with a laryngectomy cannot be ventilated or oxygenated via the mouth. A tube is usually not present. Other devices such as laryngeal buttons or speaking valves may be in situ.</p>\n<ul class=\"fp-ul\">\n<li>all NEPT acuity levels may transport a patient who lives daily with a surgical airway in situ provided no complications are forecast</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>NEPT high acuity services may transport patients with a recent surgical airway insertion &gt; 5 days prior to transport</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>patients with a surgical airway which has been inserted within 5 days prior to transport must be transported with a suitably qualified medical practitioner escort.</li>\n</ul>\n<p class=\"fp-caption\">Figure 25. Placement of different surgical airway types</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP028\" data-idx=\"1\"></div>\n<p class=\"fp-caption\">Figure 26. Management of surgical airway emergencies</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP028\" data-idx=\"2\"></div>", "CPP029": "<h2 class=\"fp-h2\">Pain relief</h2>\n<p class=\"fp-p\">The key areas of appropriate pain management include:</p>\n<ul class=\"fp-ul\">\n<li>pain assessment</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>provision of appropriate analgesia based on pain assessment</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>re-assessment and management of pain following analgesia.</li>\n</ul>\n<h3 class=\"fp-h3\">Pain assessment</h3>\n<p class=\"fp-p\">Assess pain using the most appropriate pain assessment tool(s) such as OPQRST/DOLOR, verbal rating scale, numeric rating scale and Wong-Baker FACES pain scale.</p>\n<p class=\"fp-p\">An inability to report or rate pain (for example, dementia, intellectual disability, neurodiversity, NESB) should not preclude analgesia. Where discomfort is evident in the setting of possible pain producing stimuli, analgesia may be indicated.</p>\n<h3 class=\"fp-h3\">Non-pharmacological management</h3>\n<p class=\"fp-p\">Basic care and non-pharmacological management of pain is fundamental and should be considered prior to pharmacological management. This includes:</p>\n<ul class=\"fp-ul\">\n<li>reassurance</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>posture</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>splinting</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>cooling of burns</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>occlusive dressings</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>control of temperature</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>ice packs</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>warm pack.</li>\n</ul>\n<h3 class=\"fp-h3\">Chronic pain</h3>\n<ul class=\"fp-ul\">\n<li>Exclude a new aetiology</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Ensure pain management plan followed</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Partial relief may be a more realistic goal.</li>\n</ul>\n<h3 class=\"fp-h3\">General notes</h3>\n<ul class=\"fp-ul\">\n<li>For IFTs, ensure adequate analgesia has been given prior to commencing transport or request analgesia for transport</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Consider dose reductions or longer dose intervals in small, elderly and frail patients. Entonox® must be self-administered and maximise ventilation in the space it is administered</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Dose commercial paracetamol syrup carefully as available in several strengths</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Paracetamol is not an appropriate analgesic for suspected acute coronary syndrome.</li>\n</ul>\n<p class=\"fp-p\">[</p>\n<p class=\"fp-p\">Table 16. Analgesic medication doses -- adult</p>\n<p class=\"fp-p\">---------------------------------------------------------------------------- Medication       Dose           Route          Repeat dose    Maximum dose</p>\n<p class=\"fp-p\">---------------- -------------- -------------- -------------- -------------- Paracetamol      500 mg-1g      oral           4-6/24         4000 mg daily</p>\n<p class=\"fp-p\">Methoxyflurane   3 ml           Inhaled        X 1 dose (3ml) 6 ml daily</p>\n<p class=\"fp-p\">Entonox          Titrate to     Inhaled        as required    NA pain</p>\n<p class=\"fp-p\">Table 17. Analgesic medication doses -- paediatric</p>\n<p class=\"fp-p\">--------------------------------------------------------------------------------- Medication       Dose             Route               Repeat dose  Maximum dose</p>\n<p class=\"fp-p\">---------------- ---------------- ------------------- ------------ -------------- Paracetamol      &gt; 1 month 15    oral                4-6/24       4 g daily (syrup)          mg/kg\\ (max 1g)</p>\n<p class=\"fp-p\">Methoxyflurane   3 ml             inhaled\\            X 1 dose     6 ml daily (self-administer)</p>\n<p class=\"fp-p\">Entonox          NA               NA                  NA           NA</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP029\" data-idx=\"1\"></div>", "CPP030": "<h2 class=\"fp-h2\">Burns</h2>\n<p class=\"fp-p\">This CPP refers to the management of acute burns. Where NEPT services are undertaking a transfer of a patient with pre-existing burns receiving management, these goals should be clearly articulated prior to transport with analgesia, wound management and fluid therapy (if any) in place prior to departure.</p>\n<p class=\"fp-p\">NEPT services are unlikely to encounter significant acute burn injuries during routine service-delivery, however may encounter presentations in the event of an activation under SHEMP. NEPT services may attend and manage patients with minor (superficial, not large total body surface area) acute burns.</p>\n<p class=\"fp-p\">Burn management principles include the following:</p>\n<ul class=\"fp-ul\">\n<li>Undertake cooling for at least 20 minutes. (Cool the burn and warm the patient,) Stop cooling the burn if the patient begins shivering or has a temperature &lt; 35C. Consider cooling length that has occurred prior to management by NEPT</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Cooling should be undertaken with ambient temperature water from a tap. Do not apply ice, iced water or dirty water (water not suitable for drinking)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>If running water is not available, the affected limb or body part may be immersed in water using a spray bottle or applying moist towels</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Chemical burns should be irrigated and cooled if pain persists. Take care to avoid washing chemicals into eyes or other sensitive areas and to avoid spreading chemicals further on the patient, bystanders or NEPT crew member. This may require very large volumes of water</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Remove burnt clothing, clothing containing chemicals or hot liquid when safe to do so. Do not attempt to remove clothing that is adhered to underlying tissue</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Minimise heat loss by applying blankets or thermal blankets and continuing to monitor patient temperature</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>After receiving cooling therapy, apply cling-wrap longitudinally to the affected area to provide a barrier for infection. Applying cling-wrap longitudinally allows for swelling of the affected area.</li>\n</ul>\n<p class=\"fp-p\">NEPT crew members should apply particular caution if attending a patient who has been involved in an explosive or flash fire event where there is potential for airway burns. Signs of airway burns include the following:</p>\n<ul class=\"fp-ul\">\n<li>Evidence of burns to upper torso, neck, face</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Facial and upper airway oedema (swelling)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Sooty sputum</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Burns that occurred in an enclosed space</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Singed facial hair</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Respiratory distress (including audible stridor)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Hypoxia.</li>\n</ul>\n<p class=\"fp-p\">The following burns must have care escalated and require assessment and transport by emergency ambulance:</p>\n<ul class=\"fp-ul\">\n<li>All significant burns (partial or full thickness)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Superficial burns involving more than a localised area of the body</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Burns that meet major trauma criteria</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Burns in sensitive areas (genitals, hands, feet, face).</li>\n</ul>\n<p class=\"fp-p\">Classification of burns:</p>\n<ul class=\"fp-ul\">\n<li>Superficial -- involves the epidermal (outer) layer of the skin</li>\n</ul>\n<p class=\"fp-p\">```{=html} <!-- --> ```</p>\n<ul class=\"fp-ul\">\n<li>Reddened tender skin</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Painful to touch</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Skin is intact</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Includes sunburn, hot water scalds</li>\n</ul>\n<p class=\"fp-p\">```{=html} <!-- --> ```</p>\n<ul class=\"fp-ul\">\n<li>Partial thickness -- can be classified further but involves all of the inner layers of the skin</li>\n</ul>\n<p class=\"fp-p\">```{=html} <!-- --> ```</p>\n<ul class=\"fp-ul\">\n<li>Divided into superficial partial thickness, and deep partial thickness</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Blistering and skin loss</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Sensation present</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Painful</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Will bleed to pinprick</li>\n</ul>\n<p class=\"fp-p\">```{=html} <!-- --> ```</p>\n<ul class=\"fp-ul\">\n<li>Full thickness -- involves a burn that destroys both layers of skin and may penetrate more deeply into underlying structures.</li>\n</ul>\n<p class=\"fp-p\">```{=html} <!-- --> ```</p>\n<ul class=\"fp-ul\">\n<li>Dry</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>White or blackened skin</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Absent sensation</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Ne bleeding to pinprick</li>\n</ul>\n<p class=\"fp-caption\">Figure 28. Management of burns</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP030\" data-idx=\"1\"></div>", "CPP031": "<h2 class=\"fp-h2\">Fractures or dislocations</h2>\n<p class=\"fp-p\">The principles of sound fracture and dislocation management in NEPT service delivery revolve around the following points:</p>\n<ul class=\"fp-ul\">\n<li>Irrigate and dress open wounds.</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Assess distal neurovascular observations:</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Pulse and capillary refill</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Colour</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Warmth</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Movement</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Sensation</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Pad natural hollows (for example, between thighs), deformities and bony prominences to maintain natural alignment</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Secure above and below injury sites with correct splint type, for example,</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Traction splint for femoral and upper 2/3 lower leg fracture</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Anatomical splint for neck of femur (NOF) fractures</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Constant reassessment of neurovascular observations</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Adequate analgesia as per <span class=\"fp-cpp-link\" onclick=\"jumpToProtocol(\\'CPP028\\')\">CPP028</span> Pain relief.</li>\n</ul>\n<p class=\"fp-p\">Altered sensation, loss of a pulse or cold/dusky skin in a limb distal to a fracture or dislocation are indicators of neurological or vascular compromise, constitutes a limb threatening injury and is considered time critical.</p>\n<p class=\"fp-p\">Where NEPT services attend patients with simple closed fractures, transport is authorised provided the NEPT service can appropriately splint and adequately control pain.</p>", "CPP032": "<h2 class=\"fp-h2\">Traumatic head injury</h2>\n<p class=\"fp-p\">Traumatic head injury in this CPP refers to an injury as a result of physical trauma causing actual or potential damage to the brain and can result from a blunt or penetrating injury mechanism.</p>\n<p class=\"fp-p\">Any patient with a GCS reduction of 2 or more than normal GCS should be considered time critical and care escalated.</p>\n<p class=\"fp-p\">Patients with a GCS of 13-15 with any of the following factors should be considered as time critical and care must be escalated regardless of NEPT acuity level:</p>\n<ul class=\"fp-ul\">\n<li>Any loss of consciousness exceeding 5 minutes</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Skull fracture (depressed, open or base of skull)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Vomiting more than once</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Neurological deficit</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Seizure at any time associated with head injury</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Any other concerning neurological symptom following a fall.</li>\n</ul>\n<p class=\"fp-p\">In addition to this:</p>\n<ul class=\"fp-ul\">\n<li>Any patient that presents with a GCS &lt; 15 following a blunt head injury mechanism should be escalated for advice prior to NEPT commencing transport. NEPT low acuity is not authorised to commence transport in any patient with a GCS that is not normal for the patient.</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Medium-high acuity may be authorised to commence transport with a patient who has a GCS no more than 2 points lower than normal following clinical advice.</li>\n</ul>\n<p class=\"fp-p\">NEPT crew members should also consider the following:</p>\n<ul class=\"fp-ul\">\n<li>Elderly patients who have had a standing-height fall and are anti-coagulated, on anti-platelet agents or have bleeding disorders should be transported to a neurosurgical capable facility</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>Intoxicated patients with a relatively minor mechanism of action may mask critical signs of head injury with intoxication. If assessment is unclear escalate care.</li>\n</ul>\n<p class=\"fp-caption\">Figure 29. Management of traumatic head injury</p>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP032\" data-idx=\"1\"></div>", "CPP033": "<h2 class=\"fp-h2\">Potential spinal injury</h2>\n<p class=\"fp-p\">Spinal cord injury (SCI) is a serious condition which often results in severe morbidity and permanent disability. SCI occurs when the axons of nerves running through the spinal cord are disrupted by a traumatic event. This disruption leads to a loss of motor and sensory tone below the level of injury, which is the defining feature of an SCI and may have profound effects on other aspects of the patient's physiological parameters, including blood pressure.</p>\n<p class=\"fp-p\"><strong>NEPT services may be utilised to transport patients with an established SCI for ongoing management.</strong></p>\n<p class=\"fp-p\"><strong>NEPT services may encounter patients with acute SCI following a traumatic injury (penetrating or blunt). If SCI is suspected, the patient should be considered time critical and care must be escalated.</strong></p>\n<p class=\"fp-p\">It is important to highlight that not every traumatic injury involving the spinal region is considered an SCI. The majority of injuries to the spinal region do not involve a loss of motor and sensory tone or, if present, are transient in nature and not associated with permanent disability. For patients without confirmed or suspected SCI but who may have an injury (including vertebral fracture) that may lead to an SCI, the objective is to restrict spinal motion of the patient and apply support including a soft cervical collar.</p>\n<p class=\"fp-p\">The use of a screening checklist to determine whether to undertake spinal precautions in the adult population is approved for medium-high acuity NEPT. Where there is doubt about the presence of a spinal injury or in the case of paediatric patients presenting with a relevant mechanism of injury, NEPT crew members should apply a soft cervical collar and spinal motion restriction (SMR) techniques.</p>\n<p class=\"fp-p\"><strong>NEPT may be utilised to transport patients with an acute injury/mechanism where SMR is applied but where there is no strong suspicion of associated SCI</strong></p>\n<p class=\"fp-p\">Where a soft collar is indicated, a rigid cervical collar may be used in place of a soft cervical collar until supply of rigid collars is exhausted by NEPT providers.</p>\n<p class=\"fp-p\">Prophylactic administration of an anti-emetic (ondansetron) should occur in the case of patients who are managed with spinal motion restriction.</p>\n<p class=\"fp-p\">Example mechanisms of injury which may indicate spinal injury include:</p>\n<ul class=\"fp-ul\">\n<li>motor vehicle collision</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>falls (standing height or greater)</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>object falling on patient head</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>blast injuries</li>\n</ul>\n<ul class=\"fp-ul\">\n<li>sports injuries.</li>\n</ul>\n<div class=\"fp-flowchart-slot\" data-cpp=\"CPP033\" data-idx=\"1\"></div>"};

