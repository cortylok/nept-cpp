  }
  .app-section-body { padding: 12px 16px; font-size: 13px; color: var(--text); line-height: 1.65; white-space: pre-wrap; }

  /* Abbreviations table */
  .abbr-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
