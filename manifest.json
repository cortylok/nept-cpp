  #med-drawer-close:hover { background: #fee2e2; color: #dc2626; border-color: #fca5a5; }

  /* Tab strip */
  .md-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid #e2e8f0;
    background: #f8faff;
    flex-shrink: 0;
