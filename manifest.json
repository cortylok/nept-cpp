    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: 6px;
    margin-top: 14px;
  }
  .md-section-label:first-child { margin-top: 0; }

  /* Dose rows */
  .md-dose-row {
    display: grid;
