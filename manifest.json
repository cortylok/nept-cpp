  .md-list li:last-child { border-bottom: none; }
  .md-list.ci li::before { content: '✕'; position: absolute; left: 0; color: #dc2626; font-size: 10px; top: 6px; }
  .md-list.prec li::before { content: '⚠'; position: absolute; left: 0; color: #d97706; font-size: 10px; top: 6px; }
  .md-list.se li::before { content: '◦'; position: absolute; left: 0; color: #6b7280; font-size: 12px; top: 4px; }

  /* Drawer backdrop */
  #med-drawer-backdrop {
