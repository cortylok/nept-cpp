// ── APPENDICES RENDERER ──────────────────────────────────────────────────

function renderAppendicesNav() {
  renderNav();
  // Show first appendix by default
  if (NEPT_DATA.appendices && NEPT_DATA.appendices.length && !currentItem.startsWith('APP')) {
    currentItem = NEPT_DATA.appendices[0].id;
    renderAppendix(currentItem);
    renderNav();
  }
}

function renderAppendix(id) {
  var app = NEPT_DATA.appendices && NEPT_DATA.appendices.find(function(a){ return a.id === id; });
  if (!app) return;
  currentItem = id;
  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('viewer').style.display = 'block';
  showModeToggle(false);
  var html = '<div class="app-header"><div class="app-icon">' + app.icon + '</div><div class="app-title">' + app.title + '</div></div>';

  if (app.type === 'abbreviations') {
    html += '<div style="padding:12px 16px 0;">';
    html += '<input class="abbr-search" id="abbr-search" placeholder="Search abbreviations..." oninput="filterAbbr(this.value)">';
    html += '</div>';
    html += '<div id="abbr-table-wrap"><table class="abbr-table" id="abbr-table">';
    app.abbreviations.forEach(function(a) {
      html += '<tr><td>' + escapeHtml(a.abbr) + '</td><td>' + escapeHtml(a.desc) + '</td></tr>';
    });
    html += '</table></div>';

  } else if (app.type === 'text' || app.type === 'equipment_text') {
    if (app.intro) html += '<div class="app-section-body" style="border-bottom:1px solid var(--border);">' + escapeHtml(app.intro) + '</div>';
    app.sections.forEach(function(s) {
      html += '<div class="app-section">';
      html += '<div class="app-section-heading">' + escapeHtml(s.heading) + '</div>';
      if (s.content) html += '<div class="app-section-body" style="white-space:pre-line;">' + escapeHtml(s.content) + '</div>';
      if (s.table) {
        html += '<div style="overflow-x:auto;margin-top:8px;">';
        html += '<table style="width:100%;border-collapse:collapse;font-size:12px;">';
        html += '<thead><tr>';
        s.table.headers.forEach(function(h) {
          html += '<th style="background:var(--accent);color:#fff;padding:8px 10px;text-align:left;font-weight:600;">' + escapeHtml(h) + '</th>';
        });
        html += '</tr></thead><tbody>';
        s.table.rows.forEach(function(row, ri) {
          html += '<tr style="background:' + (ri%2===0?'var(--card-bg)':'var(--sidebar-bg)') + ';">';
          row.forEach(function(cell) {
            html += '<td style="padding:7px 10px;border-bottom:1px solid var(--border);">' + escapeHtml(cell) + '</td>';
          });
          html += '</tr>';
        });
        html += '</tbody></table></div>';
      }
      html += '</div>';
    });

  } else if (app.type === 'pharmacology') {
    if (app.intro) html += '<div class="app-section-body" style="font-size:12px;color:var(--text2);border-bottom:1px solid var(--border);">' + escapeHtml(app.intro) + '</div>';
    app.drugs.forEach(function(drug, idx) {
      html += '<div class="drug-card" id="drug-' + idx + '">';
      html += '<div class="drug-card-header" onclick="toggleDrugCard(' + idx + ')">';
      html += '<div class="drug-card-name">💊 ' + escapeHtml(drug.name) + '</div>';
      html += '<div class="drug-card-chevron">▼</div>';
      html += '</div>';
      html += '<div class="drug-card-body">';
      function row(label, val) {
        if (!val || (Array.isArray(val) && val.length === 0)) return '';
        var vhtml = Array.isArray(val)
          ? '<ul>' + val.map(function(v){ return '<li>' + escapeHtml(v) + '</li>'; }).join('') + '</ul>'
          : escapeHtml(val);
        return '<div class="drug-row"><div class="drug-row-label">' + label + '</div><div class="drug-row-val">' + vhtml + '</div></div>';
      }
      html += row('Presentations', drug.presentations);
      html += row('Indications', drug.indications);
      html += row('Contraindications', drug.contraindications);
      html += row('Precautions', drug.precautions);
      html += row('Timings', drug.timings);
      html += row('Side Effects', drug.side_effects);
      html += row('Pharmacology', drug.pharmacology);
      html += row('Notes', drug.notes);
      if (drug.interactions) html += row('Interactions', drug.interactions);
      html += '</div></div>';
    });
  }

  document.getElementById('viewer').innerHTML = html;
}

function filterAbbr(q) {
  var rows = document.querySelectorAll('#abbr-table tr');
  var ql = q.toLowerCase();
  rows.forEach(function(r) {
    var text = r.textContent.toLowerCase();
    r.style.display = (!ql || text.includes(ql)) ? '' : 'none';
  });
}

function toggleDrugCard(idx) {
  var card = document.getElementById('drug-' + idx);
  if (card) card.classList.toggle('open');
}

