  }
  .md-repeat-rule { font-size: 12px; color: #0369a1; font-weight: 600; margin-bottom: 4px; }
  .md-repeat-max { font-size: 11px; color: #0c4a6e; margin-bottom: 3px; }
  .md-repeat-note { font-size: 11px; color: #64748b; font-style: italic; }

  .md-no-auth {
