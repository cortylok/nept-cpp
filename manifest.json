// MED DRAWER — click drug names in quick ref to get scope-aware popover
// ═══════════════════════════════════════════════════════════════════════════

// Keyword → med ID map (longest patterns first to avoid partial matches)
var MED_KW_MAP = [
  ['Glyceryl Trinitrate','GTN'],['glyceryl trinitrate','GTN'],
  ['Acetylsalicylic','ASPIRIN'],['Methoxyflurane','METHOXYFLURANE'],
  ['methoxyflurane','METHOXYFLURANE'],['Nitrous Oxide','ENTONOX'],
  ['nitrous oxide','ENTONOX'],['Acetaminophen','PARACETAMOL'],
  ['Nitrolingual','GTN'],['nitrolingual','GTN'],
  ['Ipratropium','IPRATROPIUM'],['ipratropium','IPRATROPIUM'],
  ['Metaraminol','METARAMINOL'],['metaraminol','METARAMINOL'],
  ['Ondansetron','ONDANSETRON'],['ondansetron','ONDANSETRON'],
  ['Paracetamol','PARACETAMOL'],['paracetamol','PARACETAMOL'],
  ['Salbutamol','SALBUTAMOL'],['salbutamol','SALBUTAMOL'],
  ['Albuterol','SALBUTAMOL'],['Ventolin','SALBUTAMOL'],
  ['Amiodarone','AMIODARONE'],['amiodarone','AMIODARONE'],
  ['Adrenaline','ADRENALINE'],['adrenaline','ADRENALINE'],
  ['Epinephrine','ADRENALINE'],['epinephrine','ADRENALINE'],
  ['Atropine','ATROPINE'],['atropine','ATROPINE'],
  ['Glucagon','GLUCAGON'],['glucagon','GLUCAGON'],
  ['Dextrose','GLUCOSE_PASTE'],['dextrose','GLUCOSE_PASTE'],
  ['Glucose','GLUCOSE_PASTE'],['Penthrox','METHOXYFLURANE'],
  ['Atrovent','IPRATROPIUM'],['EpiPen','ADRENALINE'],
  ['Anapen','ADRENALINE'],['Entonox','ENTONOX'],
  ['Aspirin','ASPIRIN'],['aspirin','ASPIRIN'],
  ['Zofran','ONDANSETRON'],
  ['GTN','GTN'],['D10','GLUCOSE_PASTE'],
  ['pMDI','SALBUTAMOL'],
];

// Build regex (longest patterns first, word-boundary aware)
var _medRe = null;
function getMedRegex() {
  if (_medRe) return _medRe;
  var patterns = MED_KW_MAP.map(function(pair) {
    return pair[0].replace(/[.*+?^${}()|[\]\\]/g,'\\$&');
  });
  _medRe = new RegExp('(' + patterns.join('|') + ')', 'g');
  return _medRe;
}

function getMedIdForKeyword(kw) {
  for (var i = 0; i < MED_KW_MAP.length; i++) {
    if (MED_KW_MAP[i][0] === kw) return MED_KW_MAP[i][1];
  }
  return null;
}

// Wrap drug names in text with clickable triggers
// Skips content already inside <a> or other <span class="med-trigger"> tags
function linkMeds(html) {
  if (!html || typeof html !== 'string') return html;
  // Process text nodes only — split on existing tags, process non-tag segments
  return html.replace(/(<[^>]+>)|([^<]+)/g, function(match, tag, text) {
    if (tag) return tag; // pass HTML tags through unchanged
    if (!text) return match;
    return text.replace(getMedRegex(), function(kw) {
      var medId = getMedIdForKeyword(kw);
      if (!medId) return kw;
      return '<span class="med-trigger" onclick="openMedDrawer(\'' + medId + '\')" title="Drug info: ' + kw + '">'
           + kw
           + '<span class="med-trigger-arrow">&#9660;</span>'
           + '</span>';
    });
  });
}

// ── Drawer open/close ─────────────────────────────────────────────────────
var _drawerCurrentMed = null;
var _drawerCurrentTab = 'dose';


// ─── CPP → relevant indication keywords (for dose filtering) ───────────────
var CPP_MED_IND = {
  CPP002:  {PARACETAMOL:['pain'],METHOXYFLURANE:['pain'],ENTONOX:['pain']},
  CPP004:  {ADRENALINE:['arrest','cardiac arrest'],AMIODARONE:['arrest','cardiac arrest']},
  CPP005:  {ADRENALINE:['arrest','cardiac arrest'],AMIODARONE:['arrest','cardiac arrest']},
  CPP009:  {AMIODARONE:['arrest','VF','VT','cardiac arrest']},
  CPP010:  {ATROPINE:['bradycardia']},
  CPP012:  {METARAMINOL:['shock','hypotension']},
  CPP013:  {ADRENALINE:['peri-arrest','cardiogenic','hypotension']},
  CPP014:  {GTN:['ACPO','ACS','hypertensive']},
  CPP018:  {SALBUTAMOL:['asthma'],IPRATROPIUM:['asthma'],ADRENALINE:['asthma','stridor','critical asthma']},
  CPP019:  {SALBUTAMOL:['asthma'],IPRATROPIUM:['asthma'],ADRENALINE:['asthma','stridor','critical asthma']},
  CPP020:  {SALBUTAMOL:['asthma','COPD'],IPRATROPIUM:['asthma','COPD']},
  CPP021:  {ADRENALINE:['anaphylaxis','stridor'],SALBUTAMOL:['anaphylaxis','bronchospasm'],IPRATROPIUM:['anaphylaxis','bronchospasm'],GLUCAGON:['anaphylaxis','refractory']},
  CPP022:  {ADRENALINE:['anaphylaxis'],SALBUTAMOL:['anaphylaxis','bronchospasm','asthma'],IPRATROPIUM:['anaphylaxis','bronchospasm','asthma']},
  CPP023:  {ASPIRIN:['ACS','cardiac'],GTN:['ACS','cardiac'],METHOXYFLURANE:['pain'],ENTONOX:['pain']},
  CPP024:  {GLUCOSE_PASTE:['hypoglycaemia'],GLUCAGON:['hypoglycaemia']},
  CPP026:  {ONDANSETRON:['nausea','vomiting']},
  CPP029:  {PARACETAMOL:['pain'],METHOXYFLURANE:['pain'],ENTONOX:['pain']},
  CPP030:  {PARACETAMOL:['pain'],METHOXYFLURANE:['pain'],ENTONOX:['pain']},
  CPP031:  {PARACETAMOL:['pain'],METHOXYFLURANE:['pain'],ENTONOX:['pain']},
  CPP032:  {PARACETAMOL:['pain'],METHOXYFLURANE:['pain']},
  CPP033:  {ONDANSETRON:['nausea','vomiting']}
};
var PAED_CPPS = ['CPP005','CPP019','CPP022'];

function openMedDrawer(medId) {
  var med = NEPT_DATA.medications.find(function(m) { return m.id === medId; });
  if (!med) return;
  _drawerCurrentMed = medId;
  _drawerCurrentTab = 'dose';

  var isPaed = PAED_CPPS.indexOf(currentItem) !== -1;

  // Header
  document.getElementById('med-drawer-name').textContent = med.name;
  document.getElementById('med-drawer-class').textContent = med.class || '';
  var scopeTag = document.getElementById('med-drawer-scope-tag');
  scopeTag.textContent = currentScope + (isPaed ? ' · Paediatric' : '');
  var scColors = {PTO:'#e0e7ff:#3730a3', EN:'#dbeafe:#1e40af',
                  ATA:'#dcfce7:#166534', RN:'#fef9c3:#854d0e', RNCC:'#fce7f3:#9d174d'};
  var sc = (scColors[currentScope]||'#dbeafe:#1e40af').split(':');
  scopeTag.style.background = sc[0]; scopeTag.style.color = sc[1];
  scopeTag.style.borderColor = sc[1] + '44';

  // Render all panels
  document.getElementById('md-panel-dose').innerHTML = renderMdDose(med, isPaed);
  document.getElementById('md-panel-ci').innerHTML = renderMdList(med.contraindications, 'ci', 'None listed.');
  document.getElementById('md-panel-prec').innerHTML = renderMdList(med.precautions, 'prec', 'No specific precautions listed.');
  document.getElementById('md-panel-se').innerHTML = renderMdList(med.side_effects, 'se', 'No side effects listed.');

  mdSwitchTab('dose');
  document.getElementById('med-drawer').classList.add('open');
  document.getElementById('med-drawer-backdrop').classList.add('open');
}


function closeMedDrawer() {
  document.getElementById('med-drawer').classList.remove('open');
  document.getElementById('med-drawer-backdrop').classList.remove('open');
}

function mdSwitchTab(tab) {
  _drawerCurrentTab = tab;
  document.querySelectorAll('.md-tab').forEach(function(el) {
    el.classList.toggle('active', el.getAttribute('data-tab') === tab);
  });
  document.querySelectorAll('.md-panel').forEach(function(el) {
    el.classList.toggle('active', el.id === 'md-panel-' + tab);
  });
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeMedDrawer();
});

// ── Dose panel renderer ───────────────────────────────────────────────────

function renderMdDose(med, isPaed) {
  var scope = currentScope;
  var cppId = currentItem;
  var html = '';

  // ── Scope authorisation check ───────────────────────────────────────────
  var authEntry = med.scope_authorisation && med.scope_authorisation[scope];
  // Meds with no entry at all for this scope = not authorised
  if (!authEntry) {
    return '<div class="md-no-auth">&#128683; <strong>' + med.name
      + '</strong> is not authorised for <strong>' + scope
      + '</strong> scope in NEPT.</div>';
  }
  // Stringify for simple string entries like "YES", "NO", "YES — sublingual"
  var authStr = (typeof authEntry === 'string') ? authEntry.toUpperCase() : (authEntry.level || '').toUpperCase();
  if (authStr === 'NO' || authStr === 'N/A') {
    return '<div class="md-no-auth">&#128683; <strong>' + med.name
      + '</strong> is not authorised for <strong>' + scope
      + '</strong> scope in NEPT.</div>';
  }

  // ── Get indication keywords for this CPP ──────────────────────────────
  var cppFilter = (CPP_MED_IND[cppId] && CPP_MED_IND[cppId][med.id]) || null;

  // Helper: does a dose entry's indication match this CPP context?
  function indicationMatches(d) {
    if (!cppFilter) return true; // no filter = show all
    var ind = (d.indication || '').toLowerCase();
    return cppFilter.some(function(kw) { return ind.indexOf(kw.toLowerCase()) !== -1; });
  }

  // ── Paediatric CPPs ────────────────────────────────────────────────────
  if (isPaed) {
    var paedDoses = (med.dosing && med.dosing.paediatric) || [];

    // Special case: Adrenaline in paediatric anaphylaxis/asthma
    if (med.id === 'ADRENALINE' && (cppId === 'CPP022' || cppId === 'CPP019')) {
      html += '<div class="md-section-label">Auto-injector — preferred first line</div>';
      html += '<div class="md-dose-row">';
      html += '<div class="md-dose-amount">150 mcg</div>';
      html += '<div class="md-dose-route">IM mid-outer thigh — EpiPen<sup>®</sup> Jr</div>';
      html += '<div class="md-dose-indication">Child 7.5–20 kg</div></div>';
      html += '<div class="md-dose-row">';
      html += '<div class="md-dose-amount">300 mcg</div>';
      html += '<div class="md-dose-route">IM mid-outer thigh — EpiPen<sup>®</sup> / Anapen<sup>®</sup></div>';
      html += '<div class="md-dose-indication">Child &gt;20 kg</div></div>';
      html += '<div class="md-note-box">&#9432; Use EpiPen Jr (150 mcg) where available for children 7.5–20 kg. '
            + 'Use the adult EpiPen (300 mcg) only if EpiPen Jr is unavailable.</div>';

      // Weight-based ampoule dose if scope allows 1:1000 ampoule
      var ampScopes = ['RN','RNCC','ATA'];
      if (ampScopes.indexOf(scope) !== -1 || authStr.indexOf('TE') !== -1) {
        html += '<div class="md-section-label" style="margin-top:14px;">1:1000 Ampoule'
              + (authStr.indexOf('TE') !== -1 ? ' <span class="md-dose-te">TE</span>' : '') + '</div>';
        html += '<div class="md-dose-row">'
              + '<div class="md-dose-amount">0.01 mg/kg</div>'
              + '<div class="md-dose-route">IM (1:1000) — max 0.5 mg (500 mcg)</div>'
              + '<div class="md-dose-indication">Refer to paediatric dosing chart if unknown weight</div>'
              + '</div>';
        // Mini weight calculator
        html += renderPaedCalcWidget(med.id, cppId);
      }
    } else if (med.id === 'ADRENALINE' && cppId === 'CPP005') {
      // Cardiac arrest — weight-based IV/IO
      html += '<div class="md-section-label">Cardiac Arrest — IV/IO</div>';
      html += '<div class="md-dose-row">'
            + '<div class="md-dose-amount">0.01 mg/kg</div>'
            + '<div class="md-dose-route">IV/IO bolus</div>'
            + '<div class="md-dose-indication">Every 4 minutes (every 2nd CPR cycle) — no maximum during arrest</div>'
            + '</div>';
      html += renderPaedCalcWidget(med.id, cppId);
    } else {
      // Other meds in paediatric CPPs — show paed doses if available
      var showDoses = paedDoses.filter(function(d) {
        var inScope = d.scopes && d.scopes.indexOf(scope) !== -1;
        var inTE = d.te_scopes && d.te_scopes.indexOf(scope) !== -1;
        return (inScope || inTE) && indicationMatches(d);
      });

      if (showDoses.length) {
        html += '<div class="md-section-label">Paediatric Doses — ' + scope + '</div>';
        showDoses.forEach(function(d) {
          var te = d.te_scopes && d.te_scopes.indexOf(scope) !== -1 && !(d.scopes && d.scopes.indexOf(scope) !== -1);
          html += '<div class="md-dose-row">'
                + '<div class="md-dose-amount">' + d.dose + (te ? '<span class="md-dose-te">TE</span>' : '') + '</div>'
                + '<div class="md-dose-route">' + (d.route || '') + '</div>'
                + (d.indication ? '<div class="md-dose-indication">' + d.indication + '</div>' : '')
                + '</div>';
        });
      } else {
        // Fall back to adult doses filtered by indication
        var adultDoses = ((med.dosing && med.dosing.adult) || []).filter(function(d) {
          var inScope = d.scopes && d.scopes.indexOf(scope) !== -1;
          var inTE = d.te_scopes && d.te_scopes.indexOf(scope) !== -1;
          return (inScope || inTE) && indicationMatches(d);
        });
        if (adultDoses.length) {
          html += '<div class="md-section-label">Doses — ' + scope + '</div>';
          adultDoses.forEach(function(d) {
            var te = d.te_scopes && d.te_scopes.indexOf(scope) !== -1 && !(d.scopes && d.scopes.indexOf(scope) !== -1);
            html += '<div class="md-dose-row">'
                  + '<div class="md-dose-amount">' + d.dose + (te ? '<span class="md-dose-te">TE</span>' : '') + '</div>'
                  + '<div class="md-dose-route">' + (d.route || '') + '</div>'
                  + (d.indication ? '<div class="md-dose-indication">' + d.indication + '</div>' : '')
                  + '</div>';
          });
        }
      }
    }
  } else {
    // ── Adult CPPs ─────────────────────────────────────────────────────────
    var doses = ((med.dosing && med.dosing.adult) || []).filter(function(d) {
      var inScope = d.scopes && d.scopes.indexOf(scope) !== -1;
      var inTE = d.te_scopes && d.te_scopes.indexOf(scope) !== -1;
      return (inScope || inTE) && indicationMatches(d);
    });

    if (doses.length) {
      html += '<div class="md-section-label">Dose — ' + scope + '</div>';
      doses.forEach(function(d) {
        var te = d.te_scopes && d.te_scopes.indexOf(scope) !== -1 && !(d.scopes && d.scopes.indexOf(scope) !== -1);
        html += '<div class="md-dose-row">'
              + '<div class="md-dose-amount">' + d.dose + (te ? '<span class="md-dose-te">TE</span>' : '') + '</div>'
              + '<div class="md-dose-route">' + d.route + '</div>'
              + (d.indication ? '<div class="md-dose-indication">' + d.indication + '</div>' : '')
              + '</div>';
      });
    } else if (!html) {
      html += '<div class="md-no-auth" style="background:#f0f9ff;border-color:#bae6fd;color:#0369a1;">'
            + '&#8505; No dose listed for this indication and scope.</div>';
    }
  }

  // ── Repeat dosing — filtered to relevant indication ────────────────────
  if (med.repeat_dosing) {
    var repeatKeys = Object.keys(med.repeat_dosing).filter(function(k) {
      if (!cppFilter) return true;
      return cppFilter.some(function(kw) { return k.toLowerCase().indexOf(kw.toLowerCase()) !== -1; });
    });
    if (repeatKeys.length) {
      html += '<div class="md-section-label" style="margin-top:14px;">Repeat &amp; Maximum</div>';
      repeatKeys.forEach(function(key) {
        var r = med.repeat_dosing[key];
        html += '<div class="md-repeat-box">';
        if (repeatKeys.length > 1) html += '<div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;margin-bottom:4px;">' + key.replace(/_/g,' ') + '</div>';
        if (r.rule) html += '<div class="md-repeat-rule">' + r.rule + '</div>';
        if (r.maximum) html += '<div class="md-repeat-max">Max: ' + r.maximum + '</div>';
        if (r.note) html += '<div class="md-repeat-note">' + r.note + '</div>';
        html += '</div>';
      });
    }
  }

  return html || '<div style="color:#94a3b8;font-size:12px;padding:8px 0;">No dose data available for this CPP and scope.</div>';
}

// ── Paediatric weight calculator widget ───────────────────────────────────
function renderPaedCalcWidget(medId, cppId) {
  var uid = 'pwc_' + medId + '_' + cppId;
  // Register wheel — callback fires calcPaedDose
  var wheelId = uid + '_age';
  var wtCb = "calcPaedDose('" + uid + "','" + medId + "','" + cppId + "')";
  var ageCb = function(id, val, unit) { calcPaedDose(uid, medId, cppId); };
  // Build HTML — wheel built lazily after insertion
  var html = '<div class="md-paed-calc" id="' + uid + '">'
    + '<div class="md-paed-calc-title">&#9881; Dose calculator</div>'
    + '<div class="md-paed-calc-row">'
    + '<div class="md-paed-input-group">'
    + '<label>Age</label>'
    + '<div id="' + wheelId + '_container"></div>'
    + '</div>'
    + '<div class="md-paed-or">or</div>'
    + '<div class="md-paed-input-group">'
    + '<label>Weight</label>'
    + '<input id="' + uid + '_wt" type="number" min="1" max="80" step="0.5" placeholder="—"'
    + ' oninput="' + wtCb + '" class="md-paed-wt-input"/>'
    + '<span class="md-paed-unit">kg</span>'
    + '</div>'
    + '</div>'
    + '<div class="md-paed-calc-result" id="' + uid + '_result"></div>'
    + '</div>';
  // Inject wheel after a tick so container exists in DOM
  setTimeout(function() {
    var cont = document.getElementById(wheelId + '_container');
    if (cont) {
      cont.innerHTML = buildAgeWheel(wheelId, 'years', 16, function() { calcPaedDose(uid, medId, cppId); });
    }
  }, 0);
  return html;
}

function calcPaedDose(uid, medId, cppId) {
  var wtInput = document.getElementById(uid + '_wt');
  var result  = document.getElementById(uid + '_result');
  if (!result) return;

  var wt  = wtInput ? parseFloat(wtInput.value) : NaN;
  // Read age from scroll wheel
  var ageData = ageWheelGet(uid + '_age');
  var age = null; var ageUnit = 'years';
  if (ageData && ageData.value !== null) {
    age = ageData.value; ageUnit = ageData.unit;
  }

  // Derive working weight
  var wtEstimated = false; var wtSource = '';
  if (!wt || isNaN(wt)) {
    if (age !== null) {
      var ageMonths = ageUnit === 'months' ? age : age * 12;
      if (ageMonths < 3)        wt = 6;
      else if (ageMonths < 12)  wt = 8;
      else if (ageMonths < 48)  wt = Math.round((ageMonths/12*2+8)*10)/10;
      else                       wt = Math.round(Math.min(80, ageMonths/12*3.3)*10)/10;
      wtEstimated = true;
      wtSource = '(estimated — ' + age + ' ' + (ageUnit==='months'?'mo':'yr') + ')';
    }
  }

  if (!wt || isNaN(wt)) { result.innerHTML = ''; return; }

  var html = '';

  // Estimated weight note
  if (wtEstimated) {
    html += '<div class="md-calc-est-note">&#9432; Using estimated weight: <strong>' + wt + ' kg</strong> ' + wtSource + '</div>';
  } else if (!isNaN(wt) && age !== null) {
    var ageMonths2 = ageUnit === 'months' ? age : age * 12;
    var estWt = ageMonths2 < 48 ? ageMonths2/12*2+8 : ageMonths2/12*3.3;
    if (Math.abs(wt - estWt) > estWt * 0.3) {
      html += '<div class="md-calc-warn-note">&#9888; Actual weight (' + wt + ' kg) differs from age estimate (' + Math.round(estWt) + ' kg). Using actual weight.</div>';
    }
  }

  if (medId === 'ADRENALINE') {
    if (cppId === 'CPP005') {
      var dose_mg = Math.round(wt * 0.01 * 100) / 100;
      var dose_ml = dose_mg.toFixed(2);
      html += '<div class="md-calc-row"><span class="md-calc-label">Dose (0.01 mg/kg):</span><span class="md-calc-value">' + dose_mg.toFixed(2) + ' mg &nbsp;|&nbsp; ' + dose_ml + ' mL of 1:1000</span></div>';
      html += '<div class="md-calc-row"><span class="md-calc-label">Max:</span><span class="md-calc-value">No maximum during arrest</span></div>';
      html += '<div class="md-calc-row"><span class="md-calc-label">Repeat:</span><span class="md-calc-value">Every 4 min (every 2nd cycle)</span></div>';
    } else {
      var raw_mg = Math.round(wt * 0.01 * 100) / 100;
      var capped = raw_mg > 0.5;
      var dose_mg = capped ? 0.5 : raw_mg;
      var dose_ml = dose_mg.toFixed(2);
      var autoInj = '';
      if (wt < 7.5)     autoInj = 'Auto-injector not suitable below 7.5 kg \u2014 use 1:1000 ampoule';
      else if (wt < 20) autoInj = 'EpiPen\u00ae Jr 150 mcg \u2714  <span style="color:#475569;font-weight:500;">(child 7.5\u201320 kg)</span>';
      else              autoInj = 'EpiPen\u00ae 300 mcg \u2714  <span style="color:#475569;font-weight:500;">(child &gt;20 kg)</span>';
      html += '<div class="md-calc-row"><span class="md-calc-label">Auto-injector:</span><span class="md-calc-value">' + autoInj + '</span></div>';
      if (wt >= 7.5 && wt < 20) {
        html += '<div class="md-calc-row" style="padding-left:8px;"><span class="md-calc-label" style="color:#d97706;">If Jr unavailable:</span><span class="md-calc-value" style="color:#b45309;">EpiPen\u00ae 300 mcg (adult)</span></div>';
      }
      html += '<div class="md-calc-row"><span class="md-calc-label">IM ampoule:</span><span class="md-calc-value">' + dose_mg.toFixed(2) + ' mg' + (capped ? ' \u2190 capped at 0.5 mg' : ' (0.01 mg/kg)') + ' &nbsp;|&nbsp; ' + dose_ml + ' mL of 1:1000</span></div>';
    }
  } else if (medId === 'SALBUTAMOL') {
    var puffs = wt >= 6 ? '4\u201312 puffs' : '2\u20136 puffs';
    var neb   = wt < 20 ? '2.5 mg' : '5 mg';
    html += '<div class="md-calc-row"><span class="md-calc-label">pMDI + spacer:</span><span class="md-calc-value">' + puffs + '</span></div>';
    html += '<div class="md-calc-row"><span class="md-calc-label">Nebulised:</span><span class="md-calc-value">' + neb + '</span></div>';
  } else if (medId === 'IPRATROPIUM') {
    html += '<div class="md-calc-row"><span class="md-calc-label">Nebulised:</span><span class="md-calc-value">0.25 mg (all paediatric ages)</span></div>';
  }

  result.innerHTML = html;
}



// ── List panel renderer (CI / precautions / side effects) ─────────────────
function renderMdList(data, type, emptyMsg) {
  var items = [];
  if (!data) return '<p style="color:#94a3b8;font-size:12px;">' + emptyMsg + '</p>';
  if (typeof data === 'string') {
    items = data.split(/[.;]/).map(function(s){return s.trim();}).filter(function(s){return s.length > 2;});
  } else if (Array.isArray(data)) {
    items = data;
  }
  if (!items.length) return '<p style="color:#94a3b8;font-size:12px;">' + emptyMsg + '</p>';
  var html = '<ul class="md-list ' + type + '">';
  items.forEach(function(item) { html += '<li>' + item + '</li>'; });
  html += '</ul>';
  return html;
}


// ─── Scroll-wheel age picker ──────────────────────────────────────────────
// State: { value: number|null, unit: 'years'|'months', max }
var _ageWheels = {};

function ageWheelInit(id, unit, max, onchange) {
  _ageWheels[id] = { value: null, unit: unit || 'years', max: max || 12, onchange: onchange };
}

function ageWheelStep(id, delta) {
  var w = _ageWheels[id];
  if (!w) return;
  var max = w.unit === 'months' ? 11 : w.max;
  var cur = (w.value === null) ? (delta > 0 ? 0 : max) : w.value;
  w.value = Math.max(0, Math.min(max, cur + delta));
  _ageWheelRender(id);
  if (w.onchange) w.onchange(id, w.value, w.unit);
}

function ageWheelSetUnit(id, unit) {
  var w = _ageWheels[id];
  if (!w) return;
  w.unit = unit;
  w.value = null; // reset value when switching unit
  // Update buttons
  var wrap = document.getElementById(id + '_unitwrap');
  if (wrap) {
    wrap.querySelectorAll('.age-wheel-unit-btn').forEach(function(b) {
      b.classList.toggle('active', b.getAttribute('data-unit') === unit);
    });
  }
  _ageWheelRender(id);
  if (w.onchange) w.onchange(id, w.value, w.unit);
}

function ageWheelClear(id) {
  var w = _ageWheels[id];
  if (!w) return;
  w.value = null;
  _ageWheelRender(id);
  if (w.onchange) w.onchange(id, null, w.unit);
}

function _ageWheelRender(id) {
  var w = _ageWheels[id];
  var disp = document.getElementById(id + '_disp');
  if (!disp) return;
  if (w.value === null) {
    disp.textContent = '—';
    disp.classList.add('empty');
  } else {
    disp.textContent = w.value;
    disp.classList.remove('empty');
  }
}

function ageWheelGet(id) {
  var w = _ageWheels[id]; if (!w) return null;
  return { value: w.value, unit: w.unit };
}

function buildAgeWheel(id, unit, max, onchange) {
  ageWheelInit(id, unit, max, onchange);
  var u = unit || 'years';
  return '<div class="age-wheel-wrap" id="' + id + '_wrap">'
    + '<button class="age-wheel-btn" onclick="ageWheelStep(\'' + id + '\',1)">&#9650;</button>'
    + '<div class="age-wheel-display empty" id="' + id + '_disp">—</div>'
    + '<button class="age-wheel-btn" onclick="ageWheelStep(\'' + id + '\',-1)">&#9660;</button>'
    + '<div class="age-wheel-unit-toggle" id="' + id + '_unitwrap">'
    + '<button class="age-wheel-unit-btn' + (u==='years'?' active':'') + '" data-unit="years" onclick="ageWheelSetUnit(\'' + id + '\',\'years\')">yrs</button>'
    + '<button class="age-wheel-unit-btn' + (u==='months'?' active':'') + '" data-unit="months" onclick="ageWheelSetUnit(\'' + id + '\',\'months\')">mo</button>'
    + '</div>'
    + '</div>';
}

</script>

<!-- Med info drawer -->
<div id="med-drawer-backdrop" onclick="closeMedDrawer()"></div>
<div id="med-drawer" role="dialog" aria-label="Medication information">
  <div id="med-drawer-inner">
    <div id="med-drawer-header">
      <div style="flex:1;min-width:0;">
        <div id="med-drawer-name">—</div>
        <div id="med-drawer-class"></div>
      </div>
      <div id="med-drawer-scope-tag">—</div>
      <div id="med-drawer-close" onclick="closeMedDrawer()" title="Close (Esc)">&#215;</div>
    </div>
    <div class="md-tabs">
      <div class="md-tab active" data-tab="dose" onclick="mdSwitchTab('dose')">&#128138; Dose</div>
      <div class="md-tab" data-tab="ci" onclick="mdSwitchTab('ci')">&#10005; Contra&shy;indications</div>
      <div class="md-tab" data-tab="prec" onclick="mdSwitchTab('prec')">&#9888; Precautions</div>
      <div class="md-tab" data-tab="se" onclick="mdSwitchTab('se')">&#9898; Side Effects</div>
    </div>
    <div id="med-drawer-body">
      <div id="md-panel-dose" class="md-panel active"></div>
      <div id="md-panel-ci" class="md-panel"></div>
      <div id="md-panel-prec" class="md-panel"></div>
      <div id="md-panel-se" class="md-panel"></div>
    </div>
  </div>
</div>
<script>
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('./sw.js')
      .then(reg => console.log('NEPT SW registered:', reg.scope))
      .catch(err => console.log('SW registration failed:', err));
  });
}
</script>
