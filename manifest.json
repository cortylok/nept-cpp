              "text": "Confirm cardiac arrest: unconscious, not breathing normally, no/unsure pulse",
              "note": ""
            },
            {
              "step": 2,
              "text": "Commence high-quality CPR immediately: 100\u2013120/min, \u22655cm depth, full recoil",
              "note": ""
            },
            {
              "step": 3,
              "text": "Apply defibrillation pads while minimising interruption to CPR",
              "note": ""
            },
            {
              "step": 4,
              "text": "Escalate per CPP006 as early as practicable",
              "note": ""
            },
            {
              "step": 5,
              "text": "Follow AED instructions OR analyse rhythm",
              "note": ""
            },
            {
              "step": 6,
              "text": "SHOCKABLE (VF/VT): Press shock / Defibrillate 200J. Immediately recommence compressions",
              "note": "AED / Manual"
            },
            {
              "step": 7,
              "text": "NON-SHOCKABLE (PEA/Asystole): Disarm (manual only). Immediately recommence compressions",
              "note": ""
            },
            {
              "step": 8,
              "text": "Apply additional interventions where accredited (where scope permits). Prioritise CPR and defibrillation above all else",
              "note": ""
            },
            {
              "step": 9,
              "text": "Insert OPA/NPA/SGA as per scope",
              "note": "OPA/NPA/SGA"
