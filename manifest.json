            },
            {
              "step": 8,
              "text": "Expose \u2014 identify injuries/signs. Consider temperature",
              "note": ""
            },
            {
              "step": 9,
              "text": "Secondary survey \u2014 SAMPLE history, head-to-toe assessment",
              "note": ""
            },
            {
              "step": 10,
              "text": "Manage identified conditions per applicable CPP",
              "note": ""
            },
