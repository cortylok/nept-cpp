        {
          "id": "ASSESS_RSA",
          "title": "NEPT Respiratory Status Assessment (RSA) \u2013 Adult",
          "category": "Assessment Tools",
          "scope": "RN",
          "background": "RSA assesses both ventilation (movement of air in/out) and gas exchange (O2/CO2 at alveolar level). No single sign constitutes respiratory status \u2014 assess as a collection.",
          "recognition": [],
          "memory_items": [],
          "checklist_steps": [],
          "special_notes": [],
          "decision_tree": [],
          "medications_used": [],
