        {
      "id": "ASSESS_GCS_AVPU",
      "title": "Glasgow Coma Scale / AVPU",
      "category": "Assessment Tools",
      "scope_applicable": ["PTO","EN","ATA","RN","RNCC"],
      "background": "GCS objectively quantifies impaired consciousness. Express as E+V+M sum (3–15). Any change must be noted and escalated. AVPU is a rapid, simpler consciousness scale used as an initial screen.",
      "gcs_adult": {
        "eye_response": [
          {"score": 4, "description": "Eyes open spontaneously"},
          {"score": 3, "description": "Eyes open to sound/speech"},
          {"score": 2, "description": "Eyes open to pain"},
          {"score": 1, "description": "No eye opening"}
        ],
        "verbal_response": [
          {"score": 5, "description": "Orientated — knows name, place, date"},
          {"score": 4, "description": "Confused — conversation but disoriented"},
          {"score": 3, "description": "Words only — isolated words, no sustained conversation"},
          {"score": 2, "description": "Sounds — moans/groans, no recognisable words"},
          {"score": 1, "description": "No verbal response"}
        ],
        "motor_response": [
          {"score": 6, "description": "Obeys commands"},
          {"score": 5, "description": "Localises pain — purposeful movement toward stimulus"},
          {"score": 4, "description": "Withdrawal from pain — pulls away, not localised"},
          {"score": 3, "description": "Abnormal flexion to pain (decorticate posturing)"},
          {"score": 2, "description": "Abnormal extension to pain (decerebrate posturing)"},
          {"score": 1, "description": "No motor response"}
        ]
      },
      "gcs_paediatric": {
        "note": "Children ≤4 years use modified verbal scale. Children >4 years assessed against adult GCS.",
        "verbal_response": [
          {"score": 5, "description": "Appropriate words or social smile"},
          {"score": 4, "description": "Cries but consolable"},
          {"score": 3, "description": "Persistently irritable"},
          {"score": 2, "description": "Moans to pain"},
          {"score": 1, "description": "No verbal response"}
        ],
        "eye_response_note": "Same as adult (4-point scale)",
        "motor_response_note": "Same as adult (6-point scale)"
      },
      "avpu": {
        "levels": [
          {"level": "A", "description": "Alert — aware of examiner, responds to environment independently, follows commands, opens eyes spontaneously, tracks objects"},
          {"level": "V", "description": "Verbally Responsive — eyes do not open spontaneously; opens and responds meaningfully only to verbal stimulus directed toward them"},
          {"level": "P", "description": "Painfully Responsive — eyes do not open spontaneously; responds only to painful stimuli with movement, moaning or crying"},
          {"level": "U", "description": "Unresponsive — no spontaneous response; no response to verbal or painful stimuli"}
        ]
      },
      "memory_items": [
        "GCS = E (4) + V (5) + M (6). Minimum score 3, maximum 15",
        "GCS <13 in adults (≥16 yrs) = time critical. GCS <15 in paeds (≤15 yrs) = time critical",
        "GCS 13–15 = mild impairment | 9–12 = moderate | ≤8 = severe",
        "AVPU: anything less than Alert warrants concern and reassessment",
        "Paediatric verbal scale differs for children ≤4 years"
      ],
      "checklist_steps": [],
      "decision_tree": [],
      "flowchart_image": null,
      "medications_used": [],
      "quiz_triggers": [
        "A patient opens eyes to pain, speaks confused words, and localises pain — what is their GCS?",
        "What GCS score indicates severe impairment?",
        "A patient opens their eyes only when you call their name. What is their AVPU?",
        "What modified GCS scale is used for children ≤4 years?"
      ]
    },
    {
      "id": "ASSESS_PAT",
      "title": "Paediatric Assessment Triangle (PAT)",
      "category": "Assessment Tools",
      "scope_applicable": ["PTO","EN","ATA","RN","RNCC"],
      "background": "The PAT is a rapid 30–60 second visual and auditory assessment requiring no equipment. It provides an immediate impression of a paediatric patient's overall status and helps determine urgency and management priority. Parent or caregiver concern alone is sufficient reason to escalate care, even without other identifiable markers.",
      "pat_components": {
        "appearance": {
          "label": "Appearance",
          "mnemonic": "TICLS",
          "items": [
            {"key": "T", "label": "Tone", "detail": "Assess muscle tone — is the child moving all limbs, sitting upright, or limp/hypotonic?"},
            {"key": "I", "label": "Interactiveness", "detail": "How alert and engaged is the child with you, caregivers, and the environment?"},
            {"key": "C", "label": "Consolability", "detail": "Can the child be comforted by a caregiver? Inconsolable crying is a concerning sign."},
            {"key": "L", "label": "Look/Gaze", "detail": "Does the child track faces or objects? A blank or glassy gaze is abnormal."},
            {"key": "S", "label": "Speech/Cry", "detail": "Is the cry strong and normal, or weak, high-pitched, or absent?"}
          ]
        },
        "work_of_breathing": {
          "label": "Work of Breathing",
          "detail": "Assessed by listening and watching — do not wait for numbers.",
          "items": [
            "Abnormal airway sounds: stridor, grunting, gurgling, wheezing",
            "Abnormal positioning: sniffing, tripod, refusing to lie down",
            "Retractions: intercostal, subcostal, suprasternal, supraclavicular",
            "Nasal flaring",
            "Head bobbing (infants) — a sign of severe respiratory distress"
          ]
        },
        "circulation_to_skin": {
          "label": "Circulation to Skin",
          "detail": "Central versus peripheral perfusion assessed visually.",
          "items": [
