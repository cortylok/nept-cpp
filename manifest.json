    cursor: default; user-select: none; font-family: monospace;
  }
  .age-wheel-display.empty { color: #cbd5e1; font-size: 16px; }
  .age-wheel-unit-toggle {
    display: flex; border-radius: 7px; overflow: hidden;
    border: 1.5px solid #bfdbfe; margin-top: 4px; width: 64px;
  }
  .age-wheel-unit-btn {
    flex: 1; padding: 5px 4px;
    font-size: 12px; font-weight: 700; cursor: pointer;
    background: #fff; color: #64748b; border: none; outline: none;
    transition: background .15s, color .15s;
    user-select: none;
  }
  .age-wheel-unit-btn.active { background: #3b82f6; color: #fff; }

  /* ── Med drawer calc — readable text ── */
  .md-paed-calc { background: #f0f9ff; border: 1px solid #7dd3fc; border-radius: 8px; padding: 14px 14px 12px; margin-top: 14px; }
  .md-paed-calc-title { font-size: 11px; font-weight: 700; color: #0369a1; margin-bottom: 12px; letter-spacing: .03em; }
  .md-paed-calc-row { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; justify-content: center; }
  .md-paed-input-group { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .md-paed-input-group label {
    font-size: 11px; font-weight: 700; color: #1e3a8a;
    text-transform: uppercase; letter-spacing: .05em; white-space: nowrap;
  }
  .md-paed-or { font-size: 12px; color: #64748b; font-style: italic; }
  .md-paed-unit { font-size: 12px; color: #374151; font-weight: 600; margin-top: 2px; }
  .md-paed-wt-input {
    width: 70px; padding: 6px 8px;
    border: 1.5px solid #7dd3fc; border-radius: 6px;
    font-size: 18px; font-weight: 700; color: #1e3a8a;
    background: #fff; outline: none; text-align: center;
    font-family: monospace;
  }
  .md-paed-wt-input:focus { border-color: #3b82f6; box-shadow: 0 0 0 2px #bfdbfe; }
  .md-paed-calc-result { margin-top: 10px; }
  .md-calc-row { display: flex; gap: 8px; align-items: baseline; padding: 5px 0; border-bottom: 1px solid #e0f2fe; font-size: 12px; }
  .md-calc-row:last-child { border-bottom: none; }
  .md-calc-label { color: #374151; font-weight: 600; flex-shrink: 0; min-width: 110px; }
  .md-calc-value { color: #0c4a6e; font-weight: 700; }
  .md-calc-est-note { font-size: 11px; color: #0369a1; background: #e0f2fe; border-radius: 4px; padding: 5px 8px; margin-bottom: 8px; border: 1px solid #bae6fd; }
  .md-calc-warn-note { font-size: 11px; color: #92400e; background: #fffbeb; border-radius: 4px; padding: 5px 8px; margin-bottom: 8px; border: 1px solid #fde68a; }
  .md-note-box { background: #fffbeb; border: 1px solid #fde68a; border-radius: 6px; padding: 9px 12px; font-size: 11px; color: #92400e; margin-top: 10px; line-height: 1.5; }

  /* General paed calc inputs — more readable */
  .paed-label { font-size: 12px; font-weight: 700; color: #1e293b; text-transform: uppercase; letter-spacing: 0.06em; }
  .paed-unit-label { font-size: 13px; color: #1e293b; font-weight: 700; }
  .paed-input-sep { color: #475569; font-size: 13px; font-weight: 600; align-self: center; }
</style>
</head>
