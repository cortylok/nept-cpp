  {"id": "b1", "type": "col_body", "col": 1, "text": "Deliver shock\nResume CPR immediately (2 mins)\nIV/IO access\nAdrenaline every 2nd cycle\nAmiodarone after 3rd shock"},

  {"id": "h2", "type": "col_header", "col": 2, "text": "NON-SHOCKABLE\nAsystole / PEA"},
  {"id": "b2", "type": "col_body", "col": 2, "text": "Continue CPR (2 mins)\nIV/IO access\nAdrenaline ASAP\nRepeat every 2nd cycle"},

  {"id": "f0", "type": "col_footer", "col": 0, "text": "Reassess rhythm every 2 mins\nMinimise interruptions"},
  {"id": "f1", "type": "col_footer", "col": 1, "text": "Treat reversible causes\n4 Hs & 4 Ts"},
  {"id": "f2", "type": "col_footer", "col": 2, "text": "Continue ALS algorithm\nConsider termination criteria"},

  {"id": "end", "type": "footer", "text": "ROSC → Post-resuscitation care\nMaintain SpO₂ 94–98%\n12-lead ECG\nManage hypotension"}
