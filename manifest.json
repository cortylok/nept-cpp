  .abbr-table tr:hover td { background: var(--bg3); }
  .abbr-search { width: 100%; box-sizing: border-box; padding: 8px 12px; background: var(--bg3); border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-size: 13px; margin-bottom: 8px; }
  .abbr-search:focus { outline: none; border-color: var(--accent); }

  /* Pharmacology cards */
  .drug-card { border: 1px solid var(--border); border-radius: 8px; margin: 10px 12px; overflow: hidden; }
  .drug-card-header { padding: 10px 14px; background: var(--bg3); cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
  .drug-card-name { font-size: 14px; font-weight: 700; color: var(--text); }
  .drug-card-chevron { color: var(--text3); font-size: 12px; transition: transform 0.2s; }
  .drug-card.open .drug-card-chevron { transform: rotate(180deg); }
  .drug-card-body { display: none; padding: 0; }
  .drug-card.open .drug-card-body { display: block; }
  .drug-row { display: flex; border-top: 1px solid var(--border); font-size: 12px; }
  .drug-row-label { min-width: 110px; max-width: 110px; padding: 8px 10px; background: var(--bg3); font-weight: 600; color: var(--text2); font-size: 11px; }
  .drug-row-val { padding: 8px 10px; color: var(--text); line-height: 1.55; flex: 1; }
  .drug-row-val ul { margin: 0; padding-left: 14px; }
  .drug-row-val li { margin-bottom: 2px; }

  /* Equipment list */
  .equip-col-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; }
  .equip-col { border: 1px solid var(--border); padding: 10px 12px; font-size: 12px; }
  .equip-col-title { font-weight: 700; color: var(--accent); font-size: 11px; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 8px; }
  .equip-item { padding: 3px 0; border-bottom: 1px solid rgba(255,255,255,0.04); color: var(--text); line-height: 1.4; }
  @media (max-width: 600px) { .equip-col-grid { grid-template-columns: 1fr; } }


  /* ── Drug name triggers in quick-ref cards ── */
  .med-trigger {
    display: inline;
    cursor: pointer;
    border-bottom: 1px dashed var(--blue, #3b82f6);
    color: inherit;
    white-space: nowrap;
  }
  .med-trigger:hover {
    background: #eff6ff;
    border-radius: 2px;
  }
  .med-trigger-arrow {
    display: inline-block;
    font-size: 9px;
    color: #3b82f6;
    margin-left: 2px;
    vertical-align: middle;
    line-height: 1;
    user-select: none;
    transition: transform .15s;
  }
  .med-trigger:hover .med-trigger-arrow {
    color: #1d4ed8;
  }

  /* ── Med info drawer ── */
  #med-drawer {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 5000;
    transform: translateY(100%);
