  .age-wheel-btn:hover { background: #dbeafe; }
  .age-wheel-btn:active { background: #bfdbfe; }
  .age-wheel-display {
    width: 64px; height: 48px;
    background: #fff; border: 2px solid #3b82f6; border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
