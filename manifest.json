  .splash-footer {
    margin-top: 20px; font-size: 10px; color: #334155;
    text-align: center; line-height: 1.6;
  }

  /* Paediatric Weight Calculator */
  .paed-calc { padding: 16px; max-width: 600px; }
  .paed-calc-header { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
  .paed-calc-icon { font-size: 32px; }
  .paed-calc-title { font-size: 16px; font-weight: 800; color: var(--text); }
  .paed-calc-sub { font-size: 11px; color: var(--text3); font-family: var(--mono); margin-top: 2px; }
  .paed-calc-inputs { display: flex; gap: 20px; align-items: center; flex-wrap: wrap; justify-content: center; margin-bottom: 20px; background: var(--bg3); border-radius: 10px; padding: 20px; border: 1px solid var(--border); }
  .paed-input-group { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .paed-label { font-size: 11px; font-weight: 600; color: var(--text2); text-transform: uppercase; letter-spacing: 0.06em; }
  .paed-age-row { display: flex; gap: 6px; align-items: center; }
  .paed-input { background: var(--bg); border: 1px solid var(--border); border-radius: 7px; color: var(--text); padding: 8px 10px; font-size: 15px; font-family: var(--mono); width: 90px; }
  .paed-input:focus { outline: none; border-color: var(--accent); }
  .paed-select { background: var(--bg); border: 1px solid var(--border); border-radius: 7px; color: var(--text); padding: 8px 10px; font-size: 13px; }
  .paed-unit-label { font-size: 13px; color: var(--text2); font-weight: 600; }
  .paed-input-sep { color: var(--text3); font-size: 12px; align-self: center; padding-top: 16px; }
  
  .paed-result { }
  .paed-result-header { background: linear-gradient(135deg, rgba(59,130,246,0.15), rgba(16,185,129,0.1)); border: 1px solid rgba(59,130,246,0.25); border-radius: 10px; padding: 14px 16px; margin-bottom: 16px; }
  .paed-result-age { font-size: 13px; color: var(--text3); margin-bottom: 2px; }
  .paed-result-weight { font-size: 22px; font-weight: 800; color: var(--text); }
  .paed-result-weight span { color: var(--accent); }
  .paed-result-group { font-size: 12px; color: var(--text2); margin-top: 4px; font-style: italic; }
  
  .paed-section-title { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text2); font-family: var(--mono); padding: 10px 0 6px; border-top: 1px solid var(--border); margin-top: 4px; }
  
  .paed-vss-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-bottom: 6px; }
  .paed-vss-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 10px 8px; text-align: center; }
  .paed-vss-label { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 4px; }
  .paed-vss-val { font-size: 16px; font-weight: 800; color: var(--green); font-family: var(--mono); }
  .paed-vss-unit { font-size: 10px; color: var(--text3); margin-top: 2px; }
  .paed-vss-note { font-size: 10px; color: var(--text3); font-style: italic; margin-bottom: 4px; }
  
  .paed-cpr-box { background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2); border-radius: 8px; padding: 10px 12px; font-size: 12px; color: var(--text); line-height: 1.6; margin-bottom: 4px; }
  
  .paed-drug-table { border: 1px solid var(--border); border-radius: 8px; overflow: hidden; margin-bottom: 4px; }
  .paed-drug-header { display: grid; grid-template-columns: 2fr 2fr 1.5fr; background: var(--bg3); padding: 6px 10px; font-size: 10px; font-weight: 700; color: var(--text2); text-transform: uppercase; letter-spacing: 0.06em; }
  .paed-drug-row { display: grid; grid-template-columns: 2fr 2fr 1.5fr; padding: 8px 10px; border-top: 1px solid var(--border); font-size: 12px; align-items: start; gap: 4px; }
  .paed-drug-row:first-child { border-top: none; }
  .paed-note-row { grid-template-columns: 1fr 3fr; background: rgba(245,158,11,0.06); }
  .paed-drug-name { color: var(--text2); line-height: 1.4; }
  .paed-drug-dose { color: var(--text); font-weight: 600; line-height: 1.4; }
  .paed-drug-dose.accent { color: var(--accent); }
  .paed-drug-max { color: var(--text3); font-size: 11px; line-height: 1.4; }
  .paed-disclaimer { margin-top: 16px; font-size: 11px; color: var(--orange); padding: 8px 10px; background: rgba(245,158,11,0.06); border-radius: 6px; border-left: 3px solid var(--orange); line-height: 1.5; }
  @media (max-width: 480px) {
    .paed-drug-header, .paed-drug-row { grid-template-columns: 1.5fr 1.5fr; }
    .paed-drug-max { display: none; }
